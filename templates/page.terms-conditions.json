        "ai_gen_block_460c19e_nynM4T": {
          "type": "ai_gen_block_460c19e",
          "settings": {
            "max_width": 1000,
            "section_padding_top": 40,
            "section_padding_bottom": 40,
            "section_padding_horizontal": 20,

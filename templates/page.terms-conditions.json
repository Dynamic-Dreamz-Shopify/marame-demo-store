    "new_generic_hero_8hBj8N": {
      "type": "new-generic-hero",
      "disabled": true,
      "settings": {
        "heading": "<h2>TERMS & CONDITIONS</h2><h5>Last updated: 25th March 2025</h5><h5>Welcome to marame.com, the official website of Marame. These Terms & Conditions govern your use of this website, your purchase of products, and your relationship with Marame (referred to as “we”, “us”, or “our”). By accessing our site or placing an order, you agree to be legally bound by these Terms & Conditions. If you do not agree, you should not use this website.</h5>"
      }
    },
    "generic_list_JnjnxK": {
      "type": "generic-list",
      "blocks": {
        "block_nfpAVn": {
          "type": "block",
          "settings": {
            "heading": "COMPANY Information",
            "content": "<h5>Marame Clothing LTD is a registered company in the United Kingdom (Company Registration Number: 14444446). <br/><br/>Registered address: Henge Barn, Pury Hill Business Park, Alderton Road, NN12 7LS. <br/><br/>Email: help@marame.com</h5>",
            "html": ""
          }
        },
        "block_npPH9Y": {
          "type": "block",
          "settings": {
            "heading": "ORDERS & ACCEPTANCE",
            "content": "<h5>All orders are subject to availability and confirmation of payment. Once an order is placed, you will receive a confirmation email. This email is an acknowledgement, not acceptance of your order. A contract between us is formed only when your item is dispatched. We reserve the right to refuse or cancel any order at our discretion, for example, if a product is out of stock, pricing is incorrect, or we suspect fraudulent activity.</h5>",
            "html": ""
          }
        },
        "block_DaPyCP": {
          "type": "block",
          "settings": {
            "heading": "DELIVERY",
            "content": "<h5><strong>UK Delivery</strong></h5><h5>We offer UK delivery via DPD, with the following options:</h5><h5><strong>Standard Delivery </strong>- £2.95<br/><br/><strong>Next Day Delivery</strong> - £4.95<br/><br/><strong>Free Next Day Delivery</strong> - All orders over £200<br/></h5><h5><em>Orders must be placed by 3pm (Monday–Friday, excluding Bank Holidays) to qualify for Next Day Delivery. Orders placed after 3pm or on weekends/bank holidays will be processed on the next working day.</em></h5><h5>All UK orders are shipped via tracked services, and you will receive tracking details once your order has been dispatched.</h5><h5></h5><h5><strong>International Delivery</strong></h5><h5>We offer worldwide delivery from the United Kingdom with two options depending on your preference:</h5><h5><strong>DAP (Delivered At Place)</strong>: Duties and taxes are payable by the customer upon arrival in the destination country. Our delivery partner will contact you to arrange payment before releasing the goods.<br/></h5><h5><strong>DDP (Delivered Duty Paid):</strong> Duties and taxes are included in the shipping price at checkout. No additional payment is required on delivery.<br/></h5><h5>Estimated delivery timeframes are provided at checkout. Please note that these are estimates only and may vary depending on customs clearance, courier processing times, or events beyond our control. Marame cannot be held responsible for delays caused by external factors.</h5><h5></h5><h5><strong>Excluded Destinations</strong></h5><h5>We are unable to ship to the following countries and territories:</h5><h5>Afghanistan, Albania, Antarctica, Argentina, Ascension Islands, Bangladesh, Belarus, Bosnia & Herzegovina, Brazil, British Indian Ocean Territory, Christmas Islands, Cocos (Keeling) Islands, Cuba, East Timor, Easter Island, Egypt, Falkland Island, French Southern Territories, Ghana, Heard/McDonald Island, India, Indonesia, Iran, Israel, Jordan, Kenya, Kiribati, Kuwait, Marshall Islands, Mexico, Micronesia, Moldova, Myanmar, Nauru, Nigeria, Niue, North Korea, Northern Mariana Islands, Norfolk Island, Occupied Palestinian Territory, Oman, Pakistan, Philippines, Pitcairn Island, Qatar, Russia, Sahara, Samoa, Sao Tome & Principe, Saudi Arabia, Serbia, Sierra Leone, Somalia, South Africa, South Georgia/Sandwich Island, Sri Lanka, St Helena, Sudan, Svalbard & Jan Mayan, Syria, Thailand, Tajikistan, Tokelau, Tonga, Tuvalu, Ukraine, US Minor Outlying Island, Venezuela, Vietnam, Wallis and Futuna Islands, Yemen.</h5><h5></h5><h5><strong>Customs Duties and Taxes</strong></h5><h5>For DAP shipments, the customer is responsible for paying any customs duties, taxes, or handling fees required by their local authority. These charges must be settled before delivery can occur.</h5><h5>For DDP shipments, duties and taxes are included in the shipping price at checkout, and no additional payment is required on delivery.</h5><h5></h5><h5><strong>International Returns</strong></h5><h5>International returns are accepted within 14 days of delivery, provided items are unworn, unwashed, in their original condition, and have all original swing tags attached. Delivery costs are non-refundable, and returns must be sent at the customer’s expense. We recommend using a tracked and insured service to ensure your return reaches us safely.</h5><h5><strong>Currency</strong></h5><h5>Where possible, prices will be displayed in the customer’s local currency. If this is not available, prices will default to GBP (£).</h5><h5></h5><h5><strong>Liability for Delays and Losses</strong></h5><h5>While we work closely with our delivery partners to ensure smooth shipping, Marame is not responsible for delays caused by customs clearance procedures, incorrect shipping information provided at checkout, weather conditions, or unforeseen logistical disruptions beyond our control.</h5><h5></h5><h5><strong>Contact Us</strong></h5><h5>For any questions regarding delivery or international shipping, please contact our Customer Care team at help@marame.com.</h5>",
            "html": ""
          }
        },
        "block_t8U8kP": {
          "type": "block",
          "settings": {
            "heading": "Swing tags & Tampering",
            "content": "<h5>Swing tags are attached through buttonholes, zip pulls, or label loops to avoid damaging garments. If a tag has been removed, altered, or there is evidence the item has been worn or tampered with, Marame reserves the right to reject the return.</h5>",
            "html": ""
          }
        },
        "block_gXtzTh": {
          "type": "block",
          "settings": {
            "heading": "Privacy & Cookies",
            "content": "<h5>By using our website, placing an order, or creating an account, you agree to the collection, use, and handling of your data in accordance with our Cookies & Privacy Policy.</h5><ul><li><h5>We use cookies and similar tools to personalise your experience, analyse traffic, and offer relevant promotions (with consent)</h5></li><li><h5>You may access, update, or delete your data at any time by contacting us</h5></li><li><h5>Your rights under the UK GDPR are fully supported by Marame</h5></li></ul>",
            "html": ""
          }
        },
        "block_3Firfq": {
          "type": "block",
          "settings": {
            "heading": "CHANGES TO THESE TERMS",
            "content": "<h5>We may update these Terms & Conditions from time to time to reflect changes in law, operations, or service offerings. Updates will be published on this page and take effect immediately unless otherwise stated. Your continued use of our website confirms your acceptance of any changes.</h5>",
            "html": ""
          }
        },
        "block_anBFRp": {
          "type": "block",
          "settings": {
            "heading": "Contact Us",
            "content": "<h5>If you have any questions about these Terms & Conditions, your order, or your membership, please contact our team:</h5><ul><li><h5>Email: help@marame.com</h5></li><li><h5>Postal Address: Marame, 3 Willows, Mill Farm Courtyard, Beachampton, MK19 6DS</h5></li></ul>",
            "html": ""
          }
        },
        "block_NPdm8W": {
          "type": "block",
          "settings": {
            "heading": "ELIGIBILITY",
            "content": "<h5>To place an order with us, you must be at least 18 years old and possess a valid payment method. By ordering, you confirm that all information provided is accurate, current, and complete.</h5>",
            "html": ""
          }
        },
        "block_eKPXra": {
          "type": "block",
          "settings": {
            "heading": "PRICING & PAYMENT",
            "content": "<h5>All prices are listed in GBP (£) and include VAT (where applicable). Delivery charges (if any) are displayed at checkout. We reserve the right to change prices at any time, but changes will not affect orders already placed. We accept payment via secure third-party payment providers (e.g. Shopify Payments, Klarna, PayPal). By submitting your payment information, you confirm that you are authorised to use the selected method.</h5>",
            "html": ""
          }
        },
        "block_UJxjaP": {
          "type": "block",
          "settings": {
            "heading": "Returns & Exchanges",
            "content": "<h5>You may return eligible items within 14 days of delivery, provided they are:</h5><ul><li><h5>Unworn and unwashed</h5></li><li><h5>In original condition</h5></li><li><h5>Have all original swing tags attached</h5></li></ul><h5><strong>Items bought as gifts between 15 November and 23 December 2025 are eligible for exchange or store credit until 10 January 2026.<br/><br/>For refunds, the standard 14-day return policy still applies.</strong></h5><h5>Returns must be initiated via our Returns Portal. A £5 return fee will be charged on all refunds. Exchanges are available free of charge only for the same item in a different size, or for items that are faulty or incorrect. Items returned outside the return window or in unsuitable condition may be refused. <br/><br/>Refunds are processed within 5–7 working days once returns are received and approved. Original delivery costs are non-refundable unless an item is faulty. International returns are at the customer’s expense and risk.</h5>",
            "html": ""
          }
        },
        "block_ickBqp": {
          "type": "block",
          "settings": {
            "heading": "PRODUCT DESCRIPTIONS",
            "content": "<h5>We strive for accuracy in all product descriptions, images, and pricing. However, colours and textures may vary slightly due to lighting or screen settings. Sizing guidance is approximate, and we cannot guarantee perfect fit for all body types.</h5>",
            "html": ""
          }
        },
        "block_MTyadG": {
          "type": "block",
          "settings": {
            "heading": "Intellectual property",
            "content": "<h5>All content on marame.com — including but not limited to product designs, text, graphics, images, logos, branding, packaging, and technology — is the exclusive property of Marame Ltd or its licensors.</h5><ul><li><h5>Content may not be reproduced, published, distributed, or exploited for commercial use without express written consent</h5></li><li><h5>All rights reserved under applicable intellectual property laws</h5></li><li><h5>Marame is a registered trademark in the UK and EU. Any unauthorised use or infringement may result in legal action</h5></li></ul>",
            "html": ""
          }
        },
        "block_ydKWY6": {
          "type": "block",
          "settings": {
            "heading": "LIABILITY",
            "content": "<h5>To the fullest extent permitted by law, Marame Ltd is not liable for:</h5><ul><li><h5>Indirect, incidental, or consequential damages</h5></li><li><h5>Loss of profits, income, or data</h5></li><li><h5>Delays or failures caused by third-party service providers or external events</h5></li></ul><h5>We do not exclude or limit liability where it would be unlawful to do so, including liability for death or personal injury caused by negligence or for fraud.</h5>",
            "html": ""
          }
        },
        "block_Qp9qjQ": {
          "type": "block",
          "settings": {
            "heading": "EVENTS BEYOND OUR CONTROL",
            "content": "<h5>We are not responsible for any failure or delay caused by events beyond our reasonable control, including but not limited to:</h5><ul><li><h5>Industrial action</h5></li><li><h5>Natural disasters</h5></li><li><h5>Transport or courier failures</h5></li><li><h5>Cyber-attacks or internet outages</h5></li><li><h5>Government actions or customs delays</h5></li></ul>",
            "html": ""
          }
        },
        "block_rb9emQ": {
          "type": "block",
          "settings": {
            "heading": "GOVERNING LAW",
            "content": "<h5>These Terms & Conditions are governed by and interpreted under the laws of England and Wales. Disputes will be subject to the exclusive jurisdiction of the courts of England and Wales.</h5>",
            "html": ""
          }
        }
      },

            "title_color": "#121212",
            "title_bg_color": "#ffffff",
            "title_hover_color": "#636363",
            "title_hover_bg_color": "#ffffff",
            "content_font": "sans_serif_n4",
            "content_font_size": 14,
            "content_line_height": 1.6,
            "content_letter_spacing": 1.5,
            "content_text_transform": "none",
            "content_color": "#949494",
            "content_bg_color": "#ffffff",
            "content_border_thickness": 0,
            "content_border_style": "solid",
            "content_border_color": "#e0e0e0",
            "icon_size": 20,
            "icon_color": "#242833",
            "icon_hover_color": "#000000",
            "divider_thickness": 1,
            "divider_style": "solid",
            "divider_color": "#eceaea",
            "animation_duration": 0.5,
            "animation_easing": "ease",
            "item_1_title": "About Us",
            "item_1_content": "<span style=\"text-transform:none !important;\">\n\n  <span style=\"font-size:0.9em;\">\n    Marame Ltd is a company registered in England and Wales.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    <strong style=\"text-transform:none !important; font-size:inherit;\">Registered address:</strong> Henge Barn, Pury Hill Business Park, Alderton Road, Northamptonshire, NN12 7LS.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    <strong style=\"text-transform:none !important; font-size:inherit;\">Company number:</strong> 14444446.\n  </span>\n  <br>\n\n  <span style=\"font-size:0.9em;\">\n    <strong style=\"text-transform:none !important; font-size:inherit;\">VAT number:</strong> GB451 9209 92.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    <strong style=\"text-transform:none !important; font-size:inherit;\">Contact:</strong> <a href=\"mailto:help@marame.com\">help@marame.com</a>\n  </span>\n\n</span>",
            "item_2_title": "Using Our Website",
            "item_2_content": "<span style=\"text-transform:none !important;\">\n\n  <span style=\"font-size:0.9em;\">\n    You must be at least <strong style=\"text-transform:none !important; font-size:inherit;\">18 years old</strong> to place an order on our website. You agree to use our site only for lawful purposes and in a way that does not infringe the rights of others or restrict their use of the site.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    We may suspend or withdraw access to our website at any time without notice for operational, legal, or security reasons.\n  </span>\n\n</span>",
            "item_3_title": "Products & Availability",
            "item_3_content": "<span style=\"text-transform:none !important;\">\n\n  <span style=\"font-size:0.9em;\">\n    All products are subject to <strong style=\"text-transform:none !important; font-size:inherit;\">availability</strong>. We make every effort to ensure that product descriptions, images, and pricing are accurate, however colours and finishes may vary slightly due to photography and individual screen settings.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    We reserve the right to <strong style=\"text-transform:none !important; font-size:inherit;\">discontinue or amend</strong> any product without notice.\n  </span>\n\n</span>",
            "item_4_title": "Prices & Payment",
            "item_4_content": "<span style=\"text-transform:none !important;\">\n\n  <span style=\"font-size:0.9em;\">\n    All prices are shown in <strong style=\"text-transform:none !important; font-size:inherit;\">GBP</strong> unless stated otherwise and include <strong style=\"text-transform:none !important; font-size:inherit;\">VAT</strong> where applicable. Delivery charges are shown separately at checkout.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    We reserve the right to <strong style=\"text-transform:none !important; font-size:inherit;\">change prices</strong> at any time, however any changes will not affect orders that have already been dispatched.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    Payment must be made in full at the time of placing your order. We accept the payment methods displayed at checkout.\n  </span>\n\n</span>",
            "item_5_title": "Placing An Order",
            "item_5_content": "<span style=\"text-transform:none !important;\">\n\n  <span style=\"font-size:0.9em;\">\n    When you place an order, you will receive an <strong style=\"text-transform:none !important; font-size:inherit;\">order confirmation email</strong>. This email acknowledges receipt of your order but does not constitute acceptance.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    A legally binding contract is formed only once your order has been <strong style=\"text-transform:none !important; font-size:inherit;\">dispatched</strong> and you have received a <strong style=\"text-transform:none !important; font-size:inherit;\">dispatch confirmation email</strong>.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    We reserve the right to <strong style=\"text-transform:none !important; font-size:inherit;\">refuse or cancel</strong> an order at any time, including where products are unavailable, pricing errors occur, or we suspect fraudulent activity.\n  </span>\n\n</span>",
            "item_6_title": "Delivery",
            "item_6_content": "<span style=\"text-transform:none !important;\">\n\n  <span style=\"font-size:0.9em;\">\n    We offer <strong style=\"text-transform:none !important; font-size:inherit;\">UK and international delivery</strong>. Estimated delivery times are provided as a guide only and are not guaranteed.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    Risk of loss or damage passes to you upon <strong style=\"text-transform:none !important; font-size:inherit;\">delivery</strong>. Ownership of goods passes to you once payment has been received in full and the goods have been <strong style=\"text-transform:none !important; font-size:inherit;\">dispatched</strong>.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    We are not responsible for delays caused by events outside our reasonable control, including courier delays, customs processes, weather conditions, or industrial action.\n  </span>\n\n</span>",
            "item_7_title": "International Orders, Duties & Taxes",
            "item_7_content": "<span style=\"text-transform:none !important;\">\n\n  <span style=\"font-size:0.9em;\">\n    For <strong style=\"text-transform:none !important; font-size:inherit;\">international orders</strong>, customs duties, taxes, and import charges may apply depending on the destination country and delivery terms.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    Where delivery is made on a <strong style=\"text-transform:none !important; font-size:inherit;\">Delivered At Place (DAP)</strong> basis, you are responsible for paying any applicable duties and taxes. Failure to do so may result in delays, additional charges, or the return or destruction of the shipment, for which we accept no responsibility.\n  </span>\n\n</span>",
            "item_8_title": "Returns & Exchanges",
            "item_8_content": "<span style=\"text-transform:none !important;\">\n\n  <span style=\"font-size:0.9em;\">\n    We accept returns within <strong style=\"text-transform:none !important; font-size:inherit;\">30 days of fulfilment</strong>, provided items are unworn, unused, and returned in their original condition with all tags and packaging intact.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    Returns from the UK are <strong style=\"text-transform:none !important; font-size:inherit;\">free of charge</strong>. \n\nWe also offer returns for Store Credit, Exchanges AND Instant Exchanges, where you are able to get a new product shipped out to you prior to returning your original product. We just take an authorisation hold on your card until the product is received in good order. \n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    Exchanges are offered for the <strong style=\"text-transform:none !important; font-size:inherit;\">same style of product</strong> for sizing or colour issues, or for faulty items only, and are subject to stock availability.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    Items returned that do not meet our return conditions may be refused or returned to you.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    Full details are available on our \n    <a href=\"https://marame.com/pages/returns\" style=\"color:inherit; text-decoration:underline;\">\n      <strong style=\"text-transform:none !important; font-size:inherit;\">Returns page</strong></a>, which forms part of these Terms.\n  </span>\n\n</span>",
            "item_9_title": "Faulty or Incorrect Items",
            "item_9_content": "<span style=\"text-transform:none !important;\">\n\n  <span style=\"font-size:0.9em;\">\n    If you receive a <strong style=\"text-transform:none !important; font-size:inherit;\">faulty or incorrect item</strong>, please contact us within <strong style=\"text-transform:none !important; font-size:inherit;\">48 hours of delivery</strong>, including details of the issue and supporting images where possible.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    We will assess the issue and, where appropriate, offer a <strong style=\"text-transform:none !important; font-size:inherit;\">repair, replacement, or refund</strong> in accordance with your statutory rights.\n  </span>\n\n</span>",
            "item_10_title": "Promotions & Discount Codes",
            "item_10_content": "<span style=\"text-transform:none !important;\">\n\n  <span style=\"font-size:0.9em;\">\n    Discount codes are subject to <strong style=\"text-transform:none !important; font-size:inherit;\">specific terms</strong> and may not be combined unless stated otherwise. Codes cannot be applied retrospectively to orders already placed.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    We reserve the right to <strong style=\"text-transform:none !important; font-size:inherit;\">withdraw or amend promotions</strong> at any time.\n  </span>\n\n</span>",
            "item_11_title": "Intellectual Property",
            "item_11_content": "<span style=\"text-transform:none !important;\">\n\n  <span style=\"font-size:0.9em;\">\n    All content on our website, including <strong style=\"text-transform:none !important; font-size:inherit;\">text, images, designs, logos, and trademarks</strong>, is owned by or licensed to <strong style=\"text-transform:none !important; font-size:inherit;\">Marame Ltd</strong>.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    You may not <strong style=\"text-transform:none !important; font-size:inherit;\">copy, reproduce, distribute, or use</strong> any content without our prior written permission.\n  </span>\n\n</span>",
            "item_12_title": "Liability",
            "item_12_content": "<span style=\"text-transform:none !important;\">\n\n  <span style=\"font-size:0.9em;\">\n    Nothing in these Terms limits or excludes our liability for <strong style=\"text-transform:none !important; font-size:inherit;\">death or personal injury</strong> caused by our negligence, for <strong style=\"text-transform:none !important; font-size:inherit;\">fraud</strong>, or for any other liability that cannot be excluded or limited by law.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    To the fullest extent permitted by law, we are not liable for <strong style=\"text-transform:none !important; font-size:inherit;\">indirect, incidental, or consequential losses</strong>, including loss of profits, business interruption, or loss of data.\n  </span>\n  <br><br>\n\n  <span style=\"font-size:0.9em;\">\n    Our total liability in connection with any order shall not exceed the <strong style=\"text-transform:none !important; font-size:inherit;\">total amount paid for that order</strong>.\n  </span>\n\n</span>",
            "item_13_title": "Privacy",
            "item_13_content": "<span style=\"text-transform:none !important;\">\n\n  <span style=\"font-size:0.9em;\">\n    Your personal data is handled in accordance with our \n    <strong style=\"text-transform:none !important; font-size:inherit;\">Privacy Policy</strong>, \n    which explains how we collect, use, and protect your information.\n  </span>\n\n</span>",
            "item_14_title": "Changes To These Terms",
            "item_14_content": "<span style=\"text-transform:none !important;\">\n\n  <span style=\"font-size:0.9em;\">\n    We may update these <strong style=\"text-transform:none !important; font-size:inherit;\">Terms</strong> from time to time. The version in force at the time you place your order will apply to that purchase.\n  </span>\n\n</span>",
            "item_15_title": "Governing Law",
            "item_15_content": "<span style=\"text-transform:none !important;\">\n\n  <span style=\"font-size:0.9em;\">\n    These <strong style=\"text-transform:none !important; font-size:inherit;\">Terms</strong> are governed by the laws of <strong style=\"text-transform:none !important; font-size:inherit;\">England and Wales</strong>, and any disputes will be subject to the <strong style=\"text-transform:none !important; font-size:inherit;\">exclusive jurisdiction</strong> of the courts of England and Wales.\n  </span>\n\n</span>",

{%- comment -%}
  Info icon — circle with “i” (not an eye). Optional custom upload overrides.
  @param section {Section}
{%- endcomment -%}
{%- if section.settings.terms_icon != blank -%}
  {{
    section.settings.terms_icon
    | image_url: width: 88
    | image_tag:
      class: 'msp-signup__info-icon',
      alt: '',
      width: 22,
      height: 22,
      loading: 'lazy'
  }}
{%- else -%}
  <svg class="msp-signup__info-icon" width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <circle cx="11" cy="11" r="10.5" fill="#D9D9D9" stroke="#2D2C2A" stroke-width="1"/>
    <circle cx="11" cy="7.25" r="1.35" fill="#2D2C2A"/>
    <rect x="10.2" y="9.75" width="1.6" height="5.5" rx="0.8" fill="#2D2C2A"/>
  </svg>
{%- endif -%}

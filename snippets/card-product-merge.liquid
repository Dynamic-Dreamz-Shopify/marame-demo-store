<script type="application/json"
  class="variant-images-json"
  data-product-id="{{ card_product.id }}">
{

{% assign seen_colors = '' %}
{% for variant in card_product.variants %}
  {% assign color_down = variant.option1 | downcase %}
  {% assign size_value = variant.option2 %}
  {% assign color_key = '|' | append: color_down | append: '|' %}

  "{{ variant.id }}": {
    "variant_id": {{ variant.id | json }},
    "color": {{ color_down | json }},
    "size": {{ size_value | json }},
    "options": {{ variant.options | json }},
    "variant_title": {{ variant.title | json }},
    "variant_available": {{ variant.available | json }},
    "inventory_quantity": {{ variant.inventory_quantity | json }},
    "coming_soon": {{ variant.metafields.custom.coming_soon.value | json }},
    "images": [
      {%- unless seen_colors contains color_key -%}
        {% assign first_image = true %}

        {% comment %} {% if variant.featured_media %}
          {% comment %} {% assign fm_400 = variant.featured_media | image_url: width: 400 %}
          {% assign fm_600 = variant.featured_media | image_url: width: 600 %}
          {% assign fm_800 = variant.featured_media | image_url: width: 800 %}
          {% assign fm_srcset = fm_400 | append: ' 400w, ' | append: fm_600 | append: ' 600w, ' | append: fm_800 | append: ' 800w' %} {% endcomment %}
          {
            "id": {{ variant.featured_media.id | json }},
            "src": {{ variant.featured_media | image_url: width: 1000 | json }},
            {% comment %} "srcset": {{ fm_srcset | json }}, {% endcomment %}
            "alt": {{ variant.featured_media.alt | json }}
          }
          {% assign first_image = false %}
        {% endif %} {% endcomment %}

        {% if variant.featured_media %}
          {% if card_product.type == "Unisex" %}

            {% comment %} 
              For unisex: skip featured image here — all images come from media loop below
              in their natural Shopify admin order. Just set first_image = false to allow
              the loop to add commas correctly.
            {% endcomment %}
            {% assign color_first_media = nil %}
            {% assign has_gender_first_media = false %}

            {% comment %} Check if first product media is gendered (for JS filtering) {% endcomment %}
            {% assign first_media_alt = card_product.media.first.alt | downcase | strip %}
            {% if first_media_alt contains 'woman' or first_media_alt contains 'women'
                or first_media_alt contains 'womean' or first_media_alt contains 'man '
                or first_media_alt contains 'men ' %}
              {% assign has_gender_first_media = true %}
            {% endif %}

          {% else %}
            {
              "id": {{ variant.featured_media.id | json }},
              "src": {{ variant.featured_media | image_url: width: 1000 | json }},
              "alt": {{ variant.featured_media.alt | json }}
            }
            {% assign first_image = false %}
          {% endif %}
        {% endif %}

        {% for media in card_product.media %}
        {% if media.media_type == 'image' %}
          {% assign img_color = media.alt | downcase | split: '|' | last | strip %}
          {% if img_color == color_down %}

            {% assign skip_this = false %}

            {% comment %} For non-unisex: skip featured media (already added above) {% endcomment %}
            {% if card_product.type != "Unisex" %}
              {% if variant.featured_media and media.id == variant.featured_media.id %}
                {% assign skip_this = true %}
              {% endif %}
            {% endif %}

            {% unless skip_this %}
              {% unless first_image %},{% endunless %}
              {
                "id": {{ media.id | json }},
                "src": {{ media | image_url: width: 1000 | json }},
                "alt": {{ media.alt | json }}
              }
              {% assign first_image = false %}
            {% endunless %}

          {% endif %}
        {% endif %}
      {% endfor %}

        {% assign seen_colors = seen_colors | append: color_key %}
      {%- endunless -%}
    ]
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
}
</script>

  </li>
{% endif %}

{% endif %}

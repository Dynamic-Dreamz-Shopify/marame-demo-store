  html[data-marame-collection] .filter-panels[data-marame-inline-facets] #main-filter-panel.filter-panel {
    flex: 1 1 auto;
    min-height: 0;
    overflow-x: hidden;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding: 10px 0 0;
  }
  html[data-marame-collection] .filter-panels[data-marame-inline-facets] .filter-panel__ctas {
    flex: 0 0 auto;

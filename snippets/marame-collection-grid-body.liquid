  }
  .marame-grid-controls__label {
      margin-right: 0.35rem;
      color: #666;
  }
  .marame-grid-controls__hint {
      color: #888;
      font-weight: normal;
  }
  .marame-grid-controls__btn {
      cursor: pointer;
      border: 1px solid #2a2a2d;
      background: #2a2a2d;
      color: #fff;
      padding: 0.5rem 1rem;
      font-size: 0.8125rem;

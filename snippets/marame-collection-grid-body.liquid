{% javascript %}
  document.addEventListener('marame:collection-ready', () => {
    document.querySelectorAll('.listing__list.marame-collection-loading').forEach((el) => {
      el.classList.replace('marame-collection-loading', 'marame-collection-loaded');
    });
    document.querySelector('#MainContent section.listing')?.classList.remove('marame-listing-swapping');
    document.querySelectorAll('#MainContent .marame-listing-swap-overlay').forEach((el) => {
      el.classList.add('hidden');
      el.setAttribute('aria-hidden', 'true');
    });
  });
{% endjavascript %}

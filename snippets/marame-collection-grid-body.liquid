  .iWishAddColl,
  .iWishAdd,
  .iwish-app-block-product,
  .save_item,
  .iwishDrawer,
  .iwishPage {
      display: none !important;
      pointer-events: none !important;
  }
  .marame-grid-controls {
      margin: 0 0 1.25rem;
      padding: 0.75rem 1rem;
      border: 1px solid #e5e5e5;

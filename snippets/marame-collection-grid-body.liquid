    pointer-events: none;
  }
  html[data-marame-collection] .filter-panels.marame-filter-apply-ready #secondary-view-button[aria-disabled="false"],
  html[data-marame-collection] .filter-panel__ctas:has(.active-filters li) #secondary-view-button {
    opacity: 1;
  }
  @media screen and (max-width: 1023px) {
    html[data-marame-collection]:not([data-marame-filters-drawer="open"]) .new-filters-drawer {
      bottom: -100% !important;
    }
    html[data-marame-collection] .new-filters-drawer:not(.marame-drawer-open) {
      bottom: -100% !important;
    }
    html[data-marame-collection] .new-filters-drawer.marame-drawer-open {
      left: 0;
      right: 0;
      top: auto;
      bottom: 0 !important;
      max-width: none;
      height: min(92vh, 100dvh);
      min-height: min(511px, 92vh);

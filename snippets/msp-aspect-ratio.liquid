{%- comment -%}
  Outputs aspect-ratio value for CSS (e.g. 149 / 239).
  @param preset {String}
  @param width {Number}
  @param height {Number}
{%- endcomment -%}
{%- case preset -%}
  {%- when 'tall' -%}
    149 / 239
  {%- when 'tall_desktop' -%}
    427 / 557
  {%- when 'portrait' -%}
    568 / 557
  {%- when 'square' -%}
    1 / 1
  {%- when 'wide' -%}
    390 / 218
  {%- when 'landscape' -%}
    16 / 9
  {%- when 'landscape_banner' -%}
    1440 / 760
  {%- when 'full' -%}
    585 / 300
  {%- when 'desktop_closeup' -%}
    955 / 585
  {%- when 'desktop_video' -%}
    1049 / 585
  {%- when 'custom' -%}
    {%- if width != blank and height != blank and width > 0 and height > 0 -%}
      {{- width }} / {{ height }}
    {%- else -%}
      1 / 1
    {%- endif -%}
  {%- else -%}
    1 / 1
{%- endcase -%}

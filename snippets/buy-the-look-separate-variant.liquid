{% if product.selected_or_first_available_variant.metafields.custom.buy_the_look_new.value != blank %}
{% assign btl_products_length = 0 %}
{% assign btl_products = product.selected_or_first_available_variant.metafields.custom.buy_the_look_new.value %}
{% for btl_product in btl_products %}
  {% assign btl_products_length = btl_products_length | plus: 1 %}
{% endfor %}

{% assign template = template.name %}
  <section class="buy-the-look buy-the-look-separate{% if template == 'product' and product.gift_card? == false %} pdp-look-section-wrap{% endif %}" id="buy_full_look">
    {% if section.settings.heading != blank %}
      <h3 class="h4 section-title-tag">{{ section.settings.heading }}</h3>
    {% endif %}
    <div class="buy-the-look__content--main">
        <div class="buy-the-look__content--item shop-the-look">
        {% if section.settings.heading != blank %}
          <h3 class="h4 section-title-tag buy-the-look__content-title">
            {{ section.settings.heading }}
            <div class="buy-the-look-arrow">
              <div class="shop-the-look-prev">
                <svg width="6" height="10" viewBox="0 0 6 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M5.59888 0.400391L0.598878 4.88618L5.59888 9.37198" stroke="#262525" stroke-width="0.8" stroke-miterlimit="10" stroke-linecap="round"/>
                </svg>
                Back
              </div>
              <div class="shop-the-look-next">
                View More
                <svg width="6" height="10" viewBox="0 0 6 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0.398438 9.37109L5.39844 4.8853L0.398438 0.399505" stroke="#262525" stroke-width="0.8" stroke-miterlimit="10" stroke-linecap="round"/>
                </svg>
              </div>
            </div>
          </h3>
        {% endif %}
            <div class="buy-the-look___content{% if btl_products_length > 3 %} buy-the-look__content--vertical{% endif %}">

                <div class="buy-the-look__content___details swiper">
                  <div class="swiper-wrapper">
                  {% for btl_product in btl_products %}
                  {% assign size_option = 'size' %}
                  {% assign size_option_available = false %}
                  {%- for option in btl_product.product.options_with_values -%}
                      {% assign option_name = option.name | downcase %}
                      {% if option_name == "shoe size" %}
                          {% assign size_option = 'shoe size' %}
                      {% endif %}
                      {% if option_name == size_option %}
                      {% assign size_option_available = true %}
                      {% endif %}
                  {%- endfor -%}

                  {% unless btl_product.available %}
                  {% assign size_option_available = false %}
                  {% endunless %}

                  {% assign color_name = '' %}
                  {% for option in btl_product.product.options_with_values %}
                  {% assign op_name = option.name | downcase %}

                      {% if op_name contains 'color' or op_name contains 'colour' %}
                          {% for value in option.values %}
                              {% if btl_product.title contains value %}
                              {% assign color_name = value | downcase %}
                                {% assign color_name_new = value  %}
                              {% endif %}
                          {% endfor %}
                      {% endif %}
                  {% endfor %}

                      <div class="buy-the-look__content__details__item swiper-slide product--grid--main listing__item" data_product_ID="{{ btl_product.id }}" title="{{ color_name_new }}" data-product-id="{{ btl_product.id }}">  
                          <div class="buy-the-look__content__details__item__img cursor_pointer">
                              <div class="buy-the-look__content__details__item__img__new-slider">
                              <div class="swiper-wrapper">
                                  {%- for media in btl_product.product.media -%}
                                      {%- case media.media_type -%}
                                      {%- when 'image' -%}
                                      {% comment %} {% assign img_alt = media.alt | split:'|' | last | downcase %} {% endcomment %}
                                      {% assign img_alt = media.alt | downcase | replace: ' | ', '|' | replace: '| ', '|' | replace: ' |', '|' | split: '|' | last | strip%}
                                      {% if img_alt == color_name %}
                                      <div class="swiper-slide" media_ID="{{ media.id }}" data_alt="{{ media.alt | escape }}"
                                      >
                                        <img onclick="location.href='{{ btl_product.url }}'" src="{{ media.src | img_url: 'master' }}" width="{{ media.width }}" height="{{ media.height }}" alt="{{ media.alt | escape }}" loading="eager">
                                      </div>
                                      {% endif %}
                                      {%- endcase -%}
                                  {%- endfor -%}
                              </div>
                              <div class="swiper-button-prev">
                                  <svg xmlns="http://www.w3.org/2000/svg" width="9" height="19" viewBox="0 0 9 19" fill="none">
                                    <path d="M8.409 1 .999 9.335l7.41 8.335" stroke="#8E8E8E" stroke-width="1.389"/>
                                  </svg>
                              </div>
                                  <div class="swiper-button-next">
                                      <svg xmlns="http://www.w3.org/2000/svg" width="10" height="19" viewBox="0 0 10 19" fill="none">
                                      <path d="m1.12 17.939 7.408-8.336L1.12 1.268" stroke="#8E8E8E" stroke-width="1.389"/>
                                      </svg>
                                  </div>
                              <div class="swiper-pagination"></div>
                              </div>

                              
                              <button class="atc_btn_custom" aria-label="atc">

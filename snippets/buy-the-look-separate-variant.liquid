                                  </svg>
                                  {% comment %} <img src="https://cdn.shopify.com/s/files/1/0934/8877/5503/files/download.png?v=1766987837" width="20px" height="20px"> {% endcomment %}
                                </span>
                              </button>
          
                          <div class="successfully_ATC_new hidden">Added to Bag</div>

                          {% for option in btl_product.product.options_with_values %}
                          {% assign op_name = option.name | downcase %}

                              {% if op_name contains 'size' or op_name contains 'Size' %}

                                <div class="pdp-card-option-custom">
                                  <div class="product-card__content__add-to-cart">    
                                    <ul class="size-select__select custom_select_size hidden" name="size" aria-label="Select size">

                                      {% for value in option.values %}
                                        {% assign matched_variant = nil %}
                                        {% assign qty = 0 %}

                                        {% for variant in btl_product.product.variants %}
                                          {% assign variant_color = variant.option1 | downcase %}
                                          {% assign variant_size  = variant.option2 | downcase %}

                                          {% if variant_color == color_name and variant_size == value  %}
                                            {% assign matched_variant = variant %}
                                            {% break %}
                                          {% endif %}
                                        {% endfor %}

                                        <li class="size_option {% unless matched_variant.available %}out-of-stock{% endunless %}"
                                        {% if matched_variant.available %}
                                          data-size-var="{{ matched_variant.id }}"
                                          data-size-opt="{{ value }}"
                                          data-variant-title="{{ matched_variant.title }}"
                                        {% endif %}>
                                          Size - {{ value }}
                                          {% if variant.inventory_quantity > 0 and variant.inventory_quantity <= 5 %}
                                            {% assign var_qty = variant.inventory_quantity %}
                                          {% endif %}

                                          {% if matched_variant %}
                                            {% if matched_variant.inventory_management %}
                                              {% assign var_qty = matched_variant.inventory_quantity %}
                                              {% if var_qty > 0 and var_qty <= 5 %}
                                                  - only {{ var_qty }} left
                                              {% endif %}
                                            {% endif %}
                                          {% endif %}

                                          {% unless matched_variant.available %}
                                            <span class="option--out-of-stock">
                                              {% comment %} <span>- out of stock</span> {% endcomment %}
                                              <span>-</span>
                                              <a class="button notify-button"
                                                data-product-id="{{ btl_product.id }}"
                                                data-var-id="{{ matched_variant.id }}"
                                                href="#"
                                                data-klaviyo-handle="{{ btl_product.product.handle }}">
                                                {% comment %} notify me when available {% endcomment %}
                                                Tell me when it’s back
                                              </a>
                                            </span>
                                          {% endunless %}
                                        </li>

                                      {% endfor %}

                                    </ul>
                                    <span class="close_size"> 
                                      <svg width="10" height="5" viewBox="0 0 10 5" fill="none" xmlns="http://www.w3.org/2000/svg">
                                      <path d="M9.00977 0.402832L4.65305 3.60596L0.296331 0.402832" stroke="#262525"/>
                                      </svg>
                                    </span>
                                  </div>
                                </div>
                            {% endif %}

                          {% endfor %}





                          {% comment %} {% render 'wishlist-app-links', linkType: 'list-product', product: btl_product  %} {% endcomment %}
                          <a class="iWishAddColl iwishcheck trrrrr" href="#" data-variant="{{ btl_product.id }}" data-product="{{ btl_product.product.id }}" data-pTitle="{{ btl_product.product.title | escape }}" aria-label="Add {{ btl_product.title | escape }} in wishlist"></a>
                          {% for tag in btl_product.product.tags %}
                              {% if tag contains "badge_" %}
                                  <div class="product-card__badge pc-{{ tag | handle }}">{{ tag | remove: "badge_" | capitalize }}</div>
                              {% break %}
                              {% endif %}
                          {% endfor %}
                          </div>
                          <div class="buy-the-look__content__details__item__content">
                              <div class="buy-the-look__content__details__item__content__infos">
                                  <a href="{{ btl_product.url }}" class="buy-the-look__content__details__item__content__infos__deets">
                                  <h5 class="desc">{{ btl_product.product.title }}</h5>
                                  {% if color_name %}<p class="pro-color">in {{ color_name_new }}</p>{% endif %}
                                  </a>                 
                              </div>
                          </div>
                      </div>
                  {% endfor %}
                  </div>
              </div>
            </div>
        </div>

    {% assign btl_products = product.selected_or_first_available_variant.metafields.custom.style_with_product_new.value %}
     {% if product.selected_or_first_available_variant.metafields.custom.style_with_product_new.value != blank %}

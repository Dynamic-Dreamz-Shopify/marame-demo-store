                          {% for option in btl_product.product.options_with_values %}
                          {% assign op_name = option.name | downcase %}

                              {% if op_name contains 'size' or op_name contains 'Size' %}

                                <div class="pdp-card-option-custom">
                                  <div class="product-card__content__add-to-cart">    
                                    <ul class="size-select__select custom_select_size hidden" name="size" aria-label="Select size">

                                      {% for value in option.values %}
                                        {% assign matched_variant = nil %}
                                        {% assign qty = 0 %}

                                        {% for variant in btl_product.product.variants %}
                                          {% assign variant_color = variant.option1 | downcase %}
                                          {% assign variant_size  = variant.option2 | downcase %}


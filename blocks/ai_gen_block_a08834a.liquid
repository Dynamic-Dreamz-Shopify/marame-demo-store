{% doc %}
  @prompt
    Create a free text section with title and subheading fields that includes complete customization options:
    - Separate text input fields for title and subheading
    - Typography controls for both title and subheading including: font family picker, font size, font weight (light, normal, medium, semibold, bold), letter spacing, line height, text transform (none, uppercase, lowercase, capitalize)
    - Color pickers for title color and subheading color
    - Text alignment options (left, center, right, justify)
    - Padding controls for top, bottom, left, and right
    - Margin controls for spacing around the section
    - Width and positioning options (full width, centered with max-width control, custom positioning)
    - Animation options including: fade in, slide up, slide down, slide left, slide right, animation duration, animation delay
    - Background color option for the text container
    - Individual spacing control between title and subheading
    - Mobile responsive settings with separate font sizes for mobile if needed
    - Option to show or hide title and subheading independently, Can I have a content section underneath the subheading as well please, Can the content field be like the sub heading and title heading box with a seperate section for the typography
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.container_bg_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
  }

  .ai-text-section__wrapper-{{ ai_gen_id }} {
    {% if block.settings.width_style == 'centered' %}
      max-width: {{ block.settings.max_width }}px;
      margin-left: auto;
      margin-right: auto;
    {% elsif block.settings.width_style == 'full' %}
      width: 100%;
    {% endif %}
  }

  .ai-text-section__content-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-text-section__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
    line-height: {{ block.settings.title_line_height }};
    text-transform: {{ block.settings.title_text_transform }};
    margin: 0;
    margin-bottom: {{ block.settings.title_subheading_spacing }}px;
  }

  .ai-text-section__subheading-{{ ai_gen_id }} {
    font-family: {{ block.settings.subheading_font.family }}, {{ block.settings.subheading_font.fallback_families }};
    font-weight: {{ block.settings.subheading_font.weight }};
    font-size: {{ block.settings.subheading_font_size }}px;
    color: {{ block.settings.subheading_color }};
    letter-spacing: {{ block.settings.subheading_letter_spacing }}px;
    line-height: {{ block.settings.subheading_line_height }};
    text-transform: {{ block.settings.subheading_text_transform }};
    margin: 0;
    margin-bottom: {{ block.settings.subheading_content_spacing }}px;
  }

  .ai-text-section__body-{{ ai_gen_id }} {
    font-family: {{ block.settings.content_font.family }}, {{ block.settings.content_font.fallback_families }};
    font-weight: {{ block.settings.content_font.weight }};
    font-size: {{ block.settings.content_font_size }}px;
    color: {{ block.settings.content_color }};
    letter-spacing: {{ block.settings.content_letter_spacing }}px;
    line-height: {{ block.settings.content_line_height }};
    text-transform: {{ block.settings.content_text_transform }};
    margin: 0;
  }

  {% if block.settings.animation_enabled %}
    .ai-text-section__content-{{ ai_gen_id }} {
      opacity: 0;
      animation: ai-text-section-{{ block.settings.animation_type }}-{{ ai_gen_id }} {{ block.settings.animation_duration }}s ease-out {{ block.settings.animation_delay }}s forwards;
    }

    @keyframes ai-text-section-fade-in-{{ ai_gen_id }} {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    @keyframes ai-text-section-slide-up-{{ ai_gen_id }} {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes ai-text-section-slide-down-{{ ai_gen_id }} {
      from {
        opacity: 0;
        transform: translateY(-30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes ai-text-section-slide-left-{{ ai_gen_id }} {
      from {
        opacity: 0;
        transform: translateX(30px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes ai-text-section-slide-right-{{ ai_gen_id }} {
      from {
        opacity: 0;
        transform: translateX(-30px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-text-section__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_mobile }}px;
    }

    .ai-text-section__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_font_size_mobile }}px;
    }

    .ai-text-section__body-{{ ai_gen_id }} {
      font-size: {{ block.settings.content_font_size_mobile }}px;
    }
  }
{% endstyle %}

<free-text-section-{{ ai_gen_id }} class="ai-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-section__wrapper-{{ ai_gen_id }}">
    <div class="ai-text-section__content-{{ ai_gen_id }}">
      {% if block.settings.show_title and block.settings.title != blank %}
        <h2 class="ai-text-section__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}

      {% if block.settings.show_subheading and block.settings.subheading != blank %}
        <p class="ai-text-section__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}

      {% if block.settings.show_content and block.settings.content != blank %}
        <p class="ai-text-section__body-{{ ai_gen_id }}">{{ block.settings.content }}</p>
      {% endif %}
    </div>
  </div>
</free-text-section-{{ ai_gen_id }}>

<script>
  (function() {
    class FreeTextSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('free-text-section-{{ ai_gen_id }}', FreeTextSection{{ ai_gen_id }});
  })();
</script>


{% doc %}
  @prompt
    Create a custom Shopify theme section block called "YouTube Video Embed" with full desktop and mobile responsive customisation controls. The block should include:
    
    **Video Embed:**
    - YouTube URL input field (auto-extracts video ID)
    - Responsive iframe embed with configurable aspect ratio (16:9, 4:3, 1:1, 9:16)
    - Separate width/max-width controls for desktop and mobile
    
    **Thumbnail & Play Button:**
    - Custom thumbnail image picker (overrides YouTube's default thumbnail)
    - Option to use YouTube's auto-generated thumbnail as fallback
    - Play button style options: circle filled, circle outline, rounded rectangle
    - Play button colour picker (background, icon, hover state)
    - Play button size control (small / medium / large) for desktop and mobile separately
    - Smooth fade/scale animation on hover
    
    **Frame Styling:**
    - Border radius control (0–50px) for desktop and mobile
    - Border toggle with colour picker and width control
    - Box shadow options: none, soft, medium, hard, custom
    - Custom shadow controls: colour, blur, spread, X/Y offset
    - Overflow hidden to respect border radius on iframe
    
    **Padding & Spacing:**
    - Individual padding controls (top, right, bottom, left) for desktop and mobile
    - Margin controls (top, bottom) for desktop and mobile
    
    **Background Layer:**
    - Background image picker that sits behind the video frame
    - Background colour picker (fallback or overlay)
    - Background image position (centre, top, bottom, left, right)
    - Background image size (cover, contain, custom %)
    - Optional colour overlay on background image with opacity slider
    - Background height control for desktop and mobile
    
    **Layout & Position:**
    - Video horizontal alignment: left, centre, right
    - Optional full-width mode toggle
    - Z-index control for layering
    - Vertical offset (nudge up/down) for desktop and mobile
    
    **Interaction:**
    - Clicking thumbnail/play button loads and autoplays the YouTube iframe
    - Lazy load option toggle
    - Option to open video in a lightbox/modal overlay instead of inline
    
    All settings should be clearly grouped in the theme editor sidebar with desktop and mobile tabs or clearly labelled responsive fields using Shopify's native settings schema (range, color, image_picker, select, checkbox, text). Use clean, minimal default styles that suit a premium/luxury brand aesthetic., Can you add the ability to put a title over the top of this section and allow complete customisation of where this sits and how it's styled/font, weight, letter spacing, size etc.... and make this customisable for both mobile and desktop, Can you give us the option of either having a background image, or a solid background colour, the background colour option isn't currently working when applied, I need more flexibility to move the title, it should be able to be placed anywhere in the block (including over the top of the video frame) also the shadow on the video frame doesn't seem to be working (particularly when you chose a lighter colour because the background is dark)
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-youtube-embed-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    margin-top: {{ block.settings.margin_top_desktop }}px;
    margin-bottom: {{ block.settings.margin_bottom_desktop }}px;
    z-index: {{ block.settings.z_index }};
  }

  .ai-youtube-content-wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-youtube-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-style: {{ block.settings.title_font.style }};
    font-size: {{ block.settings.title_size_desktop }}px;
    letter-spacing: {{ block.settings.title_letter_spacing_desktop }}px;
    line-height: {{ block.settings.title_line_height_desktop }};
    color: {{ block.settings.title_color }};
    text-align: {{ block.settings.title_alignment_desktop }};
    text-transform: {{ block.settings.title_text_transform }};
    margin: 0;
    padding: 0;
    {% if block.settings.title_position == 'absolute' %}
      position: absolute;
      top: {{ block.settings.title_top_desktop }}px;
      left: {{ block.settings.title_left_desktop }}px;
      right: {{ block.settings.title_right_desktop }}px;
      z-index: {{ block.settings.title_z_index }};
    {% else %}
      margin-top: {{ block.settings.title_margin_top_desktop }}px;
      margin-bottom: {{ block.settings.title_margin_bottom_desktop }}px;
      padding-left: {{ block.settings.title_padding_left_desktop }}px;
      padding-right: {{ block.settings.title_padding_right_desktop }}px;
    {% endif %}
    {% if block.settings.title_max_width_enabled %}
      max-width: {{ block.settings.title_max_width_desktop }}px;
      {% if block.settings.title_position != 'absolute' %}
        margin-left: {% if block.settings.title_alignment_desktop == 'left' %}0{% elsif block.settings.title_alignment_desktop == 'center' %}auto{% else %}auto{% endif %};
        margin-right: {% if block.settings.title_alignment_desktop == 'right' %}0{% elsif block.settings.title_alignment_desktop == 'center' %}auto{% else %}auto{% endif %};
      {% endif %}
    {% endif %}
    {% if block.settings.title_text_shadow_enabled %}
      text-shadow: {{ block.settings.title_text_shadow_x }}px {{ block.settings.title_text_shadow_y }}px {{ block.settings.title_text_shadow_blur }}px {{ block.settings.title_text_shadow_color }};
    {% endif %}
  }

  .ai-youtube-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: {{ block.settings.background_height_desktop }}px;
    z-index: -1;
    {% if block.settings.background_type == 'image' %}
      {% if block.settings.background_image %}
        background-image: url('{{ block.settings.background_image | image_url: width: 2000 }}');
        background-position: {{ block.settings.background_position }};
        background-size: {% if block.settings.background_size == 'custom' %}{{ block.settings.background_size_custom }}%{% else %}{{ block.settings.background_size }}{% endif %};
        background-repeat: no-repeat;
      {% endif %}
    {% elsif block.settings.background_type == 'color' %}
      background-color: {{ block.settings.background_color }};
    {% endif %}
  }

  {% if block.settings.background_overlay_enabled %}
    .ai-youtube-background-overlay-{{ ai_gen_id }} {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: {{ block.settings.background_overlay_color }};
      opacity: {{ block.settings.background_overlay_opacity }};
      z-index: 1;
    }
  {% endif %}

  .ai-youtube-container-{{ ai_gen_id }} {
    position: relative;
    {% if block.settings.full_width %}
      width: 100%;
      max-width: 100%;
    {% else %}
      width: {{ block.settings.video_width_desktop }}%;
      max-width: {{ block.settings.video_max_width_desktop }}px;
    {% endif %}
    margin-left: {% if block.settings.horizontal_alignment == 'left' %}0{% elsif block.settings.horizontal_alignment == 'center' %}auto{% else %}auto{% endif %};
    margin-right: {% if block.settings.horizontal_alignment == 'right' %}0{% elsif block.settings.horizontal_alignment == 'center' %}auto{% else %}auto{% endif %};
    transform: translateY({{ block.settings.vertical_offset_desktop }}px);
    padding-top: {{ block.settings.padding_top_desktop }}px;
    padding-right: {{ block.settings.padding_right_desktop }}px;
    padding-bottom: {{ block.settings.padding_bottom_desktop }}px;
    padding-left: {{ block.settings.padding_left_desktop }}px;
  }

  .ai-youtube-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {% if block.settings.aspect_ratio == '16:9' %}56.25%{% elsif block.settings.aspect_ratio == '4:3' %}75%{% elsif block.settings.aspect_ratio == '1:1' %}100%{% else %}177.78%{% endif %};
    border-radius: {{ block.settings.border_radius_desktop }}px;
    overflow: hidden;
    {% if block.settings.border_enabled %}
      border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {% endif %}
    {% if block.settings.shadow_preset == 'soft' %}
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    {% elsif block.settings.shadow_preset == 'medium' %}
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    {% elsif block.settings.shadow_preset == 'hard' %}
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
    {% elsif block.settings.shadow_preset == 'custom' %}
      box-shadow: {{ block.settings.shadow_x }}px {{ block.settings.shadow_y }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_spread }}px {{ block.settings.shadow_color }};
    {% elsif block.settings.shadow_preset == 'light-soft' %}
      box-shadow: 0 2px 8px rgba(255, 255, 255, 0.3);
    {% elsif block.settings.shadow_preset == 'light-medium' %}
      box-shadow: 0 4px 16px rgba(255, 255, 255, 0.4);
    {% elsif block.settings.shadow_preset == 'light-hard' %}
      box-shadow: 0 8px 24px rgba(255, 255, 255, 0.5);
    {% endif %}
  }

  .ai-youtube-thumbnail-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    cursor: pointer;
    background-color: #000;
  }

  .ai-youtube-thumbnail-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-youtube-play-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: {{ block.settings.play_button_size_desktop }}px;
    height: {{ block.settings.play_button_size_desktop }}px;
    background-color: {{ block.settings.play_button_bg_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease, opacity 0.3s ease, background-color 0.3s ease;
    z-index: 2;
    {% if block.settings.play_button_style == 'circle-filled' or block.settings.play_button_style == 'circle-outline' %}
      border-radius: 50%;
    {% elsif block.settings.play_button_style == 'rounded-rectangle' %}
      border-radius: 12px;
    {% endif %}
    {% if block.settings.play_button_style == 'circle-outline' %}
      background-color: transparent;
      border: 3px solid {{ block.settings.play_button_bg_color }};
    {% endif %}
  }

  .ai-youtube-play-button-{{ ai_gen_id }}:hover {
    transform: translate(-50%, -50%) scale(1.1);
    background-color: {{ block.settings.play_button_hover_color }};
    {% if block.settings.play_button_style == 'circle-outline' %}
      background-color: transparent;
      border-color: {{ block.settings.play_button_hover_color }};
    {% endif %}
  }

  .ai-youtube-play-icon-{{ ai_gen_id }} {
    width: calc({{ block.settings.play_button_size_desktop }}px * 0.4);
    height: calc({{ block.settings.play_button_size_desktop }}px * 0.4);
    fill: {{ block.settings.play_button_icon_color }};
    margin-left: calc({{ block.settings.play_button_size_desktop }}px * 0.05);
  }

  .ai-youtube-play-button-{{ ai_gen_id }}:hover .ai-youtube-play-icon-{{ ai_gen_id }} {
    fill: {{ block.settings.play_button_icon_hover_color }};
  }

  .ai-youtube-iframe-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .ai-youtube-modal-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.9);
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }

  .ai-youtube-modal-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-youtube-modal-content-{{ ai_gen_id }} {
    position: relative;
    width: 90%;
    max-width: 1200px;
    aspect-ratio: {% if block.settings.aspect_ratio == '16:9' %}16/9{% elsif block.settings.aspect_ratio == '4:3' %}4/3{% elsif block.settings.aspect_ratio == '1:1' %}1/1{% else %}9/16{% endif %};
  }

  .ai-youtube-modal-close-{{ ai_gen_id }} {
    position: absolute;
    top: -40px;
    right: 0;
    background: none;
    border: none;
    color: #fff;
    font-size: 32px;
    cursor: pointer;
    padding: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media screen and (max-width: 749px) {
    .ai-youtube-embed-{{ ai_gen_id }} {
      margin-top: {{ block.settings.margin_top_mobile }}px;
      margin-bottom: {{ block.settings.margin_bottom_mobile }}px;
    }

    .ai-youtube-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
      letter-spacing: {{ block.settings.title_letter_spacing_mobile }}px;
      line-height: {{ block.settings.title_line_height_mobile }};
      text-align: {{ block.settings.title_alignment_mobile }};
      {% if block.settings.title_position == 'absolute' %}
        top: {{ block.settings.title_top_mobile }}px;
        left: {{ block.settings.title_left_mobile }}px;
        right: {{ block.settings.title_right_mobile }}px;
      {% else %}
        margin-top: {{ block.settings.title_margin_top_mobile }}px;
        margin-bottom: {{ block.settings.title_margin_bottom_mobile }}px;
        padding-left: {{ block.settings.title_padding_left_mobile }}px;
        padding-right: {{ block.settings.title_padding_right_mobile }}px;
      {% endif %}
      {% if block.settings.title_max_width_enabled %}
        max-width: {{ block.settings.title_max_width_mobile }}px;
        {% if block.settings.title_position != 'absolute' %}
          margin-left: {% if block.settings.title_alignment_mobile == 'left' %}0{% elsif block.settings.title_alignment_mobile == 'center' %}auto{% else %}auto{% endif %};
          margin-right: {% if block.settings.title_alignment_mobile == 'right' %}0{% elsif block.settings.title_alignment_mobile == 'center' %}auto{% else %}auto{% endif %};
        {% endif %}
      {% endif %}
    }

    .ai-youtube-background-{{ ai_gen_id }} {
      height: {{ block.settings.background_height_mobile }}px;
    }

    .ai-youtube-container-{{ ai_gen_id }} {
      width: {{ block.settings.video_width_mobile }}%;
      max-width: {{ block.settings.video_max_width_mobile }}px;
      transform: translateY({{ block.settings.vertical_offset_mobile }}px);
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-right: {{ block.settings.padding_right_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
      padding-left: {{ block.settings.padding_left_mobile }}px;
    }

    .ai-youtube-wrapper-{{ ai_gen_id }} {
      border-radius: {{ block.settings.border_radius_mobile }}px;
    }

    .ai-youtube-play-button-{{ ai_gen_id }} {
      width: {{ block.settings.play_button_size_mobile }}px;
      height: {{ block.settings.play_button_size_mobile }}px;
    }

    .ai-youtube-play-icon-{{ ai_gen_id }} {
      width: calc({{ block.settings.play_button_size_mobile }}px * 0.4);
      height: calc({{ block.settings.play_button_size_mobile }}px * 0.4);
      margin-left: calc({{ block.settings.play_button_size_mobile }}px * 0.05);
    }
  }
{% endstyle %}

<youtube-video-{{ ai_gen_id }} class="ai-youtube-embed-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.background_type != 'none' %}
    <div class="ai-youtube-background-{{ ai_gen_id }}">
      {% if block.settings.background_overlay_enabled %}
        <div class="ai-youtube-background-overlay-{{ ai_gen_id }}"></div>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-youtube-content-wrapper-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-youtube-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}

    <div class="ai-youtube-container-{{ ai_gen_id }}">
      <div class="ai-youtube-wrapper-{{ ai_gen_id }}">
        <div class="ai-youtube-thumbnail-{{ ai_gen_id }}" data-video-id="{{ block.settings.youtube_url | split: 'v=' | last | split: '&' | first | split: '/' | last }}">
          {% if block.settings.custom_thumbnail %}
            <img
              src="{{ block.settings.custom_thumbnail | image_url: width: 1920 }}"
              alt="Video thumbnail"
              loading="{% if block.settings.lazy_load %}lazy{% else %}eager{% endif %}"
              width="1920"
              height="1080"
            >
          {% else %}
            {% assign video_id = block.settings.youtube_url | split: 'v=' | last | split: '&' | first | split: '/' | last %}
            {% if video_id != blank %}
              <img
                src="https://img.youtube.com/vi/{{ video_id }}/maxresdefault.jpg"
                alt="Video thumbnail"
                loading="{% if block.settings.lazy_load %}lazy{% else %}eager{% endif %}"
                width="1920"
                height="1080"
              >
            {% endif %}
          {% endif %}

          <button class="ai-youtube-play-button-{{ ai_gen_id }}" aria-label="Play video">
            <svg class="ai-youtube-play-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  {% if block.settings.open_in_modal %}
    <div class="ai-youtube-modal-{{ ai_gen_id }}">
      <div class="ai-youtube-modal-content-{{ ai_gen_id }}">
        <button class="ai-youtube-modal-close-{{ ai_gen_id }}" aria-label="Close video">&times;</button>
        <div class="ai-youtube-modal-iframe-wrapper-{{ ai_gen_id }}" style="position: relative; width: 100%; height: 100%;"></div>
      </div>
    </div>
  {% endif %}
</youtube-video-{{ ai_gen_id }}>

<script>
  (function() {
    class YoutubeVideo{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.thumbnail = this.querySelector('.ai-youtube-thumbnail-{{ ai_gen_id }}');
        this.playButton = this.querySelector('.ai-youtube-play-button-{{ ai_gen_id }}');
        this.wrapper = this.querySelector('.ai-youtube-wrapper-{{ ai_gen_id }}');
        this.modal = this.querySelector('.ai-youtube-modal-{{ ai_gen_id }}');
        this.modalClose = this.querySelector('.ai-youtube-modal-close-{{ ai_gen_id }}');
        this.openInModal = {{ block.settings.open_in_modal }};
        this.videoId = this.thumbnail.dataset.videoId;
      }

      connectedCallback() {
        this.playButton.addEventListener('click', this.handlePlay.bind(this));
        
        if (this.openInModal && this.modalClose) {
          this.modalClose.addEventListener('click', this.handleCloseModal.bind(this));
          this.modal.addEventListener('click', (e) => {
            if (e.target === this.modal) {
              this.handleCloseModal();
            }
          });
        }
      }

      handlePlay() {
        if (!this.videoId) return;

        const iframe = document.createElement('iframe');
        iframe.className = 'ai-youtube-iframe-{{ ai_gen_id }}';
        iframe.src = `https://www.youtube.com/embed/${this.videoId}?autoplay=1&rel=0`;
        iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
        iframe.allowFullscreen = true;

        if (this.openInModal) {
          const modalIframeWrapper = this.querySelector('.ai-youtube-modal-iframe-wrapper-{{ ai_gen_id }}');
          iframe.style.position = 'absolute';
          iframe.style.top = '0';
          iframe.style.left = '0';
          iframe.style.width = '100%';
          iframe.style.height = '100%';
          iframe.style.border = 'none';
          modalIframeWrapper.appendChild(iframe);
          this.modal.classList.add('active');
          document.body.style.overflow = 'hidden';
        } else {
          this.thumbnail.style.display = 'none';
          this.wrapper.appendChild(iframe);
        }
      }

      handleCloseModal() {
        const modalIframeWrapper = this.querySelector('.ai-youtube-modal-iframe-wrapper-{{ ai_gen_id }}');
        modalIframeWrapper.innerHTML = '';
        this.modal.classList.remove('active');
        document.body.style.overflow = '';
      }
    }

    customElements.define('youtube-video-{{ ai_gen_id }}', YoutubeVideo{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "YouTube video embed",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title text"
    },
    {
      "type": "select",
      "id": "title_position",
      "label": "Position mode",
      "options": [
        {
          "value": "relative",
          "label": "Normal flow"
        },
        {
          "value": "absolute",
          "label": "Absolute (overlay)"
        }
      ],
      "default": "relative",
      "info": "Absolute mode allows title to overlay the video"
    },
    {
      "type": "font_picker",
      "id": "title_font",
      "label": "Font",
      "default": "helvetica_n3"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#121212"
    },
    {
      "type": "select",
      "id": "title_text_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "none"
    },
    {
      "type": "checkbox",
      "id": "title_text_shadow_enabled",
      "label": "Enable text shadow",
      "default": false,
      "info": "Useful when title overlays video"
    },
    {
      "type": "color",
      "id": "title_text_shadow_color",
      "label": "Text shadow color",
      "default": "rgba(0,0,0,0.5)"
    },
    {
      "type": "range",
      "id": "title_text_shadow_x",
      "label": "Text shadow X offset",
      "min": -10,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "title_text_shadow_y",
      "label": "Text shadow Y offset",
      "min": -10,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "title_text_shadow_blur",
      "label": "Text shadow blur",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "title_z_index",
      "label": "Title z-index",
      "min": 1,
      "max": 100,
      "step": 1,
      "default": 10,
      "info": "Only applies in absolute position mode"
    },
    {
      "type": "header",
      "content": "Desktop title style"
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "label": "Font size",
      "min": 12,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_letter_spacing_desktop",
      "label": "Letter spacing",
      "min": -5,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "title_line_height_desktop",
      "label": "Line height",
      "min": 0.8,
      "max": 2,
      "step": 0.1,
      "default": 1.2
    },
    {
      "type": "select",
      "id": "title_alignment_desktop",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "title_top_desktop",
      "label": "Top position",
      "min": 0,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 50,
      "info": "Only applies in absolute position mode"

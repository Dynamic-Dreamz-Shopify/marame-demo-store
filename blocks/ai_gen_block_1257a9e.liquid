{% endstyle %}

<title-section-{{ ai_gen_id }} class="ai-title-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-title-section__container-{{ ai_gen_id }}">
    {% if block.settings.row_1_text != blank %}
      <div class="ai-title-section__row-{{ ai_gen_id }} ai-title-section__row-{{ ai_gen_id }}--1">
        {{ block.settings.row_1_text }}
      </div>
    {% endif %}

    {% if block.settings.row_2_text != blank %}
      <div class="ai-title-section__row-{{ ai_gen_id }} ai-title-section__row-{{ ai_gen_id }}--2">
        {{ block.settings.row_2_text }}
      </div>
    {% endif %}

    {% if block.settings.row_3_text != blank %}
      <div class="ai-title-section__row-{{ ai_gen_id }} ai-title-section__row-{{ ai_gen_id }}--3">
        {{ block.settings.row_3_text }}
      </div>
    {% endif %}
  </div>
</title-section-{{ ai_gen_id }}>

<script>
  (function() {
    class TitleSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('title-section-{{ ai_gen_id }}', TitleSection{{ ai_gen_id }});
  })();
</script>


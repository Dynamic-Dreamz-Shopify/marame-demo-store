{% doc %}
  @prompt
    Create a logo carousel block with customizable SVG color controls. Add color picker settings that allow changing:
    1. The fill color of the SVG background image
    2. The fill color/tint of the logo images
    
    The block should include:
    - A color picker for the background SVG fill color with opacity control
    - A color picker for logo tint color with opacity control
    - Settings to toggle these color overlays on/off
    - CSS filters or SVG manipulation to apply the selected colors to the images
    - All existing logo carousel functionality (animation, spacing, sizing)
    
    Make sure the color controls work with both the background image and individual logos, allowing independent color customization of each element., I need to be able to add additional logos (6 isn't enough) , I don't need a header section and I need to make sure the animation seamlessly 'rotates' so when carousel runs out, it repeats seamlessly with the same spacing, I need to actually change the COLOUR of the Background SVG, rather than the full background, Can you add the ability to increase the height of the section, Can you change it so I can adjust each individual logo size, I need to be able to change the background colour size too please, the opacity isn't working on the background image, I still can't change the opacity of the background image SVG and the colour change is change the whole block as opposed to the outline of the word (almost like there no transparency on the image), It's not the background opacity I want to change, it's the IMAGE, Can you make this mobile only, desktop will need its own seperate design, Can you add a little blur behind the logos so that the background image behind the logos doesn't interfere with them, The logo backdrop blur is now not showing the background image behind at all?, Can you shift the Backgroup image up, so it sit just up from centre whereas the logos sit centrally. Or just give me the ability to adjust the position of the background image, Can you change the logo backdrop blur to transparency rather than opacity/blur, The logo backdrop section, needs to have a transparency setting can you also bring layout section to the top
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% assign logo_count = 0 %}
{% assign total_width = 0 %}
{% for i in (1..12) %}
  {% assign logo_key = 'logo_' | append: i %}
  {% assign width_key = 'logo_' | append: i | append: '_width' %}
  {% assign spacing_key = 'logo_spacing' %}
  
  {% if block.settings[logo_key] %}
    {% assign logo_count = logo_count | plus: 1 %}
    {% assign logo_width = block.settings[width_key] %}
    {% assign total_width = total_width | plus: logo_width | plus: block.settings.logo_spacing %}
  {% endif %}
{% endfor %}

{% style %}
  .ai-logo-carousel-{{ ai_gen_id }} {
    display: none;
    width: 100%;
    overflow: hidden;
    position: relative;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
    min-height: {{ block.settings.section_height }}px;
    align-items: center;
  }

  @media screen and (max-width: 749px) {
    .ai-logo-carousel-{{ ai_gen_id }} {
      display: flex;
    }
  }

  .ai-logo-carousel-background-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.background_vertical_position }}%;
    left: {{ block.settings.background_horizontal_position }}%;
    transform: translate(-50%, -50%);
    z-index: 0;
    pointer-events: none;
    width: {{ block.settings.background_width }}%;
    height: {{ block.settings.background_height }}%;
    opacity: {{ block.settings.background_image_opacity | divided_by: 100.0 }};
  }

  .ai-logo-carousel-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    {% if block.settings.enable_background_tint %}
      filter: brightness(0) saturate(100%) invert({{ block.settings.background_invert }}%) sepia(100%) saturate(10000%) hue-rotate({{ block.settings.background_hue }}deg);
    {% endif %}
  }

  .ai-logo-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    max-width: 100%;
    margin: 0 auto;
    padding: 0 20px;
    width: 100%;
  }

  .ai-logo-carousel-track-container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .ai-logo-carousel-backdrop-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    {% if block.settings.enable_logo_backdrop %}
      background: {{ block.settings.backdrop_color }};
      opacity: {{ block.settings.backdrop_opacity | divided_by: 100.0 }};
      border-radius: {{ block.settings.backdrop_radius }}px;
    {% endif %}
    pointer-events: none;
    z-index: 0;
  }

  .ai-logo-carousel-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.logo_spacing }}px;
    width: max-content;
    position: relative;
    z-index: 1;
    padding: {{ block.settings.backdrop_padding }}px 0;
  }

  {% if logo_count > 0 %}
    .ai-logo-carousel-track-{{ ai_gen_id }} {
      animation: ai-logo-scroll-{{ ai_gen_id }} {{ block.settings.animation_speed }}s linear infinite;
      will-change: transform;
    }
  {% endif %}

  {% if block.settings.pause_on_hover %}
    .ai-logo-carousel-track-{{ ai_gen_id }}:hover {
      animation-play-state: paused;
    }
  {% endif %}

  .ai-logo-carousel-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    height: {{ block.settings.logo_height }}px;
    position: relative;
  }

  {% for i in (1..12) %}
    {% assign width_key = 'logo_' | append: i | append: '_width' %}
    .ai-logo-carousel-item-{{ ai_gen_id }}-{{ i }} {
      width: {{ block.settings[width_key] }}px;
    }
  {% endfor %}

  .ai-logo-carousel-item-{{ ai_gen_id }} img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
  }

  .ai-logo-carousel-item-{{ ai_gen_id }} svg {
    max-width: 100%;
    max-height: 100%;
    display: block;
  }

  {% if block.settings.enable_logo_tint %}
    .ai-logo-carousel-item-{{ ai_gen_id }}::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: {{ block.settings.logo_tint_color }};
      mix-blend-mode: multiply;
      opacity: {{ block.settings.logo_tint_opacity | divided_by: 100.0 }};
      pointer-events: none;
    }

    .ai-logo-carousel-item-{{ ai_gen_id }} img {
      filter: grayscale({{ block.settings.logo_grayscale }}%);
    }
  {% endif %}

  {% if logo_count > 0 %}
    @keyframes ai-logo-scroll-{{ ai_gen_id }} {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(-{{ total_width }}px);
      }
    }
  {% endif %}
{% endstyle %}

<logo-carousel-{{ ai_gen_id }} class="ai-logo-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.background_image %}
    <div class="ai-logo-carousel-background-{{ ai_gen_id }}">
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    </div>
  {% endif %}

  <div class="ai-logo-carousel-wrapper-{{ ai_gen_id }}">
    <div class="ai-logo-carousel-track-container-{{ ai_gen_id }}">
      {% if block.settings.enable_logo_backdrop %}
        <div class="ai-logo-carousel-backdrop-{{ ai_gen_id }}"></div>
      {% endif %}
      
      <div class="ai-logo-carousel-track-{{ ai_gen_id }}">
        {% for i in (1..12) %}
          {% assign logo_key = 'logo_' | append: i %}
          {% assign logo = block.settings[logo_key] %}
          
          {% if logo %}
            <div class="ai-logo-carousel-item-{{ ai_gen_id }} ai-logo-carousel-item-{{ ai_gen_id }}-{{ i }}">
              <img
                src="{{ logo | image_url: width: 400 }}"
                alt="{{ logo.alt | escape }}"
                loading="lazy"
                width="400"
                height="400"
              >
            </div>
          {% endif %}
        {% endfor %}

        {% for i in (1..12) %}
          {% assign logo_key = 'logo_' | append: i %}
          {% assign logo = block.settings[logo_key] %}
          
          {% if logo %}
            <div class="ai-logo-carousel-item-{{ ai_gen_id }} ai-logo-carousel-item-{{ ai_gen_id }}-{{ i }}">
              <img
                src="{{ logo | image_url: width: 400 }}"
                alt="{{ logo.alt | escape }}"
                loading="lazy"
                width="400"
                height="400"
              >
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</logo-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class LogoCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-logo-carousel-track-{{ ai_gen_id }}');
      }
    }

    customElements.define('logo-carousel-{{ ai_gen_id }}', LogoCarousel{{ ai_gen_id }});
  })();
</script>


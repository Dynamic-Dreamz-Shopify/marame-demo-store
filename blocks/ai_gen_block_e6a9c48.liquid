{% doc %}
  @prompt
    Create a free text section with maximum customization flexibility:
    - Multiple text line blocks that can be added/removed (minimum 5 blocks available)
    - Each text line has its own separate settings for: font size, font weight (100-900 range), letter spacing, line height, text transform (none, uppercase, lowercase, capitalize), color picker
    - Global section settings including: font family picker, text alignment (left, center, right, justify), padding controls (top, bottom, left, right), margin controls, max-width control, background color with opacity
    - Individual line spacing control between each text block
    - Position controls (static, relative positioning options)
    - Animation options per line: fade in, slide up, slide down, animation delay
    - Mobile responsive with separate font size overrides for mobile
    - Rich text editor option for each line to allow bold, italic, links
    - Vertical alignment options within the section
    - Option to show/hide individual lines
    - Clean, organized settings panel grouped by: typography, spacing, colors, animations, Can you make the content fields just standard text fields and then a typography section with all the customisation, each line will need a different typography section
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-free-text-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    margin-left: {{ block.settings.margin_left }}px;
    margin-right: {{ block.settings.margin_right }}px;
    background-color: {{ block.settings.background_color }};
    opacity: {{ block.settings.background_opacity | divided_by: 100.0 }};
    position: {{ block.settings.position }};
    {% if block.settings.position == 'relative' %}
      top: {{ block.settings.position_top }}px;
      left: {{ block.settings.position_left }}px;
    {% endif %}
  }

  .ai-free-text-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.text_alignment }};
    display: flex;
    flex-direction: column;
    {% if block.settings.vertical_alignment == 'top' %}
      justify-content: flex-start;
    {% elsif block.settings.vertical_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.vertical_alignment == 'bottom' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
  }

  .ai-free-text-line-{{ ai_gen_id }} {
    opacity: 0;
  }

  .ai-free-text-line-{{ ai_gen_id }}.ai-animated {
    animation-fill-mode: forwards;
  }

  .ai-free-text-line-1-{{ ai_gen_id }} {
    font-family: {{ block.settings.line_1_font_family.family }}, {{ block.settings.line_1_font_family.fallback_families }};
    font-weight: {{ block.settings.line_1_font_weight }};
    font-size: {{ block.settings.line_1_font_size }}px;
    letter-spacing: {{ block.settings.line_1_letter_spacing }}px;
    line-height: {{ block.settings.line_1_line_height }};
    text-transform: {{ block.settings.line_1_text_transform }};
    color: {{ block.settings.line_1_color }};
    margin-bottom: {{ block.settings.line_1_spacing }}px;
  }

  .ai-free-text-line-2-{{ ai_gen_id }} {
    font-family: {{ block.settings.line_2_font_family.family }}, {{ block.settings.line_2_font_family.fallback_families }};
    font-weight: {{ block.settings.line_2_font_weight }};
    font-size: {{ block.settings.line_2_font_size }}px;
    letter-spacing: {{ block.settings.line_2_letter_spacing }}px;
    line-height: {{ block.settings.line_2_line_height }};
    text-transform: {{ block.settings.line_2_text_transform }};
    color: {{ block.settings.line_2_color }};
    margin-bottom: {{ block.settings.line_2_spacing }}px;
  }

  .ai-free-text-line-3-{{ ai_gen_id }} {
    font-family: {{ block.settings.line_3_font_family.family }}, {{ block.settings.line_3_font_family.fallback_families }};
    font-weight: {{ block.settings.line_3_font_weight }};
    font-size: {{ block.settings.line_3_font_size }}px;
    letter-spacing: {{ block.settings.line_3_letter_spacing }}px;
    line-height: {{ block.settings.line_3_line_height }};
    text-transform: {{ block.settings.line_3_text_transform }};
    color: {{ block.settings.line_3_color }};
    margin-bottom: {{ block.settings.line_3_spacing }}px;
  }

  .ai-free-text-line-4-{{ ai_gen_id }} {
    font-family: {{ block.settings.line_4_font_family.family }}, {{ block.settings.line_4_font_family.fallback_families }};
    font-weight: {{ block.settings.line_4_font_weight }};
    font-size: {{ block.settings.line_4_font_size }}px;
    letter-spacing: {{ block.settings.line_4_letter_spacing }}px;
    line-height: {{ block.settings.line_4_line_height }};
    text-transform: {{ block.settings.line_4_text_transform }};
    color: {{ block.settings.line_4_color }};
    margin-bottom: {{ block.settings.line_4_spacing }}px;
  }

  .ai-free-text-line-5-{{ ai_gen_id }} {
    font-family: {{ block.settings.line_5_font_family.family }}, {{ block.settings.line_5_font_family.fallback_families }};
    font-weight: {{ block.settings.line_5_font_weight }};
    font-size: {{ block.settings.line_5_font_size }}px;
    letter-spacing: {{ block.settings.line_5_letter_spacing }}px;
    line-height: {{ block.settings.line_5_line_height }};
    text-transform: {{ block.settings.line_5_text_transform }};
    color: {{ block.settings.line_5_color }};
    margin-bottom: {{ block.settings.line_5_spacing }}px;
  }

  @keyframes ai-fade-in-{{ ai_gen_id }} {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes ai-slide-up-{{ ai_gen_id }} {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes ai-slide-down-{{ ai_gen_id }} {
    from {
      opacity: 0;
      transform: translateY(-30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-free-text-section-{{ ai_gen_id }} {
      padding-left: {{ block.settings.padding_left | times: 0.5 }}px;
      padding-right: {{ block.settings.padding_right | times: 0.5 }}px;
    }

    .ai-free-text-line-1-{{ ai_gen_id }} {
      font-size: {{ block.settings.line_1_mobile_font_size }}px;
    }

    .ai-free-text-line-2-{{ ai_gen_id }} {
      font-size: {{ block.settings.line_2_mobile_font_size }}px;
    }

    .ai-free-text-line-3-{{ ai_gen_id }} {
      font-size: {{ block.settings.line_3_mobile_font_size }}px;
    }

    .ai-free-text-line-4-{{ ai_gen_id }} {
      font-size: {{ block.settings.line_4_mobile_font_size }}px;
    }

    .ai-free-text-line-5-{{ ai_gen_id }} {
      font-size: {{ block.settings.line_5_mobile_font_size }}px;
    }
  }
{% endstyle %}

<free-text-section-{{ ai_gen_id }} class="ai-free-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-free-text-container-{{ ai_gen_id }}">
    {% if block.settings.show_line_1 and block.settings.line_1_text != blank %}
      <div
        class="ai-free-text-line-{{ ai_gen_id }} ai-free-text-line-1-{{ ai_gen_id }}"
        data-animation="{{ block.settings.line_1_animation }}"
        data-delay="{{ block.settings.line_1_animation_delay }}"
      >
        {{ block.settings.line_1_text }}
      </div>
    {% endif %}

    {% if block.settings.show_line_2 and block.settings.line_2_text != blank %}
      <div
        class="ai-free-text-line-{{ ai_gen_id }} ai-free-text-line-2-{{ ai_gen_id }}"
        data-animation="{{ block.settings.line_2_animation }}"
        data-delay="{{ block.settings.line_2_animation_delay }}"
      >
        {{ block.settings.line_2_text }}
      </div>
    {% endif %}

    {% if block.settings.show_line_3 and block.settings.line_3_text != blank %}
      <div
        class="ai-free-text-line-{{ ai_gen_id }} ai-free-text-line-3-{{ ai_gen_id }}"
        data-animation="{{ block.settings.line_3_animation }}"
        data-delay="{{ block.settings.line_3_animation_delay }}"
      >
        {{ block.settings.line_3_text }}
      </div>
    {% endif %}

    {% if block.settings.show_line_4 and block.settings.line_4_text != blank %}
      <div
        class="ai-free-text-line-{{ ai_gen_id }} ai-free-text-line-4-{{ ai_gen_id }}"
        data-animation="{{ block.settings.line_4_animation }}"
        data-delay="{{ block.settings.line_4_animation_delay }}"
      >
        {{ block.settings.line_4_text }}
      </div>
    {% endif %}

    {% if block.settings.show_line_5 and block.settings.line_5_text != blank %}
      <div
        class="ai-free-text-line-{{ ai_gen_id }} ai-free-text-line-5-{{ ai_gen_id }}"
        data-animation="{{ block.settings.line_5_animation }}"
        data-delay="{{ block.settings.line_5_animation_delay }}"
      >
        {{ block.settings.line_5_text }}
      </div>
    {% endif %}
  </div>
</free-text-section-{{ ai_gen_id }}>

<script>
  (function() {
    class FreeTextSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.lines = [];
      }

      connectedCallback() {
        this.lines = this.querySelectorAll('.ai-free-text-line-{{ ai_gen_id }}');
        this.initAnimations();
      }

      initAnimations() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const line = entry.target;
              const animation = line.getAttribute('data-animation');
              const delay = parseFloat(line.getAttribute('data-delay')) || 0;

              setTimeout(() => {
                line.classList.add('ai-animated');
                
                if (animation === 'fade_in') {
                  line.style.animation = 'ai-fade-in-{{ ai_gen_id }} 0.6s ease-out forwards';
                } else if (animation === 'slide_up') {
                  line.style.animation = 'ai-slide-up-{{ ai_gen_id }} 0.6s ease-out forwards';
                } else if (animation === 'slide_down') {
                  line.style.animation = 'ai-slide-down-{{ ai_gen_id }} 0.6s ease-out forwards';
                } else {
                  line.style.opacity = '1';
                }
              }, delay * 1000);

              observer.unobserve(line);
            }
          });
        }, {
          threshold: 0.1
        });

        this.lines.forEach((line) => {
          observer.observe(line);
        });
      }
    }

    customElements.define('free-text-section-{{ ai_gen_id }}', FreeTextSection{{ ai_gen_id }});
  })();
</script>


{% doc %}
  @prompt
    Create a full-width image carousel block with the following features:
    
    - Support for up to 6 slides with separate desktop and mobile images for each slide
    - Text overlay capability with individual text content per slide
    - Separate clickable link/URL per slide
    - Precise positioning controls for text overlay (horizontal and vertical alignment) with separate controls for desktop and mobile
    - Complete text styling options: font family selector, font size, font weight, letter spacing, line height, text color, and text shadow
    - Smooth carousel animation with configurable speed and transition type (fade, slide, etc.)
    - Seamless transitions with no white flashes between slides - use crossfade or preloading techniques
    - Navigation controls: toggle for arrows, dots/pagination indicators, autoplay option
    - Fully responsive with independent settings for mobile and desktop layouts
    - Settings should be organized in clear sections for images, text, positioning, styling, and animation, Can you make the link text positioning totally customisable 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-carousel-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-carousel-slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: {{ block.settings.aspect_ratio_mobile }}%;
  }

  @media screen and (min-width: 750px) {
    .ai-carousel-slides-{{ ai_gen_id }} {
      padding-bottom: {{ block.settings.aspect_ratio_desktop }}%;
    }
  }

  .ai-carousel-slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity {{ block.settings.transition_speed }}ms ease-in-out;
  }

  .ai-carousel-slide-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    z-index: 2;
  }

  .ai-carousel-slide-{{ ai_gen_id }}.previous {
    opacity: 0;
    visibility: visible;
    z-index: 1;
  }

  .ai-carousel-slide-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    text-decoration: none;
  }

  .ai-carousel-slide-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-carousel-slide-image-desktop-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .ai-carousel-slide-image-mobile-{{ ai_gen_id }} {
      display: none;
    }
    .ai-carousel-slide-image-desktop-{{ ai_gen_id }} {
      display: block;
    }
  }

  .ai-carousel-text-overlay-{{ ai_gen_id }} {
    position: absolute;
    z-index: 3;
    pointer-events: none;
    max-width: 90%;
    padding: 20px;
    top: {{ block.settings.text_position_mobile_top }}%;
    left: {{ block.settings.text_position_mobile_left }}%;
    transform: translate(-{{ block.settings.text_position_mobile_left }}%, -{{ block.settings.text_position_mobile_top }}%);
  }

  @media screen and (min-width: 750px) {
    .ai-carousel-text-overlay-{{ ai_gen_id }} {
      top: {{ block.settings.text_position_desktop_top }}%;
      left: {{ block.settings.text_position_desktop_left }}%;
      transform: translate(-{{ block.settings.text_position_desktop_left }}%, -{{ block.settings.text_position_desktop_top }}%);
    }
  }

  .ai-carousel-text-content-{{ ai_gen_id }} {
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-size: {{ block.settings.text_size_mobile }}px;
    line-height: {{ block.settings.text_line_height }};
    letter-spacing: {{ block.settings.text_letter_spacing }}px;
    color: {{ block.settings.text_color }};
    text-shadow: {{ block.settings.text_shadow_x }}px {{ block.settings.text_shadow_y }}px {{ block.settings.text_shadow_blur }}px {{ block.settings.text_shadow_color }};
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .ai-carousel-text-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_desktop }}px;
    }
  }

  .ai-carousel-arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: {{ block.settings.arrow_opacity }};
    transition: opacity 0.3s ease;
  }

  .ai-carousel-arrow-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-carousel-arrow-{{ ai_gen_id }}--prev {
    left: 20px;
  }

  .ai-carousel-arrow-{{ ai_gen_id }}--next {
    right: 20px;
  }

  .ai-carousel-arrow-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
  }

  .ai-carousel-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    gap: 10px;
  }

  .ai-carousel-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    opacity: {{ block.settings.dot_opacity_inactive }};
    transition: opacity 0.3s ease;
    padding: 0;
  }

  .ai-carousel-dot-{{ ai_gen_id }}.active {
    opacity: {{ block.settings.dot_opacity_active }};
  }

  .ai-carousel-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-carousel-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-carousel-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }
{% endstyle %}

<image-carousel-{{ ai_gen_id }} class="ai-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-carousel-slides-{{ ai_gen_id }}">
    {% assign has_slides = false %}
    {% for i in (1..6) %}
      {% assign slide_enabled_key = 'slide_' | append: i | append: '_enabled' %}
      {% assign slide_desktop_image_key = 'slide_' | append: i | append: '_desktop_image' %}
      {% assign slide_mobile_image_key = 'slide_' | append: i | append: '_mobile_image' %}
      {% assign slide_text_key = 'slide_' | append: i | append: '_text' %}
      {% assign slide_link_key = 'slide_' | append: i | append: '_link' %}

      {% assign slide_enabled = block.settings[slide_enabled_key] %}
      {% assign desktop_image = block.settings[slide_desktop_image_key] %}
      {% assign mobile_image = block.settings[slide_mobile_image_key] %}
      {% assign slide_text = block.settings[slide_text_key] %}
      {% assign slide_link = block.settings[slide_link_key] %}

      {% if slide_enabled %}
        {% assign has_slides = true %}
        <div class="ai-carousel-slide-{{ ai_gen_id }}{% if forloop.first %} active{% endif %}" data-slide-index="{{ forloop.index0 }}">
          {% if slide_link != blank %}
            <a href="{{ slide_link }}" class="ai-carousel-slide-link-{{ ai_gen_id }}">
          {% else %}
            <div class="ai-carousel-slide-link-{{ ai_gen_id }}">
          {% endif %}
            {% if desktop_image != blank or mobile_image != blank %}
              {% if mobile_image != blank %}
                <img
                  src="{{ mobile_image | image_url: width: 1500 }}"
                  alt="{{ mobile_image.alt | escape }}"
                  class="ai-carousel-slide-image-{{ ai_gen_id }} ai-carousel-slide-image-mobile-{{ ai_gen_id }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  width="{{ mobile_image.width }}"
                  height="{{ mobile_image.height }}"
                >
              {% endif %}
              {% if desktop_image != blank %}
                <img
                  src="{{ desktop_image | image_url: width: 2400 }}"
                  alt="{{ desktop_image.alt | escape }}"
                  class="ai-carousel-slide-image-{{ ai_gen_id }} ai-carousel-slide-image-desktop-{{ ai_gen_id }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  width="{{ desktop_image.width }}"
                  height="{{ desktop_image.height }}"
                >
              {% endif %}
            {% else %}
              <div class="ai-carousel-placeholder-{{ ai_gen_id }}">
                {{ 'hero-apparel-1' | placeholder_svg_tag }}
                {% if forloop.first %}
                  <div class="ai-carousel-empty-state-{{ ai_gen_id }}">
                    Add images to your slides
                  </div>
                {% endif %}
              </div>
            {% endif %}

            {% if slide_text != blank %}
              <div class="ai-carousel-text-overlay-{{ ai_gen_id }}">
                <div class="ai-carousel-text-content-{{ ai_gen_id }}">
                  {{ slide_text }}
                </div>
              </div>
            {% endif %}
          {% if slide_link != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if has_slides and block.settings.show_arrows %}
    <button class="ai-carousel-arrow-{{ ai_gen_id }} ai-carousel-arrow-{{ ai_gen_id }}--prev" aria-label="Previous slide">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>
    <button class="ai-carousel-arrow-{{ ai_gen_id }} ai-carousel-arrow-{{ ai_gen_id }}--next" aria-label="Next slide">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  {% endif %}

  {% if has_slides and block.settings.show_dots %}
    <div class="ai-carousel-dots-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% assign slide_enabled_key = 'slide_' | append: i | append: '_enabled' %}
        {% if block.settings[slide_enabled_key] %}
          <button class="ai-carousel-dot-{{ ai_gen_id }}{% if forloop.first %} active{% endif %}" data-slide-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</image-carousel-{{ ai_gen_id }}>

{{ block.settings.text_font | font_face: font_display: 'swap' }}

<script>
  (function() {
    class ImageCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.slides = [];
        this.autoplayInterval = null;
        this.isTransitioning = false;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-carousel-slide-{{ ai_gen_id }}'));
        
        if (this.slides.length === 0) return;

        this.prevButton = this.querySelector('.ai-carousel-arrow-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-carousel-arrow-{{ ai_gen_id }}--next');
        this.dots = Array.from(this.querySelectorAll('.ai-carousel-dot-{{ ai_gen_id }}'));

        this.setupEventListeners();
        
        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}

        this.preloadImages();
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.goToPrevious());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.goToNext());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          {% if block.settings.autoplay %}
            this.startAutoplay();
          {% endif %}
        });
      }

      goToSlide(index) {
        if (this.isTransitioning || index === this.currentIndex) return;
        
        this.isTransitioning = true;
        const previousIndex = this.currentIndex;
        
        this.slides[previousIndex].classList.remove('active');
        this.slides[previousIndex].classList.add('previous');
        
        this.slides[index].classList.add('active');
        this.slides[index].classList.remove('previous');
        
        this.dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === index);
        });

        this.currentIndex = index;

        setTimeout(() => {
          this.slides[previousIndex].classList.remove('previous');
          this.isTransitioning = false;
        }, {{ block.settings.transition_speed }});
      }

      goToNext() {
        const nextIndex = (this.currentIndex + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      goToPrevious() {
        const prevIndex = (this.currentIndex - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          this.goToNext();
        }, {{ block.settings.autoplay_speed }});
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      preloadImages() {
        this.slides.forEach((slide, index) => {
          if (index > 0) {
            const images = slide.querySelectorAll('img');
            images.forEach(img => {
              const preloadImg = new Image();
              preloadImg.src = img.src;
            });
          }
        });
      }
    }

    customElements.define('image-carousel-{{ ai_gen_id }}', ImageCarousel{{ ai_gen_id }});
  })();
</script>


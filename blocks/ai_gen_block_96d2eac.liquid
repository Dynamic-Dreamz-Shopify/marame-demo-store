{% doc %}
  @prompt
    Create a simple fullscreen video banner section with these specific requirements:
    - Single video upload field for desktop and single video upload field for mobile
    - Use native Shopify video handling with proper source URLs
    - HTML5 video tag with these exact attributes: autoplay muted loop playsinline preload="auto"
    - CSS: position relative, width 100%, height 100vh, object-fit cover
    - Media query at 768px to switch between desktop and mobile videos
    - Ensure video sources use proper Shopify CDN URLs
    - Add a dark grey background color as fallback while video loads
    - No complex toggles or modes - just straightforward video uploads that work
    - Include proper video MIME type in source tag
    - Test that video element actually renders the uploaded file
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-fullscreen-video-banner-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    background-color: #2a2a2d;
  }

  .ai-fullscreen-video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-fullscreen-video-desktop-{{ ai_gen_id }} {
    display: block;
  }

  .ai-fullscreen-video-mobile-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 768px) {
    .ai-fullscreen-video-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-fullscreen-video-mobile-{{ ai_gen_id }} {
      display: block;
    }
  }
{% endstyle %}

<fullscreen-video-banner-{{ ai_gen_id }}
  class="ai-fullscreen-video-banner-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.video_desktop != blank %}
    <video
      class="ai-fullscreen-video-{{ ai_gen_id }} ai-fullscreen-video-desktop-{{ ai_gen_id }}"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
    >
      <source src="{{ block.settings.video_desktop.sources[1].url }}" type="{{ block.settings.video_desktop.sources[1].mime_type }}">
    </video>
  {% endif %}

  {% if block.settings.video_mobile != blank %}
    <video
      class="ai-fullscreen-video-{{ ai_gen_id }} ai-fullscreen-video-mobile-{{ ai_gen_id }}"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
    >
      <source src="{{ block.settings.video_mobile.sources[1].url }}" type="{{ block.settings.video_mobile.sources[1].mime_type }}">
    </video>
  {% endif %}
</fullscreen-video-banner-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Fullscreen video banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video_desktop",
      "label": "Desktop video"
    },
    {
      "type": "video",
      "id": "video_mobile",
      "label": "Mobile video"
    }
  ],
  "presets": [
    {
      "name": "Fullscreen video banner"
    }
  ]
}
{% endschema %}

              {{ block.settings.link_text_3 }}
            </a>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.message_4 != blank %}
        <div class="ai-announcement-bar__message-{{ ai_gen_id }}" data-message-index="3">
          {{ block.settings.message_4 }}
          {% if block.settings.link_4 != blank %}
            <a href="{{ block.settings.link_4 }}" class="ai-announcement-bar__link-{{ ai_gen_id }}">
              {{ block.settings.link_text_4 }}

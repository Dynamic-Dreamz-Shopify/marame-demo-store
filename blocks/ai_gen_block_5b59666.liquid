{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-announcement-bar-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    overflow: hidden;
    position: relative;
    padding: 9px 0;
    display: block;
  }
  
  {% comment %} .template-product .ai-announcement-bar-{{ ai_gen_id }} {
    display: none;
  } {% endcomment %}

  .ai-announcement-bar__container-{{ ai_gen_id }} {
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ai-announcement-bar__trustpilot-{{ ai_gen_id }} {
    display: none;
  }

  @media (min-width: 1025px) {
    .ai-announcement-bar__trustpilot-{{ ai_gen_id }} {
      display: block;
      position: absolute !important;
      top: 50%;
      right: 25px;
      transform: translateY(-50%) scale(0.7);
      width: 400px;
      z-index: 10;
    }
  }

  .ai-announcement-bar__messages-wrapper-{{ ai_gen_id }} {
    position: relative;
    height: 22px;
    overflow: hidden;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-announcement-bar__message-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 20px;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    letter-spacing: 3px;
    opacity: 0;
    transform: translateY(-100%);
  }

  .ai-announcement-bar__message-{{ ai_gen_id }}.active {
    animation: ai-drop-in-{{ ai_gen_id }} {{ block.settings.animation_duration }}s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  .ai-announcement-bar__message-{{ ai_gen_id }}.exit {
    animation: ai-drop-out-{{ ai_gen_id }} {{ block.settings.animation_duration | times: 0.5 }}s ease-in forwards;
  }

  @keyframes ai-drop-in-{{ ai_gen_id }} {
    0% {
      opacity: 0;
      transform: translateY(-100%);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes ai-drop-out-{{ ai_gen_id }} {
    0% {
      opacity: 1;
      transform: translateY(0);
    }
    100% {
      opacity: 0;
      transform: translateY(0);
    }
  }

  .ai-announcement-bar__link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
    margin-left: 8px;
  }

  .ai-announcement-bar__link-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {
    .ai-announcement-bar__message-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.85 }}px;
      padding: 0 16px;
    }
  }
{% endstyle %}

<announcement-bar-{{ ai_gen_id }} class="ai-announcement-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-announcement-bar__container-{{ ai_gen_id }}">
    <div class="ai-announcement-bar__messages-wrapper-{{ ai_gen_id }}">
      {% if block.settings.message_1 != blank %}
        <div class="ai-announcement-bar__message-{{ ai_gen_id }}" data-message-index="0">
          {{ block.settings.message_1 }}
          {% if block.settings.link_1 != blank %}
            <a href="{{ block.settings.link_1 }}" class="ai-announcement-bar__link-{{ ai_gen_id }}">
              {{ block.settings.link_text_1 }}
            </a>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.message_2 != blank %}

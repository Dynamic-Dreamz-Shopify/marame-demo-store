      {% endif %}
    </div>

    {% if block.settings.show_trustpilot %}
      <div class="ai-announcement-bar__trustpilot-{{ ai_gen_id }}">
        <div class="trustpilot-widget" data-locale="en-US" data-template-id="5419b637fa0340045cd0c936" data-businessunit-id="6863d52829d0eb9d7940e024" data-style-height="20px" data-style-width="100%" data-theme="dark" data-token="98037185-ea42-4936-8e58-13ba24d149ef">
          <a href="https://www.trustpilot.com/review/marame.com" target="_blank" rel="noopener">Trustpilot</a>
        </div>
      </div>
    {% endif %}
  </div>
</announcement-bar-{{ ai_gen_id }}>

<script>
  (function() {
    class AnnouncementBar{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.messages = [];
        this.currentIndex = 0;
        this.displayDuration = {{ block.settings.display_duration | times: 1000 }};
        this.animationDuration = {{ block.settings.animation_duration | times: 1000 }};
        this.intervalId = null;
        this.trustpilotLoaded = false;
      }

      connectedCallback() {
        this.messages = Array.from(this.querySelectorAll('.ai-announcement-bar__message-{{ ai_gen_id }}'));
        
        if (this.messages.length === 0) return;

        if (this.messages.length === 1) {
          this.messages[0].classList.add('active');
        } else {
          this.startRotation();
        }

        this.loadTrustpilot();
      }

      loadTrustpilot() {
        if (this.trustpilotLoaded || !{{ block.settings.show_trustpilot | json }}) return;

        const existingScript = document.querySelector('script[src*="trustpilot"]');
        if (existingScript) {
          this.trustpilotLoaded = true;
          if (window.Trustpilot) {
            window.Trustpilot.loadFromElement(this.querySelector('.trustpilot-widget'), true);
          }
          return;
        }

        const script = document.createElement('script');
        script.src = 'https://widget.trustpilot.com/bootstrap/v5/tp.widget.bootstrap.min.js';
        script.async = true;
        document.head.appendChild(script);
        this.trustpilotLoaded = true;
      }

      startRotation() {
        this.showMessage(this.currentIndex);

        this.intervalId = setInterval(() => {
          this.rotateMessage();
        }, this.displayDuration + this.animationDuration);
      }

      showMessage(index) {
        const message = this.messages[index];
        if (message) {
          message.classList.add('active');
        }
      }

      hideMessage(index) {
        const message = this.messages[index];
        if (message) {
          message.classList.add('exit');
          
          setTimeout(() => {
            message.classList.remove('active', 'exit');
          }, this.animationDuration * 0.5);
        }
      }

      rotateMessage() {
        this.hideMessage(this.currentIndex);
        
        this.currentIndex = (this.currentIndex + 1) % this.messages.length;
        
        setTimeout(() => {
          this.showMessage(this.currentIndex);
        }, this.animationDuration * 0.5);
      }

      disconnectedCallback() {
        if (this.intervalId) {
          clearInterval(this.intervalId);
        }
      }
    }

    customElements.define('announcement-bar-{{ ai_gen_id }}', AnnouncementBar{{ ai_gen_id }});
  })();
</script>


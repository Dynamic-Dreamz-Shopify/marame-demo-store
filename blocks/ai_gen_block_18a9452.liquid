{% doc %}
  @prompt
    Create a hero carousel section with multiple slides. Each slide has a desktop image and a mobile image (using a picture element to swap at 749px). Section settings: autoplay checkbox, autoplay delay range 2000-8000ms, show arrows checkbox, show dots checkbox. Vanilla JS for slide transitions with arrow and dot navigation. Each slide block also has a text link (label + URL, colour picker, font size) overlaid at the bottom of the image. Shopify 2.0 Liquid syntax., Add a second block type called slide_link. Each slide_link has a slide_number select (1–10) to assign it to a slide, plus a link label, URL, text colour, and font size. Render all slide_links for a given slide overlaid at the bottom of that slide., Add a separate mobile link display for each slide. On screens under 749px, hide the desktop link overlay and instead show the links stacked vertically below the image. Add a mobile font size and mobile text colour setting to each slide_link block., Add desktop positioning to each slide_link block: horizontal position (Left/Center/Right), vertical position (Top/Middle/Bottom), padding, and margin. Apply these as inline styles on each desktop link., Add to each slide_link block: font weight (300/400/500/600/700), letter spacing, text transform (uppercase/lowercase/none), hover colour, and underline toggle. Apply via a scoped style block using the block ID as a selector., Can you change it so I can add up to 10 links and then simply chose on each one which slides they appear on, the stylisation for each link would be the same, it's just the overal positioning of the links I'll need to adjust (for desktop and mobile) but the position of the links on each slide will stay the same, The links aren't displaying on mobile and also I need to be able to adjust the same settings on the mobile links as I can on the desktop in terms of placement etc... also the letter spacing and weight on the links is also not working, Theres a white space under image 1, the carousel needs to fit to the image, the mobile links need to sit over the image, not under the image and I need to be able adjust the position of them
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-carousel-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-hero-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: block;
  }

  .ai-hero-carousel-slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: block;
  }

  .ai-hero-carousel-slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s ease-in-out, visibility 0.5s ease-in-out;
    display: block;
  }

  .ai-hero-carousel-slide-{{ ai_gen_id }}.active {
    position: relative;
    opacity: 1;
    visibility: visible;
  }

  .ai-hero-carousel-slide-{{ ai_gen_id }} picture {
    display: block;
    width: 100%;
    line-height: 0;
  }

  .ai-hero-carousel-slide-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    vertical-align: middle;
  }

  .ai-hero-carousel-links-desktop-{{ ai_gen_id }} {
    position: absolute;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.desktop_link_gap }}px;
  }

  .ai-hero-carousel-links-desktop-{{ ai_gen_id }}.horizontal-left {
    left: {{ block.settings.desktop_horizontal_offset }}%;
  }

  .ai-hero-carousel-links-desktop-{{ ai_gen_id }}.horizontal-center {
    left: 50%;
    transform: translateX(-50%);
  }

  .ai-hero-carousel-links-desktop-{{ ai_gen_id }}.horizontal-right {
    right: {{ block.settings.desktop_horizontal_offset }}%;
  }

  .ai-hero-carousel-links-desktop-{{ ai_gen_id }}.vertical-top {
    top: {{ block.settings.desktop_vertical_offset }}%;
  }

  .ai-hero-carousel-links-desktop-{{ ai_gen_id }}.vertical-middle {
    top: 50%;
    transform: translateY(-50%);
  }

  .ai-hero-carousel-links-desktop-{{ ai_gen_id }}.vertical-middle.horizontal-center {
    transform: translate(-50%, -50%);
  }

  .ai-hero-carousel-links-desktop-{{ ai_gen_id }}.vertical-bottom {
    bottom: {{ block.settings.desktop_vertical_offset }}%;
  }

  .ai-hero-carousel-links-mobile-{{ ai_gen_id }} {
    display: none;
  }

  .ai-hero-carousel-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    font-size: {{ block.settings.link_font_size }}px;
    font-weight: {{ block.settings.link_font_weight }};
    letter-spacing: {{ block.settings.link_letter_spacing }}px;
    text-transform: {{ block.settings.link_text_transform }};
    text-decoration: {% if block.settings.link_underline %}underline{% else %}none{% endif %};
    padding: {{ block.settings.desktop_link_padding }}px;
    margin: {{ block.settings.desktop_link_margin }}px;
    transition: color 0.3s ease;
  }

  .ai-hero-carousel-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-hero-carousel-arrows-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0, 0, 0, 0.5);
    color: #ffffff;
    border: none;
    width: 40px;
    height: 40px;
    cursor: pointer;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease;
  }

  .ai-hero-carousel-arrows-{{ ai_gen_id }}:hover {
    background: rgba(0, 0, 0, 0.7);
  }

  .ai-hero-carousel-arrow-prev-{{ ai_gen_id }} {
    left: 10px;
  }

  .ai-hero-carousel-arrow-next-{{ ai_gen_id }} {
    right: 10px;
  }

  .ai-hero-carousel-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 3;
  }

  .ai-hero-carousel-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s ease;
  }

  .ai-hero-carousel-dot-{{ ai_gen_id }}.active {
    background: rgba(255, 255, 255, 1);
  }

  @media screen and (max-width: 749px) {
    .ai-hero-carousel-links-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-hero-carousel-links-mobile-{{ ai_gen_id }} {
      position: absolute;
      z-index: 2;
      display: flex;
      flex-direction: column;
      gap: {{ block.settings.mobile_link_gap }}px;
      padding: {{ block.settings.mobile_link_padding }}px;
      margin: {{ block.settings.mobile_link_margin }}px;
    }

    .ai-hero-carousel-links-mobile-{{ ai_gen_id }}.horizontal-left {
      left: {{ block.settings.mobile_horizontal_offset }}%;
      align-items: flex-start;
    }

    .ai-hero-carousel-links-mobile-{{ ai_gen_id }}.horizontal-center {
      left: 50%;
      transform: translateX(-50%);
      align-items: center;
    }

    .ai-hero-carousel-links-mobile-{{ ai_gen_id }}.horizontal-right {
      right: {{ block.settings.mobile_horizontal_offset }}%;
      align-items: flex-end;
    }

    .ai-hero-carousel-links-mobile-{{ ai_gen_id }}.vertical-top {
      top: {{ block.settings.mobile_vertical_offset }}%;
    }

    .ai-hero-carousel-links-mobile-{{ ai_gen_id }}.vertical-middle {
      top: 50%;
      transform: translateY(-50%);
    }

    .ai-hero-carousel-links-mobile-{{ ai_gen_id }}.vertical-middle.horizontal-center {
      transform: translate(-50%, -50%);
    }

    .ai-hero-carousel-links-mobile-{{ ai_gen_id }}.vertical-bottom {
      bottom: {{ block.settings.mobile_vertical_offset }}%;
    }

    .ai-hero-carousel-link-mobile-{{ ai_gen_id }} {
      color: {{ block.settings.mobile_link_color }};
      font-size: {{ block.settings.mobile_link_font_size }}px;
      font-weight: {{ block.settings.link_font_weight }};
      letter-spacing: {{ block.settings.link_letter_spacing }}px;
      text-transform: {{ block.settings.link_text_transform }};
      text-decoration: {% if block.settings.link_underline %}underline{% else %}none{% endif %};
      transition: color 0.3s ease;
    }

    .ai-hero-carousel-link-mobile-{{ ai_gen_id }}:hover {
      color: {{ block.settings.link_hover_color }};
    }
  }
{% endstyle %}

<hero-carousel-{{ ai_gen_id }}
  class="ai-hero-carousel-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-delay="{{ block.settings.autoplay_delay }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-hero-carousel-wrapper-{{ ai_gen_id }}">
    <div class="ai-hero-carousel-slides-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        {% assign slide_enabled_key = 'slide_' | append: i | append: '_enabled' %}
        {% assign slide_desktop_image_key = 'slide_' | append: i | append: '_desktop_image' %}
        {% assign slide_mobile_image_key = 'slide_' | append: i | append: '_mobile_image' %}

        {% if block.settings[slide_enabled_key] %}
          <div class="ai-hero-carousel-slide-{{ ai_gen_id }}" data-slide="{{ i }}">
            <picture>
              {% if block.settings[slide_mobile_image_key] %}
                <source
                  media="(max-width: 749px)"
                  srcset="{{ block.settings[slide_mobile_image_key] | image_url: width: 750 }}"
                >
              {% endif %}
              {% if block.settings[slide_desktop_image_key] %}
                <img
                  src="{{ block.settings[slide_desktop_image_key] | image_url: width: 2000 }}"
                  alt="{{ block.settings[slide_desktop_image_key].alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings[slide_desktop_image_key].width }}"
                  height="{{ block.settings[slide_desktop_image_key].height }}"
                >
              {% else %}
                <div class="ai-hero-carousel-placeholder-{{ ai_gen_id }}">
                  {{ 'hero-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </picture>

            <div class="ai-hero-carousel-links-desktop-{{ ai_gen_id }} horizontal-{{ block.settings.desktop_horizontal_position }} vertical-{{ block.settings.desktop_vertical_position }}">
              {% for j in (1..10) %}
                {% assign link_enabled_key = 'link_' | append: j | append: '_enabled' %}
                {% assign link_slides_key = 'link_' | append: j | append: '_slides' %}
                {% assign link_label_key = 'link_' | append: j | append: '_label' %}
                {% assign link_url_key = 'link_' | append: j | append: '_url' %}

                {% if block.settings[link_enabled_key] %}
                  {% assign link_slides = block.settings[link_slides_key] %}
                  {% assign current_slide_str = i | append: '' %}
                  {% if link_slides contains current_slide_str %}
                    <a
                      href="{{ block.settings[link_url_key] }}"
                      class="ai-hero-carousel-link-{{ ai_gen_id }}"
                    >
                      {{ block.settings[link_label_key] }}
                    </a>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </div>

            <div class="ai-hero-carousel-links-mobile-{{ ai_gen_id }} horizontal-{{ block.settings.mobile_horizontal_position }} vertical-{{ block.settings.mobile_vertical_position }}" data-slide-mobile="{{ i }}">
              {% for j in (1..10) %}
                {% assign link_enabled_key = 'link_' | append: j | append: '_enabled' %}
                {% assign link_slides_key = 'link_' | append: j | append: '_slides' %}
                {% assign link_label_key = 'link_' | append: j | append: '_label' %}
                {% assign link_url_key = 'link_' | append: j | append: '_url' %}

                {% if block.settings[link_enabled_key] %}
                  {% assign link_slides = block.settings[link_slides_key] %}
                  {% assign current_slide_str = i | append: '' %}
                  {% if link_slides contains current_slide_str %}
                    <a
                      href="{{ block.settings[link_url_key] }}"
                      class="ai-hero-carousel-link-mobile-{{ ai_gen_id }}"
                    >
                      {{ block.settings[link_label_key] }}
                    </a>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if block.settings.show_arrows %}
      <button
        class="ai-hero-carousel-arrows-{{ ai_gen_id }} ai-hero-carousel-arrow-prev-{{ ai_gen_id }}"
        aria-label="Previous slide"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 16L6 10L12 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button
        class="ai-hero-carousel-arrows-{{ ai_gen_id }} ai-hero-carousel-arrow-next-{{ ai_gen_id }}"
        aria-label="Next slide"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 4L14 10L8 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.show_dots %}
      <div class="ai-hero-carousel-dots-{{ ai_gen_id }}"></div>
    {% endif %}
  </div>
</hero-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.autoplayTimer = null;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-hero-carousel-slide-{{ ai_gen_id }}'));
        this.autoplay = this.dataset.autoplay === 'true';
        this.delay = parseInt(this.dataset.delay) || 5000;

        if (this.slides.length === 0) return;

        this.showSlide(0);
        this.setupDots();
        this.setupArrows();

        if (this.autoplay) {
          this.startAutoplay();
        }
      }

      showSlide(index) {
        this.slides.forEach((slide, i) => {
          if (i === index) {
            slide.classList.add('active');
          } else {
            slide.classList.remove('active');
          }
        });

        this.updateDots(index);
        this.currentSlide = index;
      }

      setupDots() {
        const dotsContainer = this.querySelector('.ai-hero-carousel-dots-{{ ai_gen_id }}');
        if (!dotsContainer) return;

        dotsContainer.innerHTML = '';
        this.slides.forEach((_, index) => {
          const dot = document.createElement('button');
          dot.classList.add('ai-hero-carousel-dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', `Go to slide ${index + 1}`);
          dot.addEventListener('click', () => {
            this.showSlide(index);
            if (this.autoplay) {
              this.resetAutoplay();
            }
          });
          dotsContainer.appendChild(dot);
        });
      }

      updateDots(activeIndex) {
        const dots = this.querySelectorAll('.ai-hero-carousel-dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          if (index === activeIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      setupArrows() {
        const prevButton = this.querySelector('.ai-hero-carousel-arrow-prev-{{ ai_gen_id }}');
        const nextButton = this.querySelector('.ai-hero-carousel-arrow-next-{{ ai_gen_id }}');

        if (prevButton) {
          prevButton.addEventListener('click', () => {
            this.previousSlide();
            if (this.autoplay) {
              this.resetAutoplay();
            }
          });
        }

        if (nextButton) {
          nextButton.addEventListener('click', () => {
            this.nextSlide();
            if (this.autoplay) {
              this.resetAutoplay();
            }
          });
        }
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.showSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.showSlide(prevIndex);
      }

      startAutoplay() {
        this.autoplayTimer = setInterval(() => {
          this.nextSlide();
        }, this.delay);
      }

      resetAutoplay() {
        clearInterval(this.autoplayTimer);
        this.startAutoplay();
      }

      disconnectedCallback() {
        if (this.autoplayTimer) {
          clearInterval(this.autoplayTimer);
        }
      }
    }

    customElements.define('hero-carousel-{{ ai_gen_id }}', HeroCarousel{{ ai_gen_id }});
  })();
</script>


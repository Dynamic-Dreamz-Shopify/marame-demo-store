{% doc %}
  @prompt
    Create a section that displays a Trustpilot widget embed code with mobile/desktop visibility controls. The section should only be visible on mobile devices by default and hidden on desktop using CSS media queries. Include a setting to paste custom HTML/embed code. Add a background color setting that defaults to black and can be easily changed through the theme editor. Include padding controls for top and bottom spacing.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trustpilot-widget-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-trustpilot-widget-container-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding-left: 16px;
    padding-right: 16px;
  }

  .ai-trustpilot-widget-embed-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-trustpilot-widget-placeholder-{{ ai_gen_id }} {
    background-color: rgba(255, 255, 255, 0.1);
    border: 2px dashed rgba(255, 255, 255, 0.3);
    border-radius: 8px;
    padding: 40px 20px;
    text-align: center;
    color: rgba(255, 255, 255, 0.7);
    font-size: 14px;
  }

  @media screen and (min-width: 750px) {
    {% if block.settings.hide_on_desktop %}
      .ai-trustpilot-widget-{{ ai_gen_id }} {
        display: none;
      }
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    {% if block.settings.hide_on_mobile %}
      .ai-trustpilot-widget-{{ ai_gen_id }} {
        display: none;
      }
    {% endif %}
  }
{% endstyle %}

<div class="ai-trustpilot-widget-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trustpilot-widget-container-{{ ai_gen_id }}">
    {% if block.settings.embed_code != blank %}
      <div class="ai-trustpilot-widget-embed-{{ ai_gen_id }}">
        {{ block.settings.embed_code }}
      </div>
    {% else %}
      <div class="ai-trustpilot-widget-placeholder-{{ ai_gen_id }}">
        Paste your Trustpilot widget embed code in the block settings
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Trustpilot widget",
  "settings": [
    {
      "type": "header",
      "content": "Widget code"
    },
    {
      "type": "html",
      "id": "embed_code",
      "label": "Trustpilot embed code"
    },
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Hide on desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Trustpilot widget"
    }
  ]
}
{% endschema %}

{% doc %}
  @prompt
    Create a reusable homepage section with two video panels.
    
    
    Layout: • On desktop: 50/50 split screen, one video left and one right. • On mobile: videos stack vertically, full width.
    
    
    Video settings (for each panel): • Upload 1080p video • Optional poster image • Autoplay toggle • Loop toggle • Mute toggle • Optional mute/unmute button overlay • Object fit option (cover or contain)
    
    
    Overlay link (for each panel): • Add clickable overlay text with URL • Option for whole video to be clickable • Full text styling controls: • Font • Size (desktop and mobile) • Weight • Colour • Letter spacing • Line height • Alignment • Adjustable position controls for desktop and mobile
    
    
    General settings: • Adjustable padding and spacing • Works smoothly with autoplay on desktop (side by side) and mobile (stacked) • Responsive and optimised for performance
    
    
    Make this fully editable in the theme editor with clearly separated settings for Video 1 and Video 2.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-dual-video-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-dual-video__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    width: 100%;
  }

  .ai-dual-video__panel-{{ ai_gen_id }} {
    position: relative;
    flex: 1;
    overflow: hidden;
  }

  .ai-dual-video__video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: {{ block.settings.min_height_desktop }}px;
  }

  .ai-dual-video__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.video_1_object_fit }};
  }

  .ai-dual-video__video-{{ ai_gen_id }}--panel-2 {
    object-fit: {{ block.settings.video_2_object_fit }};
  }

  .ai-dual-video__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: {{ block.settings.video_1_text_vertical_position }};
    justify-content: {{ block.settings.video_1_text_horizontal_position }};
    padding: 20px;
    z-index: 2;
  }

  .ai-dual-video__overlay-{{ ai_gen_id }}--panel-2 {
    align-items: {{ block.settings.video_2_text_vertical_position }};
    justify-content: {{ block.settings.video_2_text_horizontal_position }};
  }

  .ai-dual-video__text-{{ ai_gen_id }} {
    font-family: {{ block.settings.video_1_text_font.family }}, {{ block.settings.video_1_text_font.fallback_families }};
    font-weight: {{ block.settings.video_1_text_font.weight }};
    font-size: {{ block.settings.video_1_text_size_desktop }}px;
    color: {{ block.settings.video_1_text_color }};
    letter-spacing: {{ block.settings.video_1_letter_spacing }}px;
    line-height: {{ block.settings.video_1_line_height }};
    text-align: {{ block.settings.video_1_text_alignment }};
    text-decoration: none;
    display: block;
  }

  .ai-dual-video__text-{{ ai_gen_id }}--panel-2 {
    font-family: {{ block.settings.video_2_text_font.family }}, {{ block.settings.video_2_text_font.fallback_families }};
    font-weight: {{ block.settings.video_2_text_font.weight }};
    font-size: {{ block.settings.video_2_text_size_desktop }}px;
    color: {{ block.settings.video_2_text_color }};
    letter-spacing: {{ block.settings.video_2_letter_spacing }}px;
    line-height: {{ block.settings.video_2_line_height }};
    text-align: {{ block.settings.video_2_text_alignment }};
  }

  .ai-dual-video__mute-button-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    right: 20px;
    background-color: rgba(0, 0, 0, 0.5);
    border: none;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 3;
    color: #ffffff;
    transition: background-color 0.3s ease;
  }

  .ai-dual-video__mute-button-{{ ai_gen_id }}:hover {
    background-color: rgba(0, 0, 0, 0.7);
  }

  .ai-dual-video__mute-button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-dual-video__container-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-dual-video__video-wrapper-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}px;
    }

    .ai-dual-video__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.video_1_text_size_mobile }}px;
    }

    .ai-dual-video__text-{{ ai_gen_id }}--panel-2 {
      font-size: {{ block.settings.video_2_text_size_mobile }}px;
    }

    .ai-dual-video__overlay-{{ ai_gen_id }} {
      align-items: {{ block.settings.video_1_text_vertical_position_mobile }};
      justify-content: {{ block.settings.video_1_text_horizontal_position_mobile }};
    }

    .ai-dual-video__overlay-{{ ai_gen_id }}--panel-2 {
      align-items: {{ block.settings.video_2_text_vertical_position_mobile }};
      justify-content: {{ block.settings.video_2_text_horizontal_position_mobile }};
    }
  }
{% endstyle %}

<dual-video-panels-{{ ai_gen_id }} class="ai-dual-video-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-dual-video__container-{{ ai_gen_id }}">
    <div class="ai-dual-video__panel-{{ ai_gen_id }}">
      <div class="ai-dual-video__video-wrapper-{{ ai_gen_id }}">
        {% if block.settings.video_1 %}
          <video
            class="ai-dual-video__video-{{ ai_gen_id }}"
            {% if block.settings.video_1_autoplay %}autoplay{% endif %}
            {% if block.settings.video_1_loop %}loop{% endif %}
            {% if block.settings.video_1_mute %}muted{% endif %}
            playsinline
            {% if block.settings.video_1_poster %}poster="{{ block.settings.video_1_poster | image_url: width: 1920 }}"{% endif %}
            data-video-id="video-1-{{ ai_gen_id }}"
          >
            <source src="{{ block.settings.video_1.sources[1].url }}" type="{{ block.settings.video_1.sources[1].mime_type }}">
          </video>
        {% else %}
          <div class="ai-dual-video__placeholder-{{ ai_gen_id }}" style="width: 100%; height: 100%; background-color: #f4f4f4; display: flex; align-items: center; justify-content: center;">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if block.settings.video_1_show_mute_button and block.settings.video_1 %}
          <button
            class="ai-dual-video__mute-button-{{ ai_gen_id }}"
            data-mute-button="video-1-{{ ai_gen_id }}"
            aria-label="Toggle mute"
          >
            <svg class="ai-dual-video__mute-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
              <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
            </svg>
            <svg class="ai-dual-video__unmute-icon-{{ ai_gen_id }}" style="display: none;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
              <line x1="23" y1="9" x2="17" y2="15"></line>
              <line x1="17" y1="9" x2="23" y2="15"></line>
            </svg>
          </button>
        {% endif %}

        {% if block.settings.video_1_text != blank or block.settings.video_1_link != blank %}
          <div class="ai-dual-video__overlay-{{ ai_gen_id }}">
            {% if block.settings.video_1_clickable and block.settings.video_1_link != blank %}
              <a href="{{ block.settings.video_1_link }}" class="ai-dual-video__text-{{ ai_gen_id }}">
                {{ block.settings.video_1_text }}
              </a>
            {% elsif block.settings.video_1_text != blank %}
              <div class="ai-dual-video__text-{{ ai_gen_id }}">
                {{ block.settings.video_1_text }}
              </div>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-dual-video__panel-{{ ai_gen_id }}">
      <div class="ai-dual-video__video-wrapper-{{ ai_gen_id }}">
        {% if block.settings.video_2 %}
          <video
            class="ai-dual-video__video-{{ ai_gen_id }} ai-dual-video__video-{{ ai_gen_id }}--panel-2"
            {% if block.settings.video_2_autoplay %}autoplay{% endif %}
            {% if block.settings.video_2_loop %}loop{% endif %}
            {% if block.settings.video_2_mute %}muted{% endif %}
            playsinline
            {% if block.settings.video_2_poster %}poster="{{ block.settings.video_2_poster | image_url: width: 1920 }}"{% endif %}
            data-video-id="video-2-{{ ai_gen_id }}"
          >
            <source src="{{ block.settings.video_2.sources[1].url }}" type="{{ block.settings.video_2.sources[1].mime_type }}">
          </video>
        {% else %}
          <div class="ai-dual-video__placeholder-{{ ai_gen_id }}" style="width: 100%; height: 100%; background-color: #f4f4f4; display: flex; align-items: center; justify-content: center;">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if block.settings.video_2_show_mute_button and block.settings.video_2 %}
          <button
            class="ai-dual-video__mute-button-{{ ai_gen_id }}"
            data-mute-button="video-2-{{ ai_gen_id }}"
            aria-label="Toggle mute"
          >
            <svg class="ai-dual-video__mute-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
              <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
            </svg>
            <svg class="ai-dual-video__unmute-icon-{{ ai_gen_id }}" style="display: none;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
              <line x1="23" y1="9" x2="17" y2="15"></line>
              <line x1="17" y1="9" x2="23" y2="15"></line>
            </svg>
          </button>
        {% endif %}

        {% if block.settings.video_2_text != blank or block.settings.video_2_link != blank %}
          <div class="ai-dual-video__overlay-{{ ai_gen_id }} ai-dual-video__overlay-{{ ai_gen_id }}--panel-2">
            {% if block.settings.video_2_clickable and block.settings.video_2_link != blank %}
              <a href="{{ block.settings.video_2_link }}" class="ai-dual-video__text-{{ ai_gen_id }} ai-dual-video__text-{{ ai_gen_id }}--panel-2">
                {{ block.settings.video_2_text }}
              </a>
            {% elsif block.settings.video_2_text != blank %}
              <div class="ai-dual-video__text-{{ ai_gen_id }} ai-dual-video__text-{{ ai_gen_id }}--panel-2">
                {{ block.settings.video_2_text }}
              </div>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</dual-video-panels-{{ ai_gen_id }}>

<script>
  (function() {
    class DualVideoPanels{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.muteButtons = this.querySelectorAll('[data-mute-button]');
        this.setupMuteButtons();
      }

      setupMuteButtons() {
        this.muteButtons.forEach((button) => {
          const videoId = button.getAttribute('data-mute-button');
          const video = this.querySelector(`[data-video-id="${videoId}"]`);
          const muteIcon = button.querySelector('.ai-dual-video__mute-icon-{{ ai_gen_id }}');
          const unmuteIcon = button.querySelector('.ai-dual-video__unmute-icon-{{ ai_gen_id }}');

          if (!video) return;

          const updateIcon = () => {
            if (video.muted) {
              muteIcon.style.display = 'none';
              unmuteIcon.style.display = 'block';
            } else {
              muteIcon.style.display = 'block';
              unmuteIcon.style.display = 'none';
            }
          };

          updateIcon();

          button.addEventListener('click', () => {
            video.muted = !video.muted;
            updateIcon();
          });
        });
      }
    }

    customElements.define('dual-video-panels-{{ ai_gen_id }}', DualVideoPanels{{ ai_gen_id }});
  })();
</script>


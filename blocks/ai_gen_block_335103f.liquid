{% doc %}
  @prompt
    Create a desktop-only announcement bar with rotating messages on the left/center and a static Trustpilot widget on the right.
    
    LAYOUT REQUIREMENTS:
    - Desktop and tablet only (hidden on mobile)
    - Two-column layout: rotating text messages (left/center) and static Trustpilot widget (right)
    - Text messages must be perfectly centered horizontally within their container
    - Include text alignment setting with options: left, center, right
    - Trustpilot widget positioned on the right side with configurable right padding
    - Fixed bar height to prevent size changes
    
    TEXT MESSAGE FEATURES:
    - Multiple rotating messages with customizable links
    - Auto-rotation with configurable speed (no delay between transitions)
    - Text transform options: uppercase, lowercase, sentence case, normal
    - Customizable font size, text color
    - Proper vertical centering within the bar
    
    TRUSTPILOT WIDGET:
    - Static (doesn't rotate, stays visible)
    - Right-aligned with padding control
    - Scale/size control
    - Must include Trustpilot JavaScript library script to ensure widget renders
    - Uses TrustBox embed code
    
    STYLING CONTROLS:
    - Background color
    - Horizontal and vertical padding
    - Bar height control
    - Device visibility toggle
    
    CRITICAL: Include explicit text-align CSS control so messages can be centered, and ensure the Trustpilot widget actually displays with proper script loading., The trustpilot widget needs to be an embed code 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-announcement-bar-{{ ai_gen_id }} {
    display: none;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;
    height: {{ block.settings.bar_height }}px;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .ai-announcement-bar-{{ ai_gen_id }} {
      display: block;
    }
  }

  .ai-announcement-bar__container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-announcement-bar__messages-{{ ai_gen_id }} {
    flex: 1;
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;
    overflow: hidden;
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
  }

  .ai-announcement-bar__message-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    opacity: 0;
    transition: opacity {{ block.settings.rotation_speed }}s ease-in-out;
    white-space: nowrap;
    width: 100%;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-announcement-bar__message-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-announcement-bar__message-link-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    text-decoration: none;
    font-size: {{ block.settings.font_size }}px;
    {% if block.settings.text_transform == 'uppercase' %}
      text-transform: uppercase;
    {% elsif block.settings.text_transform == 'lowercase' %}
      text-transform: lowercase;
    {% elsif block.settings.text_transform == 'capitalize' %}
      text-transform: capitalize;
    {% endif %}
  }

  .ai-announcement-bar__message-link-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-announcement-bar__trustpilot-{{ ai_gen_id }} {
    flex-shrink: 0;
    padding-right: {{ block.settings.trustpilot_padding }}px;
    display: flex;
    align-items: center;
    height: 100%;
    transform: scale({{ block.settings.trustpilot_scale }});
    transform-origin: center right;
  }
{% endstyle %}

<announcement-bar-{{ ai_gen_id }} class="ai-announcement-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-announcement-bar__container-{{ ai_gen_id }}">
    <div class="ai-announcement-bar__messages-{{ ai_gen_id }}">
      {% if block.settings.message_1 != blank %}
        <div class="ai-announcement-bar__message-{{ ai_gen_id }} active" data-message-index="0">
          {% if block.settings.message_1_link != blank %}
            <a href="{{ block.settings.message_1_link }}" class="ai-announcement-bar__message-link-{{ ai_gen_id }}">
              {{ block.settings.message_1 }}
            </a>
          {% else %}
            <span class="ai-announcement-bar__message-link-{{ ai_gen_id }}">
              {{ block.settings.message_1 }}
            </span>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.message_2 != blank %}
        <div class="ai-announcement-bar__message-{{ ai_gen_id }}" data-message-index="1">
          {% if block.settings.message_2_link != blank %}
            <a href="{{ block.settings.message_2_link }}" class="ai-announcement-bar__message-link-{{ ai_gen_id }}">
              {{ block.settings.message_2 }}
            </a>
          {% else %}
            <span class="ai-announcement-bar__message-link-{{ ai_gen_id }}">
              {{ block.settings.message_2 }}
            </span>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.message_3 != blank %}
        <div class="ai-announcement-bar__message-{{ ai_gen_id }}" data-message-index="2">
          {% if block.settings.message_3_link != blank %}
            <a href="{{ block.settings.message_3_link }}" class="ai-announcement-bar__message-link-{{ ai_gen_id }}">
              {{ block.settings.message_3 }}
            </a>
          {% else %}
            <span class="ai-announcement-bar__message-link-{{ ai_gen_id }}">
              {{ block.settings.message_3 }}
            </span>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.message_4 != blank %}
        <div class="ai-announcement-bar__message-{{ ai_gen_id }}" data-message-index="3">
          {% if block.settings.message_4_link != blank %}
            <a href="{{ block.settings.message_4_link }}" class="ai-announcement-bar__message-link-{{ ai_gen_id }}">
              {{ block.settings.message_4 }}
            </a>
          {% else %}
            <span class="ai-announcement-bar__message-link-{{ ai_gen_id }}">
              {{ block.settings.message_4 }}
            </span>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.message_5 != blank %}
        <div class="ai-announcement-bar__message-{{ ai_gen_id }}" data-message-index="4">
          {% if block.settings.message_5_link != blank %}
            <a href="{{ block.settings.message_5_link }}" class="ai-announcement-bar__message-link-{{ ai_gen_id }}">
              {{ block.settings.message_5 }}
            </a>
          {% else %}
            <span class="ai-announcement-bar__message-link-{{ ai_gen_id }}">
              {{ block.settings.message_5 }}
            </span>
          {% endif %}
        </div>
      {% endif %}
    </div>

    {% if block.settings.show_trustpilot and block.settings.trustpilot_embed_code != blank %}
      <div class="ai-announcement-bar__trustpilot-{{ ai_gen_id }}">
        {{ block.settings.trustpilot_embed_code }}
      </div>
    {% endif %}
  </div>
</announcement-bar-{{ ai_gen_id }}>

<script>
  (function() {
    class AnnouncementBar{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.messages = [];
        this.currentIndex = 0;
        this.rotationSpeed = {{ block.settings.rotation_speed | times: 1000 }};
        this.displayDuration = {{ block.settings.display_duration | times: 1000 }};
      }

      connectedCallback() {
        this.messages = Array.from(this.querySelectorAll('.ai-announcement-bar__message-{{ ai_gen_id }}'));
        
        if (this.messages.length > 1) {
          this.startRotation();
        }

        this.loadTrustpilot();
      }

      startRotation() {
        setInterval(() => {
          this.messages[this.currentIndex].classList.remove('active');
          
          this.currentIndex = (this.currentIndex + 1) % this.messages.length;
          
          this.messages[this.currentIndex].classList.add('active');
        }, this.displayDuration + this.rotationSpeed);
      }

      loadTrustpilot() {
        if (window.Trustpilot) {
          window.Trustpilot.loadFromElement(this.querySelector('.ai-announcement-bar__trustpilot-{{ ai_gen_id }}'), true);
        }
      }

      disconnectedCallback() {
        if (this.rotationInterval) {
          clearInterval(this.rotationInterval);
        }
      }
    }

    customElements.define('announcement-bar-{{ ai_gen_id }}', AnnouncementBar{{ ai_gen_id }});
  })();
</script>

<script src="https://widget.trustpilot.com/bootstrap/v5/tp.widget.bootstrap.min.js" async></script>


{% doc %}
  @prompt
    An accordion for our terms & conditions page. Fully customisable on design/layout/letter spacing/ font/ borders/spacers/animation/hover states/ want it to be totally customisable so I can make it look exactly how I want it to look, it's going to very similar to this:
    
    https://www.reiss.com/terms
    
    , Can you add hover state options, drop down animation options, letter spacing options on the titles and and the content. And divider/spacer options aswell as section padding options and colour options throughout, The padding doesn't seem to be working, it's just adding a white box, rather than adjusting the padding on both sides of the accordion, Currently the content section in the accordion items are linked to our 'custom heading fonts' can we have this so it's open to other fonts', like the headers, I'm still unable to change the content typography, it seems to be defaulting to our headings. Can you have it so that the Item content field is just a text field (like the title) and then the content typography section drives the stylisation of the content typeface, Can you add the option to have the title and content in uppercase/lowercase/sentencase etc... in the typography sections, I need the option to add more accordion items, the number of titles needed could be as many as 60, I can't seem to add more than 10 items, I need to add as many as possible
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-accordion-{{ai_gen_id}} {
    display: block;
    width: 100%;
    padding-top: {{ block.settings.section_padding_top }}px;
    padding-bottom: {{ block.settings.section_padding_bottom }}px;
    padding-left: {{ block.settings.section_padding_horizontal }}px;
    padding-right: {{ block.settings.section_padding_horizontal }}px;
  }

  .ai-accordion-container-{{ai_gen_id}} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-accordion-item-{{ai_gen_id}} {
    border-bottom: {{ block.settings.divider_thickness }}px {{ block.settings.divider_style }} {{ block.settings.divider_color }};
  }

  .ai-accordion-item-{{ai_gen_id}}:first-child {
    border-top: {{ block.settings.divider_thickness }}px {{ block.settings.divider_style }} {{ block.settings.divider_color }};
  }

  .ai-accordion-header-{{ai_gen_id}} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.item_padding_vertical }}px {{ block.settings.item_padding_horizontal }}px;
    background-color: {{ block.settings.title_bg_color }};
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background-color {{ block.settings.animation_duration }}s ease;
  }

  .ai-accordion-header-{{ai_gen_id}}:hover {
    background-color: {{ block.settings.title_hover_bg_color }};
  }

  .ai-accordion-title-{{ai_gen_id}} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-style: {{ block.settings.title_font.style }};
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
    text-transform: {{ block.settings.title_text_transform }};
    margin: 0;
    transition: color {{ block.settings.animation_duration }}s ease;
  }

  .ai-accordion-header-{{ai_gen_id}}:hover .ai-accordion-title-{{ai_gen_id}} {
    color: {{ block.settings.title_hover_color }};
  }

  .ai-accordion-icon-{{ai_gen_id}} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    margin-left: 16px;
    transition: transform {{ block.settings.animation_duration }}s ease, color {{ block.settings.animation_duration }}s ease;
    color: {{ block.settings.icon_color }};
  }

  .ai-accordion-header-{{ai_gen_id}}:hover .ai-accordion-icon-{{ai_gen_id}} {
    color: {{ block.settings.icon_hover_color }};
  }

  .ai-accordion-item-{{ai_gen_id}}.active .ai-accordion-icon-{{ai_gen_id}} {
    transform: rotate(180deg);
  }

  .ai-accordion-content-wrapper-{{ai_gen_id}} {
    max-height: 0;
    overflow: hidden;
    transition: max-height {{ block.settings.animation_duration }}s {{ block.settings.animation_easing }};
  }

  .ai-accordion-content-{{ai_gen_id}} {
    padding: 0 {{ block.settings.item_padding_horizontal }}px {{ block.settings.content_padding_bottom }}px;
    background-color: {{ block.settings.content_bg_color }};
    font-family: {{ block.settings.content_font.family }}, {{ block.settings.content_font.fallback_families }};
    font-weight: {{ block.settings.content_font.weight }};
    font-style: {{ block.settings.content_font.style }};
    font-size: {{ block.settings.content_font_size }}px;
    color: {{ block.settings.content_color }};
    line-height: {{ block.settings.content_line_height }};
    letter-spacing: {{ block.settings.content_letter_spacing }}px;
    text-transform: {{ block.settings.content_text_transform }};
    border-top: {{ block.settings.content_border_thickness }}px {{ block.settings.content_border_style }} {{ block.settings.content_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-accordion-{{ai_gen_id}} {
      padding-left: {{ block.settings.section_padding_horizontal | times: 0.5 }}px;
      padding-right: {{ block.settings.section_padding_horizontal | times: 0.5 }}px;
    }

    .ai-accordion-title-{{ai_gen_id}} {
      font-size: {{ block.settings.title_font_size | times: 0.9 }}px;
    }

    .ai-accordion-content-{{ai_gen_id}} {
      font-size: {{ block.settings.content_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<accordion-block-{{ai_gen_id}} class="ai-accordion-{{ai_gen_id}}" {{ block.shopify_attributes }}>
  <div class="ai-accordion-container-{{ai_gen_id}}">
    {% for i in (1..20) %}
      {% assign title_key = 'item_' | append: i | append: '_title' %}
      {% assign content_key = 'item_' | append: i | append: '_content' %}
      {% assign title = block.settings[title_key] %}
      {% assign content = block.settings[content_key] %}
      
      {% if title != blank %}
        <div class="ai-accordion-item-{{ai_gen_id}}" data-index="{{ i }}">
          <button class="ai-accordion-header-{{ai_gen_id}}" aria-expanded="false">
            <h3 class="ai-accordion-title-{{ai_gen_id}}">{{ title }}</h3>
            <svg class="ai-accordion-icon-{{ai_gen_id}}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="ai-accordion-content-wrapper-{{ai_gen_id}}">
            <div class="ai-accordion-content-{{ai_gen_id}}">{{ content }}</div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</accordion-block-{{ai_gen_id}}>

<script>
  (function() {
    class AccordionBlock{{ai_gen_id}} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('.ai-accordion-item-{{ai_gen_id}}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.items.forEach((item) => {
          const header = item.querySelector('.ai-accordion-header-{{ai_gen_id}}');
          const contentWrapper = item.querySelector('.ai-accordion-content-wrapper-{{ai_gen_id}}');
          const content = item.querySelector('.ai-accordion-content-{{ai_gen_id}}');

          header.addEventListener('click', () => {
            const isActive = item.classList.contains('active');
            
            if (isActive) {
              item.classList.remove('active');
              header.setAttribute('aria-expanded', 'false');
              contentWrapper.style.maxHeight = '0';
            } else {
              item.classList.add('active');
              header.setAttribute('aria-expanded', 'true');
              contentWrapper.style.maxHeight = content.scrollHeight + 'px';
            }
          });
        });
      }
    }

    customElements.define('accordion-block-{{ai_gen_id}}', AccordionBlock{{ai_gen_id}});
  })();
</script>


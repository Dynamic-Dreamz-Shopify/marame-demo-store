{% doc %}
  @prompt
    Create a mobile-only announcement bar section that includes all standard announcement bar customization options (text messages, colors, fonts, spacing, rotation settings, link options) plus the ability to add an embedded Trustpilot widget as one of the message options. The section should only display on mobile devices and be hidden on desktop. Include settings for controlling the Trustpilot widget appearance and all the typical announcement bar controls like background color, text color, font size, autoplay rotation, rotation speed, and individual message management., I don't want a 'toggle' underneath, the content should just 'rotate' from the top. I should also be able to ammend the animation speed etc..., The animation swipes in from the right, can you please have it so it animates in from the top. But I would also like the option of change the animation type, Currently two messages are appearing at one, only one message / widget should appear at any one time, It's still showing two messages, it should only be one message in a thin bar, When you change a message to trustpilot widget, the widget embed code doesn't display the widget, perfect, can you just allow for faster animation
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-mobile-announcement-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    position: relative;
    min-height: 40px;
  }

  @media screen and (min-width: 768px) {
    .ai-mobile-announcement-{{ ai_gen_id }} {
      display: none;
    }
  }

  .ai-mobile-announcement__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .ai-mobile-announcement__slider-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ai-mobile-announcement__slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    opacity: 0;
    visibility: hidden;
    transition: opacity {{ block.settings.animation_speed }}s ease-in-out, transform {{ block.settings.animation_speed }}s ease-in-out;
  }

  .ai-mobile-announcement__slide-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    position: relative;
  }

  {% if block.settings.animation_type == 'slide_top' %}
    .ai-mobile-announcement__slide-{{ ai_gen_id }} {
      transform: translateY(-100%);
    }
    .ai-mobile-announcement__slide-{{ ai_gen_id }}.active {
      transform: translateY(0);
    }
  {% elsif block.settings.animation_type == 'slide_bottom' %}
    .ai-mobile-announcement__slide-{{ ai_gen_id }} {
      transform: translateY(100%);
    }
    .ai-mobile-announcement__slide-{{ ai_gen_id }}.active {
      transform: translateY(0);
    }
  {% elsif block.settings.animation_type == 'slide_left' %}
    .ai-mobile-announcement__slide-{{ ai_gen_id }} {
      transform: translateX(-100%);
    }
    .ai-mobile-announcement__slide-{{ ai_gen_id }}.active {
      transform: translateX(0);
    }
  {% elsif block.settings.animation_type == 'slide_right' %}
    .ai-mobile-announcement__slide-{{ ai_gen_id }} {
      transform: translateX(100%);
    }
    .ai-mobile-announcement__slide-{{ ai_gen_id }}.active {
      transform: translateX(0);
    }
  {% elsif block.settings.animation_type == 'fade' %}
    .ai-mobile-announcement__slide-{{ ai_gen_id }} {
      transform: none;
    }
  {% endif %}

  .ai-mobile-announcement__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    font-weight: {{ block.settings.font_family.weight }};
    line-height: 1.4;
    margin: 0;
  }

  .ai-mobile-announcement__text-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: {{ block.settings.link_style }};
  }

  .ai-mobile-announcement__text-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-mobile-announcement__trustpilot-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .ai-mobile-announcement__trustpilot-{{ ai_gen_id }} .trustpilot-widget {
    transform: scale({{ block.settings.trustpilot_scale }});
    transform-origin: center;
  }
{% endstyle %}

<mobile-announcement-{{ ai_gen_id }} class="ai-mobile-announcement-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-mobile-announcement__wrapper-{{ ai_gen_id }}">

<script>
  (function() {
    class MobileAnnouncement{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
        this.slider = this.querySelector('[data-slider]');
        this.slides = this.slider ? Array.from(this.querySelectorAll('[data-slide]')) : [];
        this.autoplayEnabled = {{ block.settings.enable_autoplay | json }};
        this.rotationSpeed = {{ block.settings.rotation_speed | times: 1000 }};
      }

      connectedCallback() {
        if (this.slides.length === 0) {
          return;
        }

        this.slides[0].classList.add('active');

        this.loadTrustpilot();

        if (this.slides.length > 1 && this.autoplayEnabled) {
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }

      loadTrustpilot() {
        if (window.Trustpilot && window.Trustpilot.loadFromElement) {
          const widgets = this.querySelectorAll('.trustpilot-widget');
          widgets.forEach(function(widget) {
            window.Trustpilot.loadFromElement(widget, true);
          });
        }
      }

      nextSlide() {
        this.slides[this.currentSlide].classList.remove('active');
        this.currentSlide = (this.currentSlide + 1) % this.slides.length;
        this.slides[this.currentSlide].classList.add('active');
        
        this.loadTrustpilot();
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(function() {
          this.nextSlide();
        }.bind(this), this.rotationSpeed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }
    }

    customElements.define('mobile-announcement-{{ ai_gen_id }}', MobileAnnouncement{{ ai_gen_id }});
  })();
</script>


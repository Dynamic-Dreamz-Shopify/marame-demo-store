      {% if block.settings.message_1_enabled %}
        <div class="ai-mobile-announcement__slide-{{ ai_gen_id }}" data-slide>
          {% if block.settings.message_1_type == 'text' %}
            <div class="ai-mobile-announcement__text-{{ ai_gen_id }}">
              {% if block.settings.message_1_link != blank %}
                <a href="{{ block.settings.message_1_link }}">{{ block.settings.message_1_text }}</a>
              {% else %}
                {{ block.settings.message_1_text }}

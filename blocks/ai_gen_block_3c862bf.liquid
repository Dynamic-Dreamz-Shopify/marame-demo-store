{% doc %}
  @prompt
    Create a simple video banner section with working video and height controls:
    - Two video file upload settings: "Desktop video" and "Mobile video"
    - Use Shopify's video_tag Liquid filter for proper video rendering
    - HTML5 video with attributes: autoplay muted loop playsinline
    - Height control setting with dropdown options: 100vh, 90vh, 85vh, 80vh, 75vh, 70vh, 60vh, 50vh
    - Separate height controls for desktop and mobile
    - CSS: width 100%, object-fit cover to maintain aspect ratio and fill the container
    - Media query at 768px to switch between desktop/mobile videos and heights
    - Simple, clean code focused on reliability
    - Background color fallback while video loads
    - Ensure video source URLs are properly referenced from Shopify file system
    - Container uses the selected vh value for height
    - Videos should fill the height container completely without distortion
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.mobile_height }};
    overflow: hidden;
    background-color: {{ block.settings.fallback_color }};
    display: block;
  }

  .ai-video-banner__video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-banner__desktop-{{ ai_gen_id }} {
    display: none;
  }

  .ai-video-banner__mobile-{{ ai_gen_id }} {
    display: block;
  }

  @media screen and (min-width: 768px) {
    .ai-video-banner-{{ ai_gen_id }} {
      height: {{ block.settings.desktop_height }};
    }

    .ai-video-banner__desktop-{{ ai_gen_id }} {
      display: block;
    }

    .ai-video-banner__mobile-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<video-banner-{{ ai_gen_id }} class="ai-video-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.desktop_video %}
    {% assign desktop_class = 'ai-video-banner__video-' | append: ai_gen_id | append: ' ai-video-banner__desktop-' | append: ai_gen_id %}
    {{ block.settings.desktop_video | video_tag: autoplay: true, loop: true, muted: true, class: desktop_class }}
  {% endif %}

  {% if block.settings.mobile_video %}
    {% assign mobile_class = 'ai-video-banner__video-' | append: ai_gen_id | append: ' ai-video-banner__mobile-' | append: ai_gen_id %}
    {{ block.settings.mobile_video | video_tag: autoplay: true, loop: true, muted: true, class: mobile_class }}
  {% endif %}
</video-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const videos = this.querySelectorAll('video');
        videos.forEach(video => {
          video.setAttribute('playsinline', '');
          video.play().catch(() => {});
        });
      }
    }

    customElements.define('video-banner-{{ ai_gen_id }}', VideoBanner{{ ai_gen_id }});
  })();
</script>


{% doc %}
  @prompt
    Create a fullscreen banner section with the following features:
    - Option to choose between image or video for the banner content
    - Separate upload fields for desktop version (image or video)
    - Separate upload fields for mobile version (image or video)
    - Toggle setting to switch between image mode and video mode
    - Responsive display that shows desktop media on larger screens and mobile media on smaller screens
    - Fullscreen/full-width layout similar to existing fullscreen banner sections
    - Video should have options for autoplay, loop, and mute button button or mute by default
    - Maintain aspect ratio and cover the banner area
    
    
    Add hover animation/action options
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-fullscreen-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    display: block;
  }

  .ai-fullscreen-banner-media-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform {{ block.settings.hover_animation_duration }}s ease;
  }

  {% if block.settings.hover_animation == 'zoom_in' %}
    .ai-fullscreen-banner-{{ ai_gen_id }}:hover .ai-fullscreen-banner-media-{{ ai_gen_id }} {
      transform: scale(1.1);
    }
  {% elsif block.settings.hover_animation == 'zoom_out' %}
    .ai-fullscreen-banner-media-{{ ai_gen_id }} {
      transform: scale(1.1);
    }
    .ai-fullscreen-banner-{{ ai_gen_id }}:hover .ai-fullscreen-banner-media-{{ ai_gen_id }} {
      transform: scale(1);
    }
  {% elsif block.settings.hover_animation == 'pan_right' %}
    .ai-fullscreen-banner-{{ ai_gen_id }}:hover .ai-fullscreen-banner-media-{{ ai_gen_id }} {
      transform: translateX(20px);
    }
  {% elsif block.settings.hover_animation == 'pan_left' %}
    .ai-fullscreen-banner-{{ ai_gen_id }}:hover .ai-fullscreen-banner-media-{{ ai_gen_id }} {
      transform: translateX(-20px);
    }
  {% endif %}

  .ai-fullscreen-banner-desktop-{{ ai_gen_id }} {
    display: block;
  }

  .ai-fullscreen-banner-mobile-{{ ai_gen_id }} {
    display: none;
  }

  .ai-fullscreen-banner-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .ai-fullscreen-banner-content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: {{ block.settings.text_color }};
    z-index: 2;
    width: 90%;
    max-width: 800px;
  }

  .ai-fullscreen-banner-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px;
    font-weight: 700;
  }

  .ai-fullscreen-banner-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 24px;
  }

  .ai-fullscreen-banner-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    transition: all 0.3s ease;
  }

  .ai-fullscreen-banner-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-fullscreen-banner-video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-fullscreen-banner-mute-button-{{ ai_gen_id }} {
    position: absolute;
    bottom: 24px;
    right: 24px;
    z-index: 3;
    background-color: rgba(0, 0, 0, 0.6);
    color: #ffffff;
    border: none;
    border-radius: 50%;
    width: 48px;
    height: 48px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }

  .ai-fullscreen-banner-mute-button-{{ ai_gen_id }}:hover {
    background-color: rgba(0, 0, 0, 0.8);
  }

  .ai-fullscreen-banner-mute-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
  }

  .ai-fullscreen-banner-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-fullscreen-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-fullscreen-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-fullscreen-banner-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-fullscreen-banner-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-fullscreen-banner-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-fullscreen-banner-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.7 }}px;
    }

    .ai-fullscreen-banner-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
      padding: 12px 24px;
    }

    .ai-fullscreen-banner-mute-button-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
      bottom: 16px;
      right: 16px;
    }

    .ai-fullscreen-banner-mute-icon-{{ ai_gen_id }} {
      width: 20px;
      height: 20px;
    }
  }
{% endstyle %}

<fullscreen-banner-{{ ai_gen_id }}
  class="ai-fullscreen-banner-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.media_type == 'image' %}
    {% if block.settings.desktop_image %}
      <img
        src="{{ block.settings.desktop_image | image_url: width: 2400 }}"
        alt="{{ block.settings.desktop_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.desktop_image.width }}"
        height="{{ block.settings.desktop_image.height }}"
        class="ai-fullscreen-banner-media-{{ ai_gen_id }} ai-fullscreen-banner-desktop-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-fullscreen-banner-placeholder-{{ ai_gen_id }} ai-fullscreen-banner-desktop-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-fullscreen-banner-empty-state-{{ ai_gen_id }}">
          Add a desktop image
        </div>
      </div>
    {% endif %}

    {% if block.settings.mobile_image %}
      <img
        src="{{ block.settings.mobile_image | image_url: width: 1200 }}"
        alt="{{ block.settings.mobile_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.mobile_image.width }}"
        height="{{ block.settings.mobile_image.height }}"
        class="ai-fullscreen-banner-media-{{ ai_gen_id }} ai-fullscreen-banner-mobile-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-fullscreen-banner-placeholder-{{ ai_gen_id }} ai-fullscreen-banner-mobile-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-fullscreen-banner-empty-state-{{ ai_gen_id }}">
          Add a mobile image
        </div>
      </div>
    {% endif %}
  {% else %}
    {% if block.settings.desktop_video %}
      <video
        class="ai-fullscreen-banner-video-{{ ai_gen_id }} ai-fullscreen-banner-desktop-{{ ai_gen_id }}"
        {% if block.settings.video_autoplay %}autoplay{% endif %}
        {% if block.settings.video_loop %}loop{% endif %}
        {% if block.settings.video_muted %}muted{% endif %}
        playsinline
        data-video-desktop
      >
        <source src="{{ block.settings.desktop_video }}" type="video/mp4">
      </video>
    {% else %}
      <div class="ai-fullscreen-banner-placeholder-{{ ai_gen_id }} ai-fullscreen-banner-desktop-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-fullscreen-banner-empty-state-{{ ai_gen_id }}">
          Add a desktop video
        </div>
      </div>
    {% endif %}

    {% if block.settings.mobile_video %}
      <video
        class="ai-fullscreen-banner-video-{{ ai_gen_id }} ai-fullscreen-banner-mobile-{{ ai_gen_id }}"
        {% if block.settings.video_autoplay %}autoplay{% endif %}
        {% if block.settings.video_loop %}loop{% endif %}
        {% if block.settings.video_muted %}muted{% endif %}
        playsinline
        data-video-mobile
      >
        <source src="{{ block.settings.mobile_video }}" type="video/mp4">
      </video>
    {% else %}
      <div class="ai-fullscreen-banner-placeholder-{{ ai_gen_id }} ai-fullscreen-banner-mobile-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-fullscreen-banner-empty-state-{{ ai_gen_id }}">
          Add a mobile video
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_mute_button and block.settings.media_type == 'video' %}
      <button
        class="ai-fullscreen-banner-mute-button-{{ ai_gen_id }}"
        aria-label="Toggle mute"
        data-mute-button
      >
        <svg
          class="ai-fullscreen-banner-mute-icon-{{ ai_gen_id }}"
          data-mute-icon
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
          <line x1="23" y1="9" x2="17" y2="15"></line>
          <line x1="17" y1="9" x2="23" y2="15"></line>
        </svg>
        <svg
          class="ai-fullscreen-banner-mute-icon-{{ ai_gen_id }}"
          data-unmute-icon
          style="display: none;"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>
        </svg>
      </button>
    {% endif %}
  {% endif %}

  {% if block.settings.show_overlay %}
    <div class="ai-fullscreen-banner-overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  {% if block.settings.show_content %}
    <div class="ai-fullscreen-banner-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h1 class="ai-fullscreen-banner-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <div class="ai-fullscreen-banner-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
      {% endif %}

      {% if block.settings.button_text != blank and block.settings.button_link != blank %}
        <a
          href="{{ block.settings.button_link }}"
          class="ai-fullscreen-banner-button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  {% endif %}
</fullscreen-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class FullscreenBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.muteButton = this.querySelector('[data-mute-button]');
        this.videos = this.querySelectorAll('video');
        this.muteIcon = this.querySelector('[data-mute-icon]');
        this.unmuteIcon = this.querySelector('[data-unmute-icon]');
      }

      connectedCallback() {
        if (this.muteButton && this.videos.length > 0) {
          this.setupMuteButton();
        }
      }

      setupMuteButton() {
        this.muteButton.addEventListener('click', () => {
          this.videos.forEach((video) => {
            video.muted = !video.muted;
          });

          if (this.videos[0].muted) {
            this.muteIcon.style.display = 'block';
            this.unmuteIcon.style.display = 'none';
          } else {
            this.muteIcon.style.display = 'none';
            this.unmuteIcon.style.display = 'block';
          }
        });
      }
    }

    customElements.define('fullscreen-banner-{{ ai_gen_id }}', FullscreenBanner{{ ai_gen_id }});
  })();
</script>


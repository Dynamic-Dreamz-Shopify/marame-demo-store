{% doc %}
  @prompt
    Create two custom footer sections for the homepage - one mobile-only and one desktop-only. Each footer should provide complete design flexibility including: alignment controls, padding/spacing options, multi-column layouts, typography settings (font family, weight, size, letter spacing, line height), link styling with hover states, smooth animations and transitions, color customization, and responsive visibility controls. The mobile footer should be hidden on desktop and vice versa. Include settings for social media links, newsletter signup, navigation menus, copyright text, and any other common footer elements with full visual customization., can you make the payment icons customisable, so I can add them, the same with the social media icons, I want to be able to add my own SVGS. I will need total design customisation of the menu items, inlcuding font, letter spacing etc..., I need to put the menu into two columns, I don't need the menu to split into two columns, I need the different menus to be across two columns (1 column each), I need two more menus each in their own column underneath those menus
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-mobile-footer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-mobile-footer-{{ ai_gen_id }} {
      display: none;
    }
  }

  .ai-mobile-footer__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.alignment }};
  }

  .ai-mobile-footer__section-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.section_spacing }}px;
  }

  .ai-mobile-footer__section-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-mobile-footer__menus-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.menu_grid_columns }}, 1fr);
    gap: {{ block.settings.menu_grid_gap }}px;
    margin-bottom: {{ block.settings.section_spacing }}px;
  }

  .ai-mobile-footer__menu-column-{{ ai_gen_id }} {
    text-align: {{ block.settings.alignment }};
  }

  .ai-mobile-footer__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
    line-height: {{ block.settings.heading_line_height }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px;
    text-transform: {{ block.settings.heading_transform }};
  }

  .ai-mobile-footer__text-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.body_size }}px;
    letter-spacing: {{ block.settings.body_letter_spacing }}px;
    line-height: {{ block.settings.body_line_height }};
    color: {{ block.settings.body_color }};
    margin: 0;
  }

  .ai-mobile-footer__nav-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.menu_link_spacing }}px;
  }

  .ai-mobile-footer__link-{{ ai_gen_id }} {
    font-family: {{ block.settings.menu_font.family }}, {{ block.settings.menu_font.fallback_families }};
    font-weight: {{ block.settings.menu_font.weight }};
    font-size: {{ block.settings.menu_size }}px;
    letter-spacing: {{ block.settings.menu_letter_spacing }}px;
    line-height: {{ block.settings.menu_line_height }};
    color: {{ block.settings.menu_color }};
    text-decoration: {{ block.settings.menu_decoration }};
    text-transform: {{ block.settings.menu_transform }};
    transition: color {{ block.settings.transition_speed }}ms ease, opacity {{ block.settings.transition_speed }}ms ease;
    display: inline-block;
  }

  .ai-mobile-footer__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.menu_hover_color }};
    opacity: {{ block.settings.menu_hover_opacity | divided_by: 100.0 }};
  }

  .ai-mobile-footer__social-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.social_spacing }}px;
    justify-content: {{ block.settings.alignment }};
    flex-wrap: wrap;
  }

  .ai-mobile-footer__social-link-{{ ai_gen_id }} {
    width: {{ block.settings.social_icon_size }}px;
    height: {{ block.settings.social_icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.social_bg_color }};
    border-radius: {{ block.settings.social_border_radius }}px;
    transition: background-color {{ block.settings.transition_speed }}ms ease, transform {{ block.settings.transition_speed }}ms ease;
  }

  .ai-mobile-footer__social-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.social_hover_bg_color }};
    transform: translateY(-{{ block.settings.social_hover_lift }}px);
  }

  .ai-mobile-footer__social-icon-{{ ai_gen_id }} {
    width: calc({{ block.settings.social_icon_size }}px * {{ block.settings.social_icon_scale | divided_by: 100.0 }});
    height: calc({{ block.settings.social_icon_size }}px * {{ block.settings.social_icon_scale | divided_by: 100.0 }});
    fill: {{ block.settings.social_icon_color }};
    transition: fill {{ block.settings.transition_speed }}ms ease;
  }

  .ai-mobile-footer__social-link-{{ ai_gen_id }}:hover .ai-mobile-footer__social-icon-{{ ai_gen_id }} {
    fill: {{ block.settings.social_hover_icon_color }};
  }

  .ai-mobile-footer__newsletter-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.newsletter_spacing }}px;
  }

  .ai-mobile-footer__input-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.input_size }}px;
    padding: {{ block.settings.input_padding }}px;
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_bg_color }};
    color: {{ block.settings.input_text_color }};
    width: 100%;
    transition: border-color {{ block.settings.transition_speed }}ms ease;
  }

  .ai-mobile-footer__input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border_color }};
  }

  .ai-mobile-footer__button-{{ ai_gen_id }} {
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-size: {{ block.settings.button_size }}px;
    letter-spacing: {{ block.settings.button_letter_spacing }}px;
    padding: {{ block.settings.button_padding }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    transition: background-color {{ block.settings.transition_speed }}ms ease, color {{ block.settings.transition_speed }}ms ease, transform {{ block.settings.transition_speed }}ms ease;
    width: 100%;
  }

  .ai-mobile-footer__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-{{ block.settings.button_hover_lift }}px);
  }

  .ai-mobile-footer__copyright-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.copyright_size }}px;
    color: {{ block.settings.copyright_color }};
    margin-top: {{ block.settings.copyright_margin_top }}px;
  }

  .ai-mobile-footer__payment-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.payment_spacing }}px;
    justify-content: {{ block.settings.alignment }};
    flex-wrap: wrap;
    margin-top: {{ block.settings.payment_margin_top }}px;
  }

  .ai-mobile-footer__payment-icon-{{ ai_gen_id }} {
    height: {{ block.settings.payment_icon_height }}px;
    width: auto;
    opacity: {{ block.settings.payment_opacity | divided_by: 100.0 }};
    transition: opacity {{ block.settings.transition_speed }}ms ease;
  }

  .ai-mobile-footer__payment-icon-{{ ai_gen_id }}:hover {
    opacity: 1;
  }
{% endstyle %}

<div class="ai-mobile-footer-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-mobile-footer__container-{{ ai_gen_id }}">
    {% if block.settings.show_newsletter %}
      <div class="ai-mobile-footer__section-{{ ai_gen_id }}">
        {% if block.settings.newsletter_heading != blank %}
          <h3 class="ai-mobile-footer__heading-{{ ai_gen_id }}">{{ block.settings.newsletter_heading }}</h3>
        {% endif %}
        {% if block.settings.newsletter_text != blank %}
          <div class="ai-mobile-footer__text-{{ ai_gen_id }}">{{ block.settings.newsletter_text }}</div>
        {% endif %}
        {% form 'customer', class: 'ai-mobile-footer__newsletter-' | append: ai_gen_id %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input
            type="email"
            name="contact[email]"
            class="ai-mobile-footer__input-{{ ai_gen_id }}"
            placeholder="{{ block.settings.newsletter_placeholder }}"
            aria-label="Email address"
            required
          >
          <button type="submit" class="ai-mobile-footer__button-{{ ai_gen_id }}">
            {{ block.settings.newsletter_button_text }}
          </button>
        {% endform %}
      </div>
    {% endif %}

    {% assign has_menus = false %}
    {% if block.settings.show_menu_1 and block.settings.menu_1 != blank %}
      {% assign has_menus = true %}
    {% endif %}
    {% if block.settings.show_menu_2 and block.settings.menu_2 != blank %}
      {% assign has_menus = true %}
    {% endif %}
    {% if block.settings.show_menu_3 and block.settings.menu_3 != blank %}
      {% assign has_menus = true %}
    {% endif %}
    {% if block.settings.show_menu_4 and block.settings.menu_4 != blank %}
      {% assign has_menus = true %}
    {% endif %}

    {% if has_menus %}
      <div class="ai-mobile-footer__menus-grid-{{ ai_gen_id }}">
        {% if block.settings.show_menu_1 and block.settings.menu_1 != blank %}
          <div class="ai-mobile-footer__menu-column-{{ ai_gen_id }}">
            {% if block.settings.menu_1_heading != blank %}
              <h3 class="ai-mobile-footer__heading-{{ ai_gen_id }}">{{ block.settings.menu_1_heading }}</h3>
            {% endif %}
            <ul class="ai-mobile-footer__nav-{{ ai_gen_id }}">
              {% for link in linklists[block.settings.menu_1].links %}
                <li>
                  <a href="{{ link.url }}" class="ai-mobile-footer__link-{{ ai_gen_id }}">
                    {{ link.title }}
                  </a>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}

        {% if block.settings.show_menu_2 and block.settings.menu_2 != blank %}
          <div class="ai-mobile-footer__menu-column-{{ ai_gen_id }}">
            {% if block.settings.menu_2_heading != blank %}
              <h3 class="ai-mobile-footer__heading-{{ ai_gen_id }}">{{ block.settings.menu_2_heading }}</h3>
            {% endif %}
            <ul class="ai-mobile-footer__nav-{{ ai_gen_id }}">
              {% for link in linklists[block.settings.menu_2].links %}
                <li>
                  <a href="{{ link.url }}" class="ai-mobile-footer__link-{{ ai_gen_id }}">
                    {{ link.title }}
                  </a>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}

        {% if block.settings.show_menu_3 and block.settings.menu_3 != blank %}
          <div class="ai-mobile-footer__menu-column-{{ ai_gen_id }}">
            {% if block.settings.menu_3_heading != blank %}
              <h3 class="ai-mobile-footer__heading-{{ ai_gen_id }}">{{ block.settings.menu_3_heading }}</h3>
            {% endif %}
            <ul class="ai-mobile-footer__nav-{{ ai_gen_id }}">
              {% for link in linklists[block.settings.menu_3].links %}
                <li>
                  <a href="{{ link.url }}" class="ai-mobile-footer__link-{{ ai_gen_id }}">
                    {{ link.title }}
                  </a>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}

        {% if block.settings.show_menu_4 and block.settings.menu_4 != blank %}
          <div class="ai-mobile-footer__menu-column-{{ ai_gen_id }}">
            {% if block.settings.menu_4_heading != blank %}
              <h3 class="ai-mobile-footer__heading-{{ ai_gen_id }}">{{ block.settings.menu_4_heading }}</h3>
            {% endif %}
            <ul class="ai-mobile-footer__nav-{{ ai_gen_id }}">
              {% for link in linklists[block.settings.menu_4].links %}
                <li>
                  <a href="{{ link.url }}" class="ai-mobile-footer__link-{{ ai_gen_id }}">
                    {{ link.title }}
                  </a>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.show_social %}
      <div class="ai-mobile-footer__section-{{ ai_gen_id }}">
        {% if block.settings.social_heading != blank %}
          <h3 class="ai-mobile-footer__heading-{{ ai_gen_id }}">{{ block.settings.social_heading }}</h3>
        {% endif %}
        <div class="ai-mobile-footer__social-{{ ai_gen_id }}">
          {% if block.settings.social_1_url != blank and block.settings.social_1_svg != blank %}
            <a href="{{ block.settings.social_1_url }}" class="ai-mobile-footer__social-link-{{ ai_gen_id }}" target="_blank" rel="noopener" aria-label="{{ block.settings.social_1_label }}">
              <div class="ai-mobile-footer__social-icon-{{ ai_gen_id }}">{{ block.settings.social_1_svg }}</div>
            </a>
          {% endif %}
          {% if block.settings.social_2_url != blank and block.settings.social_2_svg != blank %}
            <a href="{{ block.settings.social_2_url }}" class="ai-mobile-footer__social-link-{{ ai_gen_id }}" target="_blank" rel="noopener" aria-label="{{ block.settings.social_2_label }}">
              <div class="ai-mobile-footer__social-icon-{{ ai_gen_id }}">{{ block.settings.social_2_svg }}</div>
            </a>
          {% endif %}
          {% if block.settings.social_3_url != blank and block.settings.social_3_svg != blank %}
            <a href="{{ block.settings.social_3_url }}" class="ai-mobile-footer__social-link-{{ ai_gen_id }}" target="_blank" rel="noopener" aria-label="{{ block.settings.social_3_label }}">
              <div class="ai-mobile-footer__social-icon-{{ ai_gen_id }}">{{ block.settings.social_3_svg }}</div>
            </a>
          {% endif %}
          {% if block.settings.social_4_url != blank and block.settings.social_4_svg != blank %}
            <a href="{{ block.settings.social_4_url }}" class="ai-mobile-footer__social-link-{{ ai_gen_id }}" target="_blank" rel="noopener" aria-label="{{ block.settings.social_4_label }}">
              <div class="ai-mobile-footer__social-icon-{{ ai_gen_id }}">{{ block.settings.social_4_svg }}</div>
            </a>
          {% endif %}
          {% if block.settings.social_5_url != blank and block.settings.social_5_svg != blank %}
            <a href="{{ block.settings.social_5_url }}" class="ai-mobile-footer__social-link-{{ ai_gen_id }}" target="_blank" rel="noopener" aria-label="{{ block.settings.social_5_label }}">
              <div class="ai-mobile-footer__social-icon-{{ ai_gen_id }}">{{ block.settings.social_5_svg }}</div>
            </a>
          {% endif %}
          {% if block.settings.social_6_url != blank and block.settings.social_6_svg != blank %}
            <a href="{{ block.settings.social_6_url }}" class="ai-mobile-footer__social-link-{{ ai_gen_id }}" target="_blank" rel="noopener" aria-label="{{ block.settings.social_6_label }}">
              <div class="ai-mobile-footer__social-icon-{{ ai_gen_id }}">{{ block.settings.social_6_svg }}</div>
            </a>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_payment_icons %}
      <div class="ai-mobile-footer__payment-{{ ai_gen_id }}">
        {% if block.settings.payment_1_svg != blank %}
          <div class="ai-mobile-footer__payment-icon-{{ ai_gen_id }}">{{ block.settings.payment_1_svg }}</div>
        {% endif %}
        {% if block.settings.payment_2_svg != blank %}
          <div class="ai-mobile-footer__payment-icon-{{ ai_gen_id }}">{{ block.settings.payment_2_svg }}</div>
        {% endif %}
        {% if block.settings.payment_3_svg != blank %}
          <div class="ai-mobile-footer__payment-icon-{{ ai_gen_id }}">{{ block.settings.payment_3_svg }}</div>
        {% endif %}
        {% if block.settings.payment_4_svg != blank %}
          <div class="ai-mobile-footer__payment-icon-{{ ai_gen_id }}">{{ block.settings.payment_4_svg }}</div>
        {% endif %}
        {% if block.settings.payment_5_svg != blank %}
          <div class="ai-mobile-footer__payment-icon-{{ ai_gen_id }}">{{ block.settings.payment_5_svg }}</div>
        {% endif %}
        {% if block.settings.payment_6_svg != blank %}
          <div class="ai-mobile-footer__payment-icon-{{ ai_gen_id }}">{{ block.settings.payment_6_svg }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.show_copyright and block.settings.copyright_text != blank %}
      <div class="ai-mobile-footer__copyright-{{ ai_gen_id }}">
        {{ block.settings.copyright_text }}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Mobile footer",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "paragraph",
      "content": "This footer is visible only on mobile devices (screens under 750px wide)"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 500
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "section_spacing",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Section spacing",
      "default": 30
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Stay Connected"
    },
    {
      "type": "richtext",
      "id": "newsletter_text",
      "label": "Newsletter text",
      "default": "<p>Subscribe for exclusive offers</p>"
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email placeholder",
      "default": "Your email"
    },
    {
      "type": "text",
      "id": "newsletter_button_text",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "range",
      "id": "newsletter_spacing",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "label": "Newsletter spacing",
      "default": 15
    },
    {
      "type": "header",
      "content": "Menu 1"
    },
    {
      "type": "checkbox",
      "id": "show_menu_1",
      "label": "Show menu 1",
      "default": true
    },
    {
      "type": "text",
      "id": "menu_1_heading",
      "label": "Menu 1 heading",
      "default": "Quick Links"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Menu 1"
    },
    {
      "type": "header",
      "content": "Menu 2"
    },
    {
      "type": "checkbox",
      "id": "show_menu_2",
      "label": "Show menu 2",
      "default": true
    },
    {
      "type": "text",
      "id": "menu_2_heading",
      "label": "Menu 2 heading",
      "default": "Support"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Menu 2"
    },
    {
      "type": "header",
      "content": "Menu 3"
    },
    {
      "type": "checkbox",
      "id": "show_menu_3",
      "label": "Show menu 3",
      "default": true
    },
    {
      "type": "text",
      "id": "menu_3_heading",
      "label": "Menu 3 heading",
      "default": "Company"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "Menu 3"
    },
    {
      "type": "header",
      "content": "Menu 4"
    },
    {
      "type": "checkbox",
      "id": "show_menu_4",
      "label": "Show menu 4",
      "default": true
    },
    {
      "type": "text",
      "id": "menu_4_heading",
      "label": "Menu 4 heading",
      "default": "Legal"
    },
    {
      "type": "link_list",
      "id": "menu_4",
      "label": "Menu 4"
    },
    {
      "type": "header",
      "content": "Menu grid layout"
    },
    {
      "type": "range",
      "id": "menu_grid_columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Grid columns",
      "default": 2
    },
    {
      "type": "range",
      "id": "menu_grid_gap",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Grid gap",
      "default": 20
    },
    {
      "type": "header",
      "content": "Social media"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social media",
      "default": true
    },
    {
      "type": "text",
      "id": "social_heading",
      "label": "Social heading",
      "default": "Follow Us"
    },
    {
      "type": "paragraph",
      "content": "Add your custom social media icons below"
    },
    {
      "type": "text",
      "id": "social_1_label",
      "label": "Social 1 label"
    },
    {
      "type": "url",
      "id": "social_1_url",
      "label": "Social 1 URL"
    },
    {
      "type": "html",
      "id": "social_1_svg",
      "label": "Social 1 SVG code"
    },
    {
      "type": "text",
      "id": "social_2_label",

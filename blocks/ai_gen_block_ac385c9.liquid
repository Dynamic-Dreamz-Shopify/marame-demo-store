{% doc %}
  @prompt
    Create a desktop-only announcement bar section with a working Trustpilot widget integration.
    
    REQUIREMENTS:
    - Only visible on desktop and tablet, completely hidden on mobile
    - Left side: rotating text messages with customizable links, colors, font size, and rotation speed
    - Right side: static Trustpilot widget that stays visible while messages rotate
    - Trustpilot widget must actually render and display using the TrustBox embed code
    - Include the Trustpilot JavaScript library script tag in the section code to ensure widget loads
    - Widget should be properly aligned to the right with scale control
    - Fixed bar height to prevent size changes
    - Customizable background color, text color, font size
    - Adjustable padding and spacing
    - Auto-rotation with configurable speed for messages
    - Text alignment options for messages
    - Text transform options: uppercase, lowercase, sentence case, normal
    - Device visibility toggle setting
    
    CRITICAL: The Trustpilot widget must be fully functional with proper script loading and rendering, not just a placeholder setting., The trustpilot widget needs to be an embed code, The text needs to sit in the centre of the bar, Part of the trustpilot widget isn't appearing (this is in dark mode) to ensure it appears on the black, can you fix, The messages always need to sit central of the bar (irrelevant of the trustpilot widget) also, the widget still isn't appearing only the word 'Trustpilot' the actual content isn't appearing
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-announcement-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    height: {{ block.settings.bar_height }}px;
    overflow: hidden;
    position: relative;
  }

  .ai-announcement-bar__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    height: 100%;
    padding: 0 {{ block.settings.horizontal_padding }}px;
    gap: {{ block.settings.spacing }}px;
  }

  .ai-announcement-bar__messages-{{ ai_gen_id }} {
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
  }

  .ai-announcement-bar__message-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s ease, visibility 0.5s ease;
    text-align: center;
    text-transform: {{ block.settings.text_transform }};
    font-size: {{ block.settings.font_size }}px;
    line-height: 1.4;
    padding: 0 20px;
  }

  .ai-announcement-bar__message-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
  }

  .ai-announcement-bar__message-inner-{{ ai_gen_id }} {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ai-announcement-bar__message-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
  }

  .ai-announcement-bar__message-{{ ai_gen_id }} a:hover {
    text-decoration: underline;
  }

  .ai-announcement-bar__trustpilot-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    height: 100%;
    transform: scale({{ block.settings.trustpilot_scale }});
    transform-origin: center right;
  }

  @media screen and (max-width: 749px) {
    {% if block.settings.hide_on_mobile %}
      .ai-announcement-bar-{{ ai_gen_id }} {
        display: none;
      }
    {% endif %}
  }
{% endstyle %}

<announcement-bar-{{ ai_gen_id }}
  class="ai-announcement-bar-{{ ai_gen_id }}"
  data-rotation-speed="{{ block.settings.rotation_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-announcement-bar__container-{{ ai_gen_id }}">
    <div class="ai-announcement-bar__messages-{{ ai_gen_id }}">
      {% if block.settings.message_1 != blank %}
        <div class="ai-announcement-bar__message-{{ ai_gen_id }} active" data-message-index="0">
          <div class="ai-announcement-bar__message-inner-{{ ai_gen_id }}">
            {% if block.settings.message_1_link != blank %}
              <a href="{{ block.settings.message_1_link }}">{{ block.settings.message_1 }}</a>
            {% else %}
              {{ block.settings.message_1 }}
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% if block.settings.message_2 != blank %}
        <div class="ai-announcement-bar__message-{{ ai_gen_id }}" data-message-index="1">
          <div class="ai-announcement-bar__message-inner-{{ ai_gen_id }}">
            {% if block.settings.message_2_link != blank %}
              <a href="{{ block.settings.message_2_link }}">{{ block.settings.message_2 }}</a>
            {% else %}
              {{ block.settings.message_2 }}
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% if block.settings.message_3 != blank %}
        <div class="ai-announcement-bar__message-{{ ai_gen_id }}" data-message-index="2">
          <div class="ai-announcement-bar__message-inner-{{ ai_gen_id }}">
            {% if block.settings.message_3_link != blank %}
              <a href="{{ block.settings.message_3_link }}">{{ block.settings.message_3 }}</a>
            {% else %}
              {{ block.settings.message_3 }}
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% if block.settings.message_4 != blank %}
        <div class="ai-announcement-bar__message-{{ ai_gen_id }}" data-message-index="3">
          <div class="ai-announcement-bar__message-inner-{{ ai_gen_id }}">
            {% if block.settings.message_4_link != blank %}
              <a href="{{ block.settings.message_4_link }}">{{ block.settings.message_4 }}</a>
            {% else %}
              {{ block.settings.message_4 }}
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% if block.settings.message_5 != blank %}
        <div class="ai-announcement-bar__message-{{ ai_gen_id }}" data-message-index="4">
          <div class="ai-announcement-bar__message-inner-{{ ai_gen_id }}">
            {% if block.settings.message_5_link != blank %}
              <a href="{{ block.settings.message_5_link }}">{{ block.settings.message_5 }}</a>
            {% else %}
              {{ block.settings.message_5 }}
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>

    {% if block.settings.trustpilot_embed != blank %}
      <div class="ai-announcement-bar__trustpilot-{{ ai_gen_id }}">
        {{ block.settings.trustpilot_embed }}
      </div>
    {% endif %}
  </div>
</announcement-bar-{{ ai_gen_id }}>

<script src="https://widget.trustpilot.com/bootstrap/v5/tp.widget.bootstrap.min.js" async></script>

<script>
  (function() {
    class AnnouncementBar{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.messages = [];
        this.rotationInterval = null;
      }

      connectedCallback() {
        this.messages = Array.from(this.querySelectorAll('.ai-announcement-bar__message-{{ ai_gen_id }}'));
        
        if (this.messages.length > 1) {
          const rotationSpeed = parseInt(this.dataset.rotationSpeed) * 1000;
          this.startRotation(rotationSpeed);
        }
      }

      startRotation(speed) {
        this.rotationInterval = setInterval(() => {
          this.rotateMessages();
        }, speed);
      }

      rotateMessages() {
        this.messages[this.currentIndex].classList.remove('active');
        
        this.currentIndex = (this.currentIndex + 1) % this.messages.length;
        
        this.messages[this.currentIndex].classList.add('active');
      }

      disconnectedCallback() {
        if (this.rotationInterval) {
          clearInterval(this.rotationInterval);
        }
      }
    }

    customElements.define('announcement-bar-{{ ai_gen_id }}', AnnouncementBar{{ ai_gen_id }});
  })();
</script>


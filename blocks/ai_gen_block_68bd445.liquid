{% doc %}
  @prompt
    Create a mobile-only announcement bar with rotating messages and Trustpilot widget integration.
    
    CRITICAL REQUIREMENTS:
    - Mobile devices only (hidden on desktop and tablet with CSS media queries)
    - ALL messages must rotate properly with no stopping after first two items
    - Text must be perfectly centered vertically within the bar
    - Fixed minimum height to prevent size changes during rotation
    - Trustpilot widget must actually render and display
    
    ROTATION FUNCTIONALITY:
    - Multiple rotating text messages with customizable links
    - Auto-rotation that cycles through ALL messages continuously
    - Configurable rotation speed with minimal delay between transitions
    - Must not stop after first two items - continuous rotation required
    
    TEXT FEATURES:
    - Perfect vertical centering within the bar
    - Text transform options: uppercase, lowercase, sentence case, normal
    - Customizable font size and text color
    - Horizontal text alignment options
    
    TRUSTPILOT WIDGET:
    - Option to add Trustpilot widget as one of the rotating message types
    - Must include Trustpilot JavaScript library in section code
    - Embed code field that accepts full HTML including script tags (do NOT sanitize)
    - Scale/size control for widget
    - Proper vertical alignment with text messages
    - Widget must actually render and display
    
    STYLING CONTROLS:
    - Background color
    - Text color
    - Vertical and horizontal padding
    - Fixed bar height setting
    - Device visibility toggle
    
    CRITICAL: Ensure rotation works for ALL messages, text is vertically centered, and Trustpilot widget renders properly with script loading.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-mobile-announcement-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;
    min-height: {{ block.settings.bar_height }}px;
    overflow: hidden;
    position: relative;
  }

  .ai-mobile-announcement-container-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: {{ block.settings.bar_height }}px;
    display: flex;
    align-items: center;
    justify-content: {{ block.settings.text_alignment }};
    position: relative;
  }

  .ai-mobile-announcement-message-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s ease, visibility 0.5s ease;
    display: flex;
    align-items: center;
    justify-content: {{ block.settings.text_alignment }};
    width: 100%;
    min-height: {{ block.settings.bar_height }}px;
  }

  .ai-mobile-announcement-message-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  .ai-mobile-announcement-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    text-align: {{ block.settings.text_alignment }};
    text-transform: {{ block.settings.text_transform }};
    text-decoration: none;
    display: block;
    width: 100%;
    line-height: 1.4;
  }

  .ai-mobile-announcement-text-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-mobile-announcement-widget-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: {{ block.settings.text_alignment }};
    width: 100%;
    transform: scale({{ block.settings.widget_scale }});
    transform-origin: {{ block.settings.text_alignment }};
  }

  @media screen and (min-width: 768px) {
    .ai-mobile-announcement-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<mobile-announcement-{{ ai_gen_id }}
  class="ai-mobile-announcement-{{ ai_gen_id }}"
  data-rotation-speed="{{ block.settings.rotation_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-mobile-announcement-container-{{ ai_gen_id }}">
    {% if block.settings.message_1 != blank %}
      <div class="ai-mobile-announcement-message-{{ ai_gen_id }}" data-message-index="0">
        {% if block.settings.message_1_link != blank %}
          <a href="{{ block.settings.message_1_link }}" class="ai-mobile-announcement-text-{{ ai_gen_id }}">
            {{ block.settings.message_1 }}
          </a>
        {% else %}
          <span class="ai-mobile-announcement-text-{{ ai_gen_id }}">
            {{ block.settings.message_1 }}
          </span>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.message_2 != blank %}
      <div class="ai-mobile-announcement-message-{{ ai_gen_id }}" data-message-index="1">
        {% if block.settings.message_2_link != blank %}
          <a href="{{ block.settings.message_2_link }}" class="ai-mobile-announcement-text-{{ ai_gen_id }}">
            {{ block.settings.message_2 }}
          </a>
        {% else %}
          <span class="ai-mobile-announcement-text-{{ ai_gen_id }}">
            {{ block.settings.message_2 }}
          </span>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.message_3 != blank %}
      <div class="ai-mobile-announcement-message-{{ ai_gen_id }}" data-message-index="2">
        {% if block.settings.message_3_link != blank %}
          <a href="{{ block.settings.message_3_link }}" class="ai-mobile-announcement-text-{{ ai_gen_id }}">
            {{ block.settings.message_3 }}
          </a>
        {% else %}
          <span class="ai-mobile-announcement-text-{{ ai_gen_id }}">
            {{ block.settings.message_3 }}
          </span>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.message_4 != blank %}
      <div class="ai-mobile-announcement-message-{{ ai_gen_id }}" data-message-index="3">
        {% if block.settings.message_4_link != blank %}
          <a href="{{ block.settings.message_4_link }}" class="ai-mobile-announcement-text-{{ ai_gen_id }}">
            {{ block.settings.message_4 }}
          </a>
        {% else %}
          <span class="ai-mobile-announcement-text-{{ ai_gen_id }}">
            {{ block.settings.message_4 }}
          </span>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.message_5 != blank %}
      <div class="ai-mobile-announcement-message-{{ ai_gen_id }}" data-message-index="4">
        {% if block.settings.message_5_link != blank %}
          <a href="{{ block.settings.message_5_link }}" class="ai-mobile-announcement-text-{{ ai_gen_id }}">
            {{ block.settings.message_5 }}
          </a>
        {% else %}
          <span class="ai-mobile-announcement-text-{{ ai_gen_id }}">
            {{ block.settings.message_5 }}
          </span>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.enable_trustpilot and block.settings.trustpilot_embed != blank %}
      <div class="ai-mobile-announcement-message-{{ ai_gen_id }}" data-message-index="5">
        <div class="ai-mobile-announcement-widget-{{ ai_gen_id }}">
          {{ block.settings.trustpilot_embed }}
        </div>
      </div>
    {% endif %}
  </div>
</mobile-announcement-{{ ai_gen_id }}>

{% if block.settings.enable_trustpilot %}
  <script type="text/javascript" src="//widget.trustpilot.com/bootstrap/v5/tp.widget.bootstrap.min.js" async></script>
{% endif %}

<script>
  (function() {
    class MobileAnnouncement{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.messages = [];
        this.currentIndex = 0;
        this.rotationInterval = null;
      }

      connectedCallback() {
        this.messages = Array.from(this.querySelectorAll('.ai-mobile-announcement-message-{{ ai_gen_id }}'));
        
        if (this.messages.length === 0) return;

        this.rotationSpeed = parseInt(this.dataset.rotationSpeed) * 1000 || 3000;

        this.showMessage(0);

        if (this.messages.length > 1) {
          this.startRotation();
        }
      }

      showMessage(index) {
        this.messages.forEach((message, i) => {
          if (i === index) {
            message.classList.add('active');
          } else {
            message.classList.remove('active');
          }
        });
        this.currentIndex = index;
      }

      startRotation() {
        this.rotationInterval = setInterval(() => {
          const nextIndex = (this.currentIndex + 1) % this.messages.length;
          this.showMessage(nextIndex);
        }, this.rotationSpeed);
      }

      disconnectedCallback() {
        if (this.rotationInterval) {
          clearInterval(this.rotationInterval);
        }
      }
    }

    customElements.define('mobile-announcement-{{ ai_gen_id }}', MobileAnnouncement{{ ai_gen_id }});
  })();
</script>


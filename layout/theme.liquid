              <line x1="0.646447" y1="14.0815" x2="14.0815" y2="0.646477" stroke="#FFFFFF" />
              <line y1="-0.5" x2="19" y2="-0.5" transform="matrix(-0.707107 -0.707107 -0.707107 0.707107 14.4355 14.4351)" stroke="#FFFFFF" />
          </svg>

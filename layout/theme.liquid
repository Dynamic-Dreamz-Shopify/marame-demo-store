    {%- if settings.predictive_search_enabled -%}
      <script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {% render 'klaviyo' %}
    {%- render 'collection-klaviyo-notifyme' -%}
    {%- render 'pdp-coming-soon' -%}
    <script>
      document.addEventListener('DOMContentLoaded', function() {

        function formatGBP(pence) {
          return '£' + (pence / 100).toFixed(2);
        }

        function klarnaCalc(totalPence) {
          const base = Math.floor(totalPence / 3);
          const remainder = totalPence % 3;

          return remainder === 0
            ? `Klarna: 3 interest-free payments of ${formatGBP(base)}`
            : `Klarna: 3 interest-free payments from ${formatGBP(base)}`;
        }

        function clearpayCalc(totalPence) {
          const base = Math.floor(totalPence / 4);
          const remainder = totalPence % 4;

          return remainder === 0
            ? `Clearpay: 4 interest-free payments of ${formatGBP(base)}`
            : `Clearpay: 4 interest-free payments from ${formatGBP(base)}`;
        }

        function updateFinance(pricePence) {
          const klarnaEl = document.querySelector('.klarna-message');
          const clearpayEl = document.querySelector('.clearpay-message');

          if (klarnaEl) klarnaEl.textContent = klarnaCalc(pricePence);
          if (clearpayEl) clearpayEl.textContent = clearpayCalc(pricePence);
        }

        // Shopify price already in pence
        if (window.currentVariantPrice) {
          updateFinance(window.currentVariantPrice);
        }

        // Dawn variant change
        document.addEventListener('variant:change', function(e) {
          if (e.detail && e.detail.variant) {
            updateFinance(e.detail.variant.price);
          }
        });
      });
    </script>
  </body>
</html>

  "tag": "section",
  "class": "section-marame-home-categories",
  "enabled_on": { "templates": ["index"] },
  "settings": [
    {
      "type": "paragraph",
      "content": "Crop sliders are directly under each tile’s images (sections titled “Menswear — image crop” and “Womenswear — image crop”). Confirm you are editing draft theme #195956212047, not the live theme."
    },
    {
      "type": "header",
      "content": "Menswear"
    },
    {
      "type": "image_picker",
      "id": "menswear_image_mobile",
      "label": "Image — mobile"
    },
    {
      "type": "image_picker",
      "id": "menswear_image_desktop",
      "label": "Image — desktop"
    },
    {
      "type": "header",
      "content": "Menswear — image crop"
    },
    {
      "type": "checkbox",
      "id": "menswear_use_manual_focal",
      "label": "Manual crop position (sliders)",
      "info": "Off = use focal point from the image picker above.",
      "default": true
    },
    {
      "type": "range",
      "id": "menswear_focal_x_mobile",
      "label": "Horizontal focus — mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "menswear_focal_y_mobile",
      "label": "Vertical focus — mobile",
      "info": "Lower % shows more of the top of the image.",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "menswear_focal_x_desktop",
      "label": "Horizontal focus — desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50

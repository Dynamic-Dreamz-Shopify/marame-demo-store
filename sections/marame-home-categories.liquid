    {
      "type": "range",
      "id": "menswear_label_size_desktop",
      "label": "Label size — desktop",
      "min": 14,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "menswear_label_spacing_mobile",

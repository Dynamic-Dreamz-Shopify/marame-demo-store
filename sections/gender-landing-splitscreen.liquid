<section class="splitscreen splitscreen--gutter">
  {% for block in section.blocks %}
    {% if block.settings.image != blank %}
      <div class="splitscreen__item">
        <a href="{{ block.settings.button_link | default: 'javascript:void(0)' }}" class="splitscreen__item__bg">
          <img
            src="{{ block.settings.image | img_url: "master" }}"
            alt="{{ block.settings.image.alt }}"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            loading="eager" fetchpriority="high"
            data-p-speed="0.15"
          >
          <span class="sr-only">
            {{ block.settings.button_label }}
            </span>
        </a>
        <div class="splitscreen__item__content">
          {% if block.settings.heading != blank %}
            <h2>{{ block.settings.heading }}</h2>
          {% endif %}
          {% if block.settings.button_label != blank %}
            <div class="splitscreen__item__content__ctas">
              <a href="{{ block.settings.button_link | default: 'javascript:void(0)' }}" class="btn btn--underline">
                <h4>{{ block.settings.button_label }}</h4>
              </a>
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  {% endfor %}
</section>

{% schema %}
{
  "name": "Gender landing split",
  "class": "gender-landing-splitscreen",
  "settings": [],
  "blocks": [
    {
      "type": "block",
      "name": "Block",
      "limit": 2,
      "settings": [
        {
          "type": "image_picker",
          "label": "Image",
          "id": "image"
        },
        {
          "type": "inline_richtext",
          "label": "Heading",
          "id": "heading"
        },
        {
          "type": "text",
          "label": "Button label",
          "id": "button_label"
        },
        {
          "type": "url",
          "label": "Button link",
          "id": "button_link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gender landing splitscreen"
    }
  ]
}
{% endschema %}

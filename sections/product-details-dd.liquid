{{ 'size-guide.css' | asset_url | stylesheet_tag }}
{{ 'size-chart-popup.css' | asset_url | stylesheet_tag }}
{% comment %} <script src="{{ 'size-guide-finder-engine-v3.js' | asset_url }}" defer></script>
<script src="{{ 'size-guide-finder.js' | asset_url }}" defer></script>
<script src="{{ 'size-guide.js' | asset_url }}" defer></script> {% endcomment %}

{% assign dd_template_name = product.template_suffix | split: '-' | first %}

{%- assign product_form_id = 'product-form-' | append: section.id -%}
{% assign preorder_enabled_raw = product.selected_or_first_available_variant.metafields.custom.preorder_enabled.value | default: product.selected_or_first_available_variant.metafields.custom.preorder_enabled %}

{% assign preorder_enabled = false %}

{% if preorder_enabled_raw == true or preorder_enabled_raw == 'true' or preorder_enabled_raw == 'True' %}
  {% assign preorder_enabled = true %}
{% endif %}
<script src="{{ "product-form.js" | asset_url }}" defer></script>

{% capture swiper-button-prev %}
    <svg xmlns="http://www.w3.org/2000/svg" width="9" height="19" viewBox="0 0 9 19" fill="none">
      <path d="M8.409 1 .999 9.335l7.41 8.335" stroke="#8E8E8E" stroke-width="1.389"/>
    </svg>
{% endcapture %}

{% capture swiper-button-next %}
  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="19" viewBox="0 0 10 19" fill="none">
    <path d="m1.12 17.939 7.408-8.336L1.12 1.268" stroke="#8E8E8E" stroke-width="1.389"/>
  </svg>
{% endcapture %}

{% assign show_model_selector_raw = product.metafields.custom.show_model_selector.value | default: product.metafields.custom.show_model_selector %}

{% assign show_model_selector = false %}

{% if show_model_selector_raw == true or show_model_selector_raw == 'true' or show_model_selector_raw == 'True' %}
  {% assign show_model_selector = true %}
{% endif %}

<section
  id="shopify-section-{{ section.id }}"
  class="detail pdp-hero-section {% if dd_template_name == 'dd_swatch' %} product-fragrances-div default_product_template {% endif %}{% if product.template_suffix == 'variant-selector' %} default_product_template {% endif %} {% if template == 'product' and product.gift_card? == false %} default_product_template {% endif %}{% if product.template_suffix == 'fragrances' %} product-fragrances-div default_product_template{% endif %}{% if product.gift_card? %} details-gift-card default_product_template{% endif %}"
>
  <div class="detail__breadcrumb ">
    <a href="{{ product.collections[0].url }}">
      <h6>{{ product.collections[0].title }}</h6>
    </a>
    <h6>/</h6>
    <a href="{{ product.url }}">
      <h6>{{ product.title }}</h6>
    </a>
  </div>

  <div class="row">
    {% render 'product-media-slider', product: product , swiper-button-prev:swiper-button-prev , swiper-button-next: swiper-button-next %}

    {% assign color_active = false %}
    {% assign option_color = 'color' %}

    {%- unless product.has_only_default_variant -%}
      {%- for option in product.options_with_values -%}
        {% assign option_name = option.name | downcase %}

        {% if option_name == option_color %}
          {%- for value in option.values -%}
            {% assign color_active = true %}
            {% assign color_name = value %}
            {% if forloop.first %}
              {% break %}
            {% endif %}
          {%- endfor -%}
        {% endif %}
      {%- endfor -%}
    {%- endunless -%}

    <div class="detail__sidebar col--6 col--md--4 col--lg--6">
      <div class="detail__sidebar__content  dddd" data-handle="{{ product.handle }}">
        <div class="detail__sidebar__intro {% if dd_template_name == 'dd_swatch' %} product_default {% endif %} {% if template == 'product' and product.gift_card? == false %} product_default {% endif %} {% if product.template_suffix == 'variant-selector' %} product_default {% endif %}">
          <h1 class="h4">{{ product.title }}</h1>
          <h3 class="vari_price">{{ product.selected_or_first_available_variant.title }}</h3>

          {% if template contains 'fragrances' %}
            <div class="detail__sidebar__colors__price">
              {% if product.selected_or_first_available_variant.compare_at_price != 0 %}
                <h5 class="h4 compare_at_price">
                  {{ product.selected_or_first_available_variant.compare_at_price | money_without_trailing_zeros }}
                </h5>
              {% endif %}
              <h4 class="vari_price">
                {{ product.selected_or_first_available_variant.price | money_without_trailing_zeros }}
              </h4>
            </div>
          {% endif %}

          {% if color_active %}
            <h2 class="p">IN {{ color_name }}</h2>
          {% endif %}
        </div>

        {% if template == 'product' and product.gift_card? == false %}
          <div class="detail__sidebar__intro">
            <div class="default-prodcut_page">
              <div class="pdp-title-wrap">
                <h2 class="h4">{{ product.title }}</h2>
                
                {% if color_active %}
                  <h2 class="p pdp-color-name-text desktop-hide">IN {{ color_name }}</h2>
                {% endif %}
              </div>
              <div class="pdp-title-price-row">
                <div class="detail__sidebar__colors__price">
                  {% if product.selected_or_first_available_variant.compare_at_price != 0 %}
                    <h5 class="h4 compare_at_price">
                      {{ product.selected_or_first_available_variant.compare_at_price | money_without_trailing_zeros }}
                    </h5>
                  {% endif %}
                  <h4 class="vari_price">
                    {{ product.selected_or_first_available_variant.price | money_without_trailing_zeros }}
                  </h4>
                </div>
                {% render 'size-guide-trigger', product: product, section: section %}
              </div>
            </div>

            {% if color_active %}
              <h2 class="p pdp-color-name-text mobile-hide">IN {{ color_name }}</h2>
            {% endif %}
          </div>
        {% elsif product.template_suffix == 'variant-selector' or dd_template_name == 'dd_swatch' %}
          {% unless product.gift_card? %}
            <div class="detail__sidebar__intro">
              <div class="default-prodcut_page">
                <div class="pdp-title-wrap">
                  <h2 class="h4">{{ product.title }}</h2>
                  {% if color_active %}
                    <h2 class="p pdp-color-name-text desktop-hide">IN {{ color_name }}</h2>
                  {% endif %}
                </div>
                  <div class="pdp-title-price-row">
                    <div class="detail__sidebar__colors__price 121212">
                      {% if product.selected_or_first_available_variant.compare_at_price > 0 %}
                        <h5 class="h4 compare_at_price">
                          {{ product.selected_or_first_available_variant.compare_at_price | money_without_trailing_zeros }}
                        </h5>
                      {% endif %}
                      <h4 class="vari_price">
                        {{ product.selected_or_first_available_variant.price | money_without_trailing_zeros }}
                      </h4>
                    </div>
                    {% render 'size-guide-trigger', product: product, section: section %}
                  </div>

                {% comment %} <div class="detail__sidebar__colors__price 121212">
                  {% if product.selected_or_first_available_variant.compare_at_price > 0 %}
                    <h5 class="h4 compare_at_price">
                      {{ product.selected_or_first_available_variant.compare_at_price | money_without_currency -}}
                      &nbsp;{{- shop.currency }}
                    </h5>
                  {% endif %}
                  <h4 class="vari_price">
                    {{ product.selected_or_first_available_variant.price | money_without_trailing_zeros -}}
                    &nbsp;{{- shop.currency }}
                  </h4>
                </div> {% endcomment %}
              </div>

              <div class="detail-iWishAddColl-share">
                <button class="product-share-btn" onclick="shareProduct()">
                  <svg width="18" height="15" viewBox="0 0 18 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M0.399902 8.79688V14.1426H16.6939V8.79688" stroke="#2A2A2C" stroke-width="0.8"/>
                    <path d="M8.37798 12.5352V0.400391L3.37256 5.74629" stroke="#2A2A2C" stroke-width="0.8" stroke-linejoin="round"/>
                    <path d="M8.37793 0.400391L13.3857 5.49219" stroke="#2A2A2C" stroke-width="0.8"/>
                  </svg>
                </button>
              </div>

              {% if color_active %}
                <h2 class="p pdp-color-name-text mobile-hide">IN {{ color_name }}</h2>
              {% endif %}
            </div>
          {% endunless %}
        {% endif %}

        <hr>
        {% if product.template_suffix == 'variant-selector' or dd_template_name == 'dd_swatch' %}
          {% unless product.has_only_default_variant %}
            {% comment %} {% render 'variant-picker', product: product, section_id: section.id %} {% endcomment %}
            {% render 'variant-picker-new', product: product, section_id: section.id %}
          {% endunless %}

          {% assign only_size_option = false %}
          
          {% for option in product.options %}
          {% assign option_name = option | downcase %}
          {% if option_name contains 'size' %}
          {% assign only_size_option = true %}
          {% break %}
          {% endif %}
          {% endfor %}

          <div class="custom_btns_atc{% if only_size_option %} hidden{% endif %}">
            <span class="oos_msg">We are sorry, this product is currently out of stock.</span>
            {% render 'product-atc-form', product: product, product_form_id: product_form_id %}
            {% comment %} <div class="buy_with_applepay">Buy now with</div> {% endcomment %}
          </div>

          <div class="free-exchange-bar">
            <div class="free-exchange-track">

              <div class="free-exchange-bar__inner">
                <div class="free-exchange-bar__icon">
                  {{ section.settings.free_exchange_svg }}
                </div>
                <div class="free-exchange-bar__text">
                  {{ section.settings.free_exchange_text }}
                </div>
              </div>

              <div class="free-exchange-bar__inner free_next_day">
                <div class="free-exchange-bar__icon">
                  {{ section.settings.free_next_day_svg }}
                </div>
                <div class="free-exchange-bar__text">
                  {{ section.settings.shipping_text }}
                </div>
              </div>

              <div class="free-exchange-bar__inner elarna_finance">
                <div class="free-exchange-bar__icon">
                  {{ section.settings.elarna_finance_svg }}
                </div>
                <div class="free-exchange-bar__text klarna-message">
                  {{ section.settings.elarna_finance_text }}
                </div>
              </div>
              
              <div class="free-exchange-bar__inner clearpay_finance">
                <div class="free-exchange-bar__icon">
                </div>
                <div class="free-exchange-bar__text klarna-message clearpay-message">
                </div>
              </div>
              
              <div class="free-exchange-bar__inner trustpilot">
                <div class="free-exchange-bar__icon">
                </div>
                <div class="custom-trustpilot-widget">
                  <a href="https://www.trustpilot.com/review/marame.com" target="_blank">
                    Rated 5 stars on 
                    <img src="https://cdn.shopify.com/s/files/1/0934/8877/5503/files/2b5e61bdeb21049855ef9b87ca60e716de9761b7.png?v=1773225122">
                  </a>
                </div>
              </div>
              <script>
                window.currentVariantPrice = {{ product.selected_or_first_available_variant.price }};
              </script>
            </div>
          </div>

          <div class="accordion_with_atc_buttons ddddd">
            {% if section.settings.shipping_text != blank %}
              <div class="pro_shipping-payment_text">
                <div class="pro-shipping_text">{{ section.settings.shipping_text }}</div>
                <div class="pro-payments_wrapper">
                  <div class="pro-payments_item pro-payments_klarna">
                     3 payments of £{{ product.price | divided_by: 3 | round | divided_by: 100.0 }} at 0% interest with 
                    <span>{% render 'icon-klarna' %}</span>
                  </div>
                  <div class="pro-payments_item pro-payments_clearpay">
                    or 4 payments of £{{ product.price | divided_by: 4 | round | divided_by: 100.0 }} with
                    <span>{% render 'icon-clearpay' %}</span>
                  </div>
                </div>
              </div>
            {% endif %}
            {% render 'new-product-tabs' %}
            {% comment %} {% render 'product-tabs' %} {% endcomment %}

            {% if section.settings.show_video %}
              {% assign video_file = product.selected_or_first_available_variant.metafields.custom.product_video %}
              {% if video_file != blank %}
                <div class="custom-variant-video desktop-hide" data-custom-video>
                  <video 
                    playsinline 
                    preload="metadata"
                    style="width:100%; height:auto;"
                  >
                    <source src="{{ video_file | file_url }}" type="video/mp4">
                  </video>
                  <button class="video-play-button" aria-label="Play video">
                    <svg width="94" height="107" viewBox="0 0 94 107" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <foreignObject x="-6.6" y="-6.6" width="106.458" height="119.35"><div xmlns="http://www.w3.org/1999/xhtml" style="backdrop-filter:blur(3.3px);clip-path:url(#bgblur_0_2671_2845_clip_path);height:100%;width:100%"></div></foreignObject><path data-figma-bg-blur-radius="6.6" d="M90.7578 48.7459C94.0911 50.6704 94.0911 55.4817 90.7578 57.4062L7.50218 105.474C4.16885 107.398 0.00217687 104.993 0.00217704 101.144L0.00218124 5.00836C0.00218141 1.15936 4.16885 -1.24627 7.50218 0.67823L90.7578 48.7459Z" fill="white" fill-opacity="0.54"/>
                      <defs>
                      <clipPath id="bgblur_0_2671_2845_clip_path" transform="translate(6.6 6.6)"><path d="M90.7578 48.7459C94.0911 50.6704 94.0911 55.4817 90.7578 57.4062L7.50218 105.474C4.16885 107.398 0.00217687 104.993 0.00217704 101.144L0.00218124 5.00836C0.00218141 1.15936 4.16885 -1.24627 7.50218 0.67823L90.7578 48.7459Z"/>
                      </clipPath></defs>
                    </svg>
                  </button>
                  {% if section.settings.media_text != blank %}
                    <span class="media_text">{{ section.settings.media_text }}</span>
                  {% endif %}
                </div>
              {% endif %}
            {% endif %}

          </div>
        {% else %}
          <div class="meta_product_inner">
            {% if product.metafields.custom.similar_products != blank %}
              <div class="meta-color-head">{{ product.options[0] | replace: 'Color', 'Colours' }}</div>
            {% endif %}
            {% if product.metafields.custom.similar_products != blank %}
              <div class="meta-color-value">{{ product.options_with_values[0].selected_value }}</div>
            {% endif %}
            <div class="meta-color-select">
              <div class="meta-color-select__options">
                {%- unless product.has_only_default_variant -%}
                  {%- assign color_swatch_config = settings.color_swatch_config | newline_to_br | split: '<br />' -%}
                  {%- assign color_swatch_style = '' -%}

                  {%- for option in product.options_with_values -%}
                    {% assign option_name = option.name | downcase %}

                    {% if option_name == option_color %}
                      {%- for value in option.values -%}
                        {% assign color_swatch_style = null %}
                        {%- assign swatch = value.swatch -%}
                        {%- assign color_value_downcase = value | downcase -%}
                        {%- assign color_swatch_style = 'background-color: ' | append: swatch.color | append: ';' -%}
                        {%- for color_swatch_item in color_swatch_config -%}
                          {%- assign color_swatch_parts = color_swatch_item | split: ':' -%}
                          {%- assign color_swatch_name = color_swatch_parts.first | downcase | strip -%}
                          {%- if color_value_downcase == color_swatch_name -%}
                            {%- assign color_swatch_value = color_swatch_parts.last | strip -%}
                            {%- if color_swatch_value contains '#' -%}
                              {%- assign color_swatch_style = 'background-color: '
                                | append: color_swatch_value
                                | append: ';'
                              -%}
                            {%- elsif swatch.color != blank -%}
                              {%- assign color_swatch_style = 'background-color: '
                                | append: swatch.color
                                | append: ')'
                              -%}
                            {%- elsif images[color_swatch_value] != blank -%}
                              {%- assign color_swatch_image = images[color_swatch_value] | img_url: '72x72' -%}
                              {%- assign color_swatch_style = 'background-image: url('
                                | append: color_swatch_image
                                | append: ')'
                                | append: ';'
                              -%}
                            {%- endif -%}
                          {%- endif -%}
                        {%- endfor -%}
                        {% assign color_active = true %}
                        {% assign color_swatch_style = color_swatch_style %}
                        {% if forloop.first %}
                          {% break %}
                        {% endif %}
                      {%- endfor -%}
                    {% endif %}
                  {%- endfor -%}
                {% endunless %}
                {% if product.metafields.custom.swatches_image != blank %}
                  {% assign metafiled_image = product.metafields.custom.swatches_image | img_url: 'master' %}
                  {%- assign color_swatch_style = 'background-image: url('
                    | append: metafiled_image
                    | append: ')'
                    | append: ';'
                  -%}
                {% endif %}
                <div
                  class="single_product active"
                  data_handle="{{ product.url }}"
                  data-style="{% if color_active %}{{ color_swatch_style }}{% endif %}"
                >
                  {% if template contains 'fragrances' -%}
                    {{- product.selected_or_first_available_variant.options[0] }}
                  {% else %}
                    {% if product.metafields.custom.swatches_image.value != blank %}
                      <img
                        src="{{ product.metafields.custom.swatches_image.value | img_url:"100x" }}"
                        width=""
                        height=""
                      >
                    {% else %}
                      <img src="{{ product.featured_image | img_url:"100x" }}" width="" height="">
                    {% endif %}
                  {% endif %}
                </div>
                {% if product.metafields.custom.similar_products != blank %}
                  {% for meta_product in product.metafields.custom.similar_products.value %}
                    {% unless meta_product.handle == product.handle %}
                      {%- unless meta_product.has_only_default_variant -%}
                        {%- assign color_swatch_config = settings.color_swatch_config
                          | newline_to_br
                          | split: '<br />'
                        -%}
                        {%- assign color_swatch_style = '' -%}

                        {%- for option in meta_product.options_with_values -%}
                          {% assign option_name = option.name | downcase %}

                          {% if option_name == option_color %}
                            {%- for value in option.values -%}
                              {% assign color_swatch_style = null %}
                              {%- assign swatch = value.swatch -%}
                              {%- assign color_value_downcase = value | downcase -%}
                              {%- assign color_swatch_style = 'background-color: '
                                | append: swatch.color
                                | append: ';'
                              -%}
                              {%- for color_swatch_item in color_swatch_config -%}
                                {%- assign color_swatch_parts = color_swatch_item | split: ':' -%}
                                {%- assign color_swatch_name = color_swatch_parts.first | downcase | strip -%}
                                {%- if color_value_downcase == color_swatch_name -%}
                                  {%- assign color_swatch_value = color_swatch_parts.last | strip -%}
                                  {%- if color_swatch_value contains '#' -%}
                                    {%- assign color_swatch_style = 'background-color: '
                                      | append: color_swatch_value
                                      | append: ';'
                                    -%}
                                  {%- elsif swatch.color != blank -%}
                                    {%- assign color_swatch_style = 'background-color: '
                                      | append: swatch.color
                                      | append: ')'
                                    -%}
                                  {%- elsif images[color_swatch_value] != blank -%}
                                    {%- assign color_swatch_image = images[color_swatch_value] | img_url: '72x72' -%}
                                    {%- assign color_swatch_style = 'background-image: url('
                                      | append: color_swatch_image
                                      | append: ')'
                                      | append: ';'
                                    -%}
                                  {%- endif -%}
                                {%- endif -%}
                              {%- endfor -%}
                              {% assign color_active = true %}
                              {% assign color_swatch_style = color_swatch_style %}
                              {% if forloop.first %}
                                {% break %}
                              {% endif %}
                            {%- endfor -%}
                          {% endif %}
                        {%- endfor -%}
                      {%- endunless -%}
                      {% if meta_product.metafields.custom.swatches_image != blank %}
                        {% assign metafiled_image = meta_product.metafields.custom.swatches_image | img_url: 'master' %}
                        {%- assign color_swatch_style = 'background-image: url('
                          | append: metafiled_image
                          | append: ')'
                          | append: ';'
                        -%}
                      {% endif %}
                      <div
                        class="single_product"
                        data_handle="{{ meta_product.url }}"
                        data-style="{% if color_active %}{{ color_swatch_style }}{% endif %}"
                      >
                        {% if template contains 'fragrances' -%}
                          {{- meta_product.selected_or_first_available_variant.options[0] }}
                        {% else %}
                          {% if meta_product.metafields.custom.swatches_image.value != blank %}
                            <img
                              src="{{ meta_product.metafields.custom.swatches_image.value | img_url:"100x" }}"
                              width=""
                              height=""
                            >
                          {% else %}
                            <img src="{{ meta_product.featured_image | img_url:"100x" }}" width="" height="">
                          {% endif %}
                        {% endif %}
                      </div>
                    {% endunless %}
                  {% endfor %}
                {% endif %}
              </div>
            </div>

            <div class="detail__sidebar__colors__price {% if template == 'product' and product.gift_card? == false %} product_default{% endif %}">
              {% if product.selected_or_first_available_variant.compare_at_price != 0 %}
                <h5 class="h4 compare_at_price">
                  {{ product.selected_or_first_available_variant.compare_at_price | money_without_trailing_zeros }}
                </h5>
              {% endif %}
              <h4>{{ product.selected_or_first_available_variant.price | money_without_trailing_zeros }}</h4>
            </div>
          </div>
          {% assign colors_names = 'color,colors,colour,colours' | split: ',' %}
          {% comment %}  {%- if product.available -%}{% endcomment %}
          {%- unless product.has_only_default_variant -%}
            {%- assign color_swatch_config = settings.color_swatch_config | newline_to_br | split: '<br />' -%}
            {% assign selected_variant = product.selected_or_first_available_variant %}

            {%- assign color_swatch_style = '' -%}

            {%- for option in product.options_with_values -%}
              {% assign option_size = 'size' %}
              {% assign option_name = option.name | downcase %}
              {% if option_name == 'shoe size' %}
                {% assign option_name = option_size %}
              {% endif %}

              {% assign option_color_length = 0 %}
              {% if option_name == option_color %}
                {% assign option_color_length = option.values.size %}
              {% endif %}
              {% unless colors_names contains option_name %}
                <div
                  class="{% if product.gift_card? %}detail__sidebar__sizes {% endif %}detail__sidebar__{{- option_name -}}s option_index{% if option_color_length == 1 and option_name == option_color %} hidden{% endif %}{% if template contains "fragrances" %} hidden{% endif %}"
                  data-option="option{{ forloop.index }}"
                >
                  <div
                    class="{{- option_name -}}-select"
                    {% if option_name == option_size %}
                      data-recommended="{{ option.values[2] }}"
                    {% endif %}
                  >
                    <select
                      class="{{- option_name -}}-select__select"
                      name="{{- option_name -}}"
                      aria-label="Select {{- option_name -}}"
                    >
                      {%- for value in option.values -%}
                        <option value="{{- value -}}">{{- value -}}</option>
                      {%- endfor -%}
                    </select>

                    {% comment %}
                      <div class="{{- option_name -}}-select__options">
                        {%- for value in option.values -%}
                          {% if option_name == option_color %}
                            {% assign color_swatch_style = null %}
                            {%- assign swatch = value.swatch -%}
                            {%- assign color_value_downcase = value | downcase -%}
                            {%- assign color_swatch_style = 'background-color: ' | append: swatch.color | append: ';' -%}
                            {%- for color_swatch_item in color_swatch_config -%}
                              {%- assign color_swatch_parts = color_swatch_item | split: ':' -%}
                              {%- assign color_swatch_name = color_swatch_parts.first | downcase | strip -%}
                              {%- if color_value_downcase == color_swatch_name -%}
                                {%- assign color_swatch_value = color_swatch_parts.last | strip -%}
                                {%- if color_swatch_value contains '#' -%}
                                  {%- assign color_swatch_style = 'background-color: '
                                    | append: color_swatch_value
                                    | append: ';'
                                  -%}
                                {%- elsif swatch.color != blank -%}
                                  {%- assign color_swatch_style = 'background-color: '
                                    | append: swatch.color
                                    | append: ')'
                                  -%}
                                {%- elsif images[color_swatch_value] != blank -%}
                                  {%- assign color_swatch_image = images[color_swatch_value] | img_url: '72x72' -%}
                                  {%- assign color_swatch_style = 'background-image: url('
                                    | append: color_swatch_image
                                    | append: ')'
                                    | append: ';'
                                  -%}
                                {%- endif -%}
                              {%- endif -%}
                            {%- endfor -%}
                          {% endif %}

                          <div
                            class="option{% unless value.variant.available %} option--out-of-stock{% endunless %}"
                            data-value="{{- value -}}"
                            {% if option_name == option_color %}
                              style="{{ color_swatch_style }}"
                            {% endif %}
                          >
                            {%- unless option_name == option_color -%}
                              <small>{{- value -}}</small>
                            {%- endunless -%}
                          </div>
                        {%- endfor -%}
                        {%- if option_name == option_size -%}<div class="successfully_ATC"></div>{%- endif -%}
                      </div>
                    {% endcomment %}

                    <div class="pro-custom-select" data-custom-select-option="{{ option_name }}" data-pro-custom-select>
                      <button class="pro-custom-select-button dd" data-pro-custom-select-btn>
                        {% comment %} <span class="s-text">Please select a size</span> {% endcomment %}
                         <span class="s-text"
                          ><span class="opt-value"
                            ><b>
                              {{- option.name }}
                              {{ option.selected_value -}}
                            </b>
                            {%- if selected_variant.inventory_quantity <= 5 and selected_variant.inventory_quantity > 0 %}
                              - only {{ selected_variant.inventory_quantity }} left
                            {%- endif -%}
                          </span>
                          {%- unless selected_variant.available -%}
                            <span class="opt-oos">
                              - out of stock
                              <a class="button klaviyo-bis-trigger" href="#" data-klaviyo-handle="{{ product.handle }}"
                                >notify me when available</a
                              ></span
                            >
                          {%- endunless -%}
                        </span>
                        <span class="s-icon">
                          <svg xmlns="http://www.w3.org/2000/svg" width="6" height="13" viewBox="0 0 6 13" fill="none">
                            <path d="M0.177734 0.479492L4.79655 6.866L0.177734 12.7963" stroke="#939393" stroke-width="0.461881"/>
                          </svg>
                        </span>
                      </button>
                      <ul class="pro-custom-select-list lenis" data-pro-custom-select-list>
                        {% comment %} <li class="pro-custom-select-list-item disabled">Please select a size</li> {% endcomment %}
                        {%- for value in option.values -%}
                          <li
                            class="pro-custom-select-list-item c-option{%- unless value.available %} c-option--out-of-stock{% endunless %}"
                            data-value="{{- value -}}"
                            data-pro-custom-select-list-item
                          >
                            <span class="opt-value"
                              ><b>
                                {{- option.name }}
                                {{ value -}}
                              </b>
                              {%- if value.variant.inventory_quantity <= 5 and value.variant.inventory_quantity > 0 %}
                                - only {{ value.variant.inventory_quantity }} left
                              {%- endif -%}
                            </span>
                            {%- unless value.available -%}
                              <span class="opt-oos">
                                - out of stock
                                <a
                                  class="button klaviyo-bis-trigger"
                                  href="#"
                                  data-klaviyo-handle="{{ product.handle }}"
                                  >notify me when available</a
                                ></span
                              >
                            {%- endunless -%}
                          </li>
                        {%- endfor -%}
                      </ul>
                    </div>

                    {% if product.gift_card? %}
                      <span class="select-value-alert hidden">SELECT VALUE</span>
                    {% endif %}
                    {%- if option_name == option_size -%}
                      <button class="btn btn--outline hidden"><small>RECOMMENDED SIZE</small></button>
                    {%- endif -%}

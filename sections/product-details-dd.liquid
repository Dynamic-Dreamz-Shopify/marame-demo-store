          {% form 'product',
            product,
            id: product_form_id,
            class: 'form shopify-product-form product_page_atc_form',
            data-handle: product.handle
          %}
            <select
              name="id"
              style="display:none !important"
              class="product_option_selection"
              id="products-{{ product.id }}"
            >
              {%- for variant in product.variants -%}
                <option
                  value="{{ variant.id }}"
                  {% comment %}{% if product.selected_or_first_available_variant.id == variant.id %} selected="selected"{% endif %}{% endcomment %}
                >
                  {{- variant.title -}}
                </option>
              {% endfor %}
            </select>
            <script type="application/json">
              {{ product | json }}
            </script>

            <input
              type="hidden"
              name="quantity"
              value="1"
            >

            <div class="accordion_with_atc_buttons">
              {%- assign haveSize = false -%}
              {% for opt in product.options %}
                {% assign optName = opt | downcase %}
                {% if optName == 'size' or optName == 'shoe size' %}
                  {% assign haveSize = true %}
                  {% break %}
                {% endif %}
              {% endfor %}
              {% if template contains 'fragrances' %}
                {%- assign haveSize = false -%}
              {% endif %}

              <div class="detail__sidebar__ctas{% if haveSize %} have-sizes{% endif %}">
                <div class="detail__sidebar__ctas-inner">
                  {% if haveSize %}
                    <a href="{{ product.url }}" class="btn btn--outline addtocart_form_submit-temp">Add to bag</a>
                  {% endif %}
                  <a
                    href="{{ product.url }}"
                    class="btn btn--dark addtocart_form_submit{% unless product.selected_or_first_available_variant.available %} disabled{% endunless %}"
                  >
                    {% if product.selected_or_first_available_variant.available %}
                      {{ 'products.product.add_to_cart' | t }}
                    {% else %}
                      {{ 'products.product.sold_out' | t }}
                    {% endif %}
                  </a>
                </div>
                {% if product.available %}
                  {{ form | payment_button }}
                {% endif %}
                {% if product.metafields.custom.buy_the_look != blank %}
                  <a href="#buy_full_look" class="btn btn--dark scroll-to-section">Buy Full Look</a>
                {% endif %}
              </div>

              {% if section.settings.shipping_text != blank %}
                <div class="pro_shipping-payment_text">
                  <div class="pro-shipping_text">{{ section.settings.shipping_text }}</div>
                  <div class="pro-payments_wrapper">
                    <div class="pro-payments_item pro-payments_klarna">
                      3 payments of £{{ product.price | divided_by: 3 | round | divided_by: 100.0 }} at 0% interest with
                      <span>{% render 'icon-klarna' %}</span>
                    </div>
                    <div class="pro-payments_item pro-payments_clearpay">
                      or 4 payments of £{{ product.price | divided_by: 4 | round | divided_by: 100.0 }} with
                      <span>{% render 'icon-clearpay' %}</span>
                    </div>
                  </div>
                </div>
              {% endif %}
              {% render 'product-tabs' %}
              {% comment %}
                <div class="accordion__list">
                  {% assign show_collapsible_content = true %}
                  {%- for i in (1..5) -%}
                    {% assign key = 'accordion_' | append: forloop.index | append: '_title' %}
                    {% assign title = product.metafields.custom[key].value %}
                    {% assign content_key = 'accordion_' | append: forloop.index | append: '_content' %}
                    {% assign content_accordion = product.metafields.custom[content_key] %}
                    {%- if title != blank and content_accordion != blank -%}
                      {% assign show_collapsible_content = false %}
                      <details class="accordion">
                        <summary class="accordion__head">
                          <h5>
                            {% if title != blank %}
                              {{ title | replace: "Garment", "Product" }}
                            {% endif %}
                          </h5>
                        </summary>

                        <div class="accordion__body">
                          <div class="accordion__body__inner">
                            {% if content_accordion != blank %}
                              {{ content_accordion | metafield_tag }}
                              {% if i == 3 -%}
                                {%- capture rankData -%}
                                {%- for n in (1..4) -%}
                                  {%- assign labelKey = 'label_' | append: forloop.index -%}
                                  {%- assign labelKeyVal = 'label_' | append: forloop.index | append: '_rank' -%}
                                  {%- assign labelVal = product.metafields.custom[labelKey].value -%}
                                  {%- assign labelRankVal = product.metafields.custom[labelKeyVal].value | plus: 0 -%}
                                  {%- if labelVal != blank and labelRankVal != blank -%}
                                  <div class="accordion__body-label-item">
                                    <span class="rank-label">{{ labelVal }}</span>
                                    {%- render 'icon-rank', rank: labelRankVal -%}
                                  </div>
                                  {%- endif -%}
                                {%- endfor -%}
                                {%- endcapture -%}
                                {%- if rankData != blank -%}<div class="accordion__body-label-list">{{ rankData }}</div>{%- endif -%}
                              {% endif %}
                            {% endif %}
                          </div>
                        </div>
                      </details>
                    {%- endif -%}
                  {%- endfor -%}
                  {% if settings.sr_head != blank and settings.sr_content != blank %}
                  <details class="accordion">
                    <summary class="accordion__head">
                      <h5 class="medium">{{ settings.sr_head }}</h5>
                    </summary>
                    <div class="accordion__body">
                      <div class="accordion__body__inner">{{ settings.sr_content }}</div>
                    </div>
                  </details>
                  {% endif %}
                <details class="accordion">
                  <summary class="accordion__head">
                    <h5 class="medium">Reviews</h5>
                  </summary>
                  <div class="accordion__body">
                    <div class="accordion__body__inner">
                      <div class="trustpilot_app_div">
                          <!-- TrustBox widget - Mini -->
                            <div class="trustpilot-widget" data-locale="en-GB" data-template-id="53aa8807dec7e10d38f59f32" data-businessunit-id="6863d52829d0eb9d7940e024" data-style-height="150px" data-style-width="100%">
                              <a href="https://uk.trustpilot.com/review/marame.com" target="_blank" rel="noopener">Trustpilot</a>
                            </div>
                      </div>
                    </div>
                  </div>
                </details>
                </div>
              {% endcomment %}
            </div>
            {% comment %} <a class="button klaviyo-bis-trigger" href="#" style="text-align: center; margin: 0px; width: auto; display: inline;" data-klaviyo-handle="{{ product.handle }}">OUT OF STOCK - NOTIFY ME</a> {% endcomment %}

            {% comment %}
              <div
                class="klaviyo-product-container"
                id="klaviyo-data-handle-{{ product.handle }}"
                data-klaviyo-handle="{{ product.handle }}"
              >
                <div class="klaviyo-button-container product-grid-btn">
                </div>
              </div>
            {% endcomment %}
          {% endform %}
        {% endif %}
        {% assign current_model_color = '' %}
        {% assign colors = 'color,colors,colour,colours,Color,Colors,Colour,Colours' | split: ',' %}

        {% for option in product.options_with_values %}
          {% if colors contains option.name %}
            {% assign current_model_color = option.selected_value | downcase | strip %}
            {% break %}
          {% endif %}
        {% endfor %}

        {% assign current_variant = product.selected_or_first_available_variant %}
        {% assign current_model_color = blank %}

        {% for option in product.options_with_values %}
          {% if colors contains option.name %}
            {% assign current_model_color = option.selected_value | downcase | strip %}
            {% break %}
          {% endif %}
        {% endfor %}

        {% assign default_fit_content = current_variant.metafields.custom.fit_and_fabric_accordion_3_content 
          | default: current_variant.metafields.custom.fit_and_fabric_accordion_3_contents 
          | default: product.metafields.custom.accordion_3_content 
        %}

        {% assign default_fit_text_full = default_fit_content | metafield_text | default: default_fit_content | strip_html | strip %}
        {% assign default_fit_text = default_fit_text_full %}

        {% if default_fit_text_full contains 'wearing a Size' %}
          {% assign default_fit_text_parts = default_fit_text_full | split: 'wearing a Size' %}
          {% assign before_wearing_size = default_fit_text_parts[0] | split: '.' %}
          {% assign last_sentence_start = before_wearing_size | last | strip %}
          {% assign size_part = default_fit_text_parts[1] | split: '.' | first | strip %}
          {% assign default_fit_text = last_sentence_start | append: ' wearing a Size ' | append: size_part | append: '.' %}
        {% endif %}

        {% assign default_model_size_raw = default_fit_text | split: 'Size' | last | remove: '.' | strip %}
        {% assign default_model_size = default_model_size_raw | split: ' ' | first | strip %}
        {% assign default_model_name = default_fit_text | split: ' is ' | first | strip %}

        {% assign has_default_model_info = false %}

        {% if default_fit_text contains ' is ' and default_fit_text contains 'Size' and default_model_size != blank and default_model_name != blank %}
          {% assign has_default_model_info = true %}
          {% assign default_model_title = default_model_name | append: ' is a UK Size ' | append: default_model_size %}
          {% assign default_model_label = 'Size ' | append: default_model_size %}
        {% endif %}

        {% if show_model_selector %}
          <div class="different-model-wrapper" data-model-switcher data-current-color="{{ current_model_color | escape }}">
            <p>{{ section.settings.different_model | default: 'VIEW ON A DIFFERENT MODEL' }}</p>

            <div class="different-model-list">
              {% assign default_color_keys = '' %}

              {% for media in product.media %}
                {% if media.media_type == 'image' %}
                  {% assign alt_parts = media.alt | split: '|' %}
                  {% assign first_part = alt_parts[0] | strip %}
                  {% assign second_part = alt_parts[1] | strip %}
                  {% assign option_value = '' %}
                  {% assign is_model_image = false %}

                  {% if media.alt contains '|' %}
                    {% if second_part contains 'Size' %}
                      {% assign option_value = first_part | downcase | strip %}
                      {% assign is_model_image = true %}
                    {% else %}
                      {% assign option_value = second_part | downcase | strip %}
                    {% endif %}
                  {% else %}
                    {% assign option_value = media.alt | downcase | strip %}
                  {% endif %}

                  {% assign default_color_key = 'default-model-' | append: option_value | handleize %}

                  {% unless is_model_image %}
                    {% unless default_color_keys contains default_color_key %}
                      {% assign default_color_keys = default_color_keys | append: default_color_key | append: ',' %}
                      {% if has_default_model_info %}
                        <button
                          type="button"
                          class="different-model-item default-model-item{% if option_value == current_model_color %} active{% endif %}"
                          data-model-trigger="{{ default_color_key }}"
                          data-model-title="{{ default_model_title | escape }}"
                          data-model-fit-text="{{ default_fit_text | escape }}"
                          data-model-color="{{ option_value | escape }}"
                          data-default-model="true"
                        >
                          <div class="different-model-image">
                            <img src="{{ media | img_url: '300x' }}" alt="{{ default_fit_text | escape }}">
                          </div>
                          <span>{{ default_model_label }}</span>
                        </button>
                      {% endif %}
                    {% endunless %}
                  {% endunless %}
                {% endif %}
              {% endfor %}

              {% assign model_keys = '' %}

              {% for media in product.media %}
                {% if media.media_type == 'image' and media.alt contains '|' and media.alt contains 'Size' %}
                  {% assign alt_parts = media.alt | split: '|' %}
                  {% assign option_value = alt_parts[0] | strip | downcase %}
                  {% assign model_title = alt_parts[1] | strip %}
                  {% assign model_fit_text = alt_parts[2] | strip %}
                  {% assign model_key = model_title | downcase | handleize %}
                  {% assign model_size_raw = model_title | split: 'Size' | last | strip %}
                  {% assign model_size = model_size_raw | split: ' ' | first | strip %}
                  {% assign model_label = 'Size ' | append: model_size %}

                  {% unless model_keys contains model_key %}
                    {% assign model_keys = model_keys | append: model_key | append: ',' %}

                    <button
                      type="button"
                      class="different-model-item"
                      data-model-trigger="{{ model_key }}"
                      data-model-title="{{ model_title | escape }}"
                      data-model-fit-text="{{ model_fit_text | escape }}"
                      data-model-color="{{ option_value | escape }}"
                    >
                      <div class="different-model-image">
                        <img src="{{ media | img_url: '300x' }}" alt="{{ model_title | escape }}">
                      </div>
                      <span>{{ model_label }}</span>
                    </button>
                  {% endunless %}
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>


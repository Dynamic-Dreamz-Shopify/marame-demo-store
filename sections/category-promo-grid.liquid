{{ 'category-promo-grid.css' | asset_url | stylesheet_tag }}

{% if section.settings.background_color != blank %}
<style>
    .shoe-hotspot-frame {
        background-color: {{ section.settings.background_color }};
        color: {{ section.settings.text_color }};
    }
</style>
{% endif %}

<section class="category-promo-grid">
  <div class="category-grid-container page-width">
    <div class="category-grid">
      {% for block in section.blocks %}
        <div class="category-item" {% if block.settings.mobile_item_order != blank %}style="order: {{ block.settings.mobile_item_order }}"{% endif %} {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <a href="{{ block.settings.link }}" class="category-image-link">
              <img 
                src="{{ block.settings.image | img_url: 'master' }}" 
                alt="{{ block.settings.title | escape }}" 
                loading="eager"
                width="100%"
                height="100%"
              >
            </a>
          {% endif %}

          {% if block.settings.title != blank %}
            <h3 class="category-title">
              {% if block.settings.link != blank %}
                <a href="{{ block.settings.link }}">{{ block.settings.title }}</a>
              {% else %}
                {{ block.settings.title }}
              {% endif %}
            </h3>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category Promo Grid",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f8f6f2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "category_item",
      "name": "Category Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category Title",
          "default": "Category Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category Link"
        },
        {
          "type": "number",
          "id": "mobile_item_order",
          "label": "Mobile Item Order"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Category Promo Grid",
      "category": "Image"
    }
  ]
}
{% endschema %}
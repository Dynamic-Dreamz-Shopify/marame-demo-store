          </g>
          <defs>
            <clipPath id="clip0_97_8310">
              <rect width="16" height="16" fill="white"></rect>
            </clipPath>
          </defs>
        </svg>
      </a>
    {%- endif -%}
  </div>
</header>

{% schema %}
{
  "name": "Header alter",
  "class": "section-header",
  "settings": [
    {
      "type": "html",
      "id": "header_logo_svg",
      "label": "Logo SVG"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "t:sections.header.settings.menu.label"
    },
    {
      "type": "checkbox",
      "id": "header_black",
      "label": "Header Black",
      "default": true
    },
    {
      "type": "header",
      "content": "Other menu"
    },
    {
      "type": "text",
      "id": "other_menu_1",
      "default": "Lookbook",
      "label": "Other menu 1"
    },
    {
      "type": "url",
      "id": "other_menu_url_1",
      "label": "Other menu URL 1"
    },
    {
      "type": "text",
      "id": "other_menu_2",
      "default": "Fit Finder",
      "label": "Other menu 2"
    },
    {
      "type": "url",
      "id": "other_menu_url_2",
      "label": "Other menu URL 2"
    },
    {
      "type": "header",
      "content": "Find your content"
    },
    {
      "type": "checkbox",
      "id": "show_find_your_content",
      "label": "Show Find your content",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "find_your_title",
      "default": "Find your fit",
      "label": "Title"
    },
    {
      "type": "inline_richtext",
      "id": "small_content",
      "label": "Content"
    },
    {
      "type": "url",
      "id": "url",
      "label": "URL"
    }
  ],
  "blocks": [
    {
      "type": "menu_image",
      "name": "Menu image",
      "settings": [
         {
          "type": "text",
          "id": "link_label",
          "label": "Menu item",
          "info": "In this menu item, the custom image and details are shown."
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Image"
        },
        {
          "type": "richtext",
          "id": "image_title",
          "label": "Text"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ]
}
{% endschema %}
{{ 'new-footer.css' | asset_url | stylesheet_tag }}
<style>
#footer-bottom-{{ section.id }} {
background-color: {{ section.settings.background_color }};
padding-top: {{ section.settings.padding_top }}px;
padding-bottom: {{ section.settings.padding_bottom }}px;
padding-left: {{ section.settings.padding_left }}px;
padding-right: {{ section.settings.padding_right }}px;
margin-top: {{ section.settings.margin_top }}px;
margin-bottom: {{ section.settings.margin_bottom }}px;
}
#footer-bottom-{{ section.id }} .footer-bottom-grid {
display: flex;
flex-direction: row;
align-items: {{ section.settings.vertical_align }};
justify-content: space-between;
gap: {{ section.settings.column_gap }}px;
width: 100%;
box-sizing: border-box;
}
#footer-bottom-{{ section.id }} .footer-bottom-left {
flex: 0 0 {{ section.settings.left_width }}%;
max-width: {{ section.settings.left_width }}%;
text-align: {{ section.settings.left_align }};
box-sizing: border-box;
}
#footer-bottom-{{ section.id }} .footer-bottom-center {
flex: 0 0 {{ section.settings.center_width }}%;
max-width: {{ section.settings.center_width }}%;
text-align: center;
box-sizing: border-box;
}
#footer-bottom-{{ section.id }} .footer-bottom-right {
flex: 0 0 {{ section.settings.right_width }}%;
max-width: {{ section.settings.right_width }}%;
text-align: {{ section.settings.right_align }};
box-sizing: border-box;
}
#footer-bottom-{{ section.id }} .trustpilot-scale-wrapper {
display: inline-block;
transform-origin: {{ section.settings.right_align }} center;
transform: scale({{ section.settings.widget_scale | divided_by: 100.0 }});
width: {{ section.settings.widget_scale_width }}%;
}
#footer-bottom-{{ section.id }} .footer-copyright {
color: {{ section.settings.copyright_color }};
font-size: {{ section.settings.copyright_font_size }}px;
font-weight: {{ section.settings.copyright_font_weight }};
letter-spacing: {{ section.settings.copyright_letter_spacing }}px;
text-transform: {{ section.settings.copyright_text_transform }};
margin: 0;
padding: 0;
}
#footer-bottom-{{ section.id }} .footer-logo img {
width: {{ section.settings.logo_width }}px;
height: auto;
display: block;
margin: 0 auto;
}
#footer-bottom-{{ section.id }} .footer-logo-text {
color: {{ section.settings.logo_text_color }};
font-size: {{ section.settings.logo_text_size }}px;
font-weight: {{ section.settings.logo_text_weight }};
letter-spacing: {{ section.settings.logo_text_spacing }}px;
text-transform: {{ section.settings.logo_text_transform }};
margin: 0;
padding: 0;
}
@media screen and (max-width: 768px) {
#footer-bottom-{{ section.id }} {
padding-top: {{ section.settings.padding_top_mobile }}px !important;
padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
padding-left: {{ section.settings.padding_left_mobile }}px !important;
padding-right: {{ section.settings.padding_right_mobile }}px !important;
margin-top: {{ section.settings.margin_top_mobile }}px !important;
margin-bottom: {{ section.settings.margin_bottom_mobile }}px !important;
}
#footer-bottom-{{ section.id }} .footer-bottom-grid {
flex-direction: {{ section.settings.mobile_stack }};
align-items: {{ section.settings.mobile_align }};
gap: {{ section.settings.mobile_gap }}px;
}
#footer-bottom-{{ section.id }} .footer-bottom-left,
#footer-bottom-{{ section.id }} .footer-bottom-center,
#footer-bottom-{{ section.id }} .footer-bottom-right {
flex: 0 0 100%;
max-width: 100%;
text-align: {{ section.settings.mobile_text_align }};
}
#footer-bottom-{{ section.id }} .trustpilot-scale-wrapper {
transform: scale({{ section.settings.widget_scale_mobile | divided_by: 100.0 }});
transform-origin: {{ section.settings.mobile_text_align }} center;
width: {{ section.settings.widget_scale_width_mobile }}%;
}
#footer-bottom-{{ section.id }} .footer-copyright {
font-size: {{ section.settings.copyright_font_size_mobile }}px;
}
#footer-bottom-{{ section.id }} .footer-logo img {
width: {{ section.settings.logo_width_mobile }}px;
margin: 0 auto;
{% if section.settings.mobile_text_align == 'left' %}margin-left: 0;{% endif %}
{% if section.settings.mobile_text_align == 'right' %}margin-right: 0;{% endif %}
}
#footer-bottom-{{ section.id }} .footer-logo-text {
font-size: {{ section.settings.logo_text_size_mobile }}px;
}
}
</style>
<section id="footer-bottom-{{ section.id }}">
<div class="footer-bottom-grid">
<div class="footer-bottom-left">
<p class="footer-copyright">
&copy; {{ 'now' | date: '%Y' }} {{ section.settings.copyright_text }}
</p>
</div>
<div class="footer-bottom-center">
{% if section.settings.logo != blank %}
<div class="footer-logo">
<img src="{{ section.settings.logo | image_url: width: 400 }}" alt="{{ section.settings.logo_alt | default: shop.name }}">
</div>
{% elsif section.settings.logo_text != blank %}
<p class="footer-logo-text">{{ section.settings.logo_text }}</p>
{% endif %}
</div>
<div class="footer-bottom-right">
<div class="trustpilot-scale-wrapper">
<div class="trustpilot-widget"
data-locale="{{ section.settings.locale }}"
data-template-id="{{ section.settings.template_id }}"
data-businessunit-id="{{ section.settings.business_unit_id }}"
data-style-height="{{ section.settings.widget_height }}px"
data-style-width="100%"
data-theme="{{ section.settings.widget_theme }}"
data-stars="{{ section.settings.stars }}">
<a href="https://www.trustpilot.com/review/{{ section.settings.domain }}" target="_blank" rel="noopener">Trustpilot</a>
</div>
</div>
</div>
</div>
</section>

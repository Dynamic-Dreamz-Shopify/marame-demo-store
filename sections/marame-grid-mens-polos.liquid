{% render 'marame-collection-grid-body' %}

{% schema %}
{
  "name": "G — Polos (Mens)",
  "settings": [
    {
      "type": "collection",
      "id": "marame_scope_collection",
      "label": "Collection (pick in editor)",
      "info": "If set, overrides the handle below. Use this to fix mismatched handles without touching template JSON."
    },
    {
      "type": "text",
      "id": "marame_scope_handle",
      "label": "Collection handle (locked for this grid)",
      "default": "polos-1",
      "info": "Grid for /collections/polos-1 on the merge template."
    },
    {
      "type": "textarea",
      "id": "marame_scope_extra_handles",
      "label": "Also show on these collection handles (comma-separated)"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 2,
      "max": 44,
      "step": 2,
      "default": 10,
      "label": "Products per page (auto / random mode)"
    },
    {
      "type": "range",
      "id": "marame_cards_per_page",
      "min": 20,
      "max": 60,
      "step": 4,
      "default": 44,
      "label": "Colour cards per page"
    },
    {
      "type": "header",
      "content": "Product card"
    },
    {
      "type": "checkbox",
      "id": "show_variant_count",
      "default": true,
      "label": "Show Variants count"
    },
    {
      "type": "checkbox",
      "id": "marame_native_shuffle",
      "default": true,
      "label": "Native variant shuffle (Sezerium replacement)"
    },
    {
      "type": "select",
      "id": "marame_display_mode",
      "label": "Which variants to show",
      "default": "blocks",
      "options": [
        { "value": "all", "label": "All products in this collection (auto)" },
        { "value": "blocks", "label": "Drag & drop Grid cards (manual seasons)" },
        { "value": "tag", "label": "Only products with a tag" },
        { "value": "metafield", "label": "Collection metafield (advanced)" },
        { "value": "manual", "label": "Manual list (below)" }
      ]
    },
    {
      "type": "select",
      "id": "marame_tag_mode",
      "label": "Product tag matching",
      "default": "collection",
      "options": [
        { "value": "collection", "label": "Collection tag" },
        { "value": "collection_or_custom", "label": "Collection tag OR extra tag below" },
        { "value": "custom", "label": "Extra tag only" }
      ]
    },
    {
      "type": "text",
      "id": "marame_include_tag",
      "label": "Extra include tag (optional)"
    },
    {
      "type": "textarea",
      "id": "marame_manual_variants",
      "label": "Manual variant list (when mode = manual)"
    },
    {
      "type": "checkbox",
      "id": "marame_hide_sold_out",
      "default": true,
      "label": "Hide sold-out colour variants"
    },
    {
      "type": "checkbox",
      "id": "marame_hide_no_image",
      "default": true,
      "label": "Hide colour variants without product images"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "default": true,
      "label": "Enable filtering"
    },
    {
      "type": "select",
      "id": "filter_type",
      "options": [
        { "value": "horizontal", "label": "Horizontal" },
        { "value": "vertical", "label": "Vertical" },
        { "value": "drawer", "label": "Drawer" }
      ],
      "default": "horizontal",
      "label": "Filter layout"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "default": true,
      "label": "Enable sorting"
    }
  ],
  "blocks": [
    {
      "type": "grid_variant",
      "name": "Grid card",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "color", "label": "Colour" },
        { "type": "text", "id": "collection_handle", "label": "Collection handle" }
      ]
    }
  ],
  "max_blocks": 250
}
{% endschema %}

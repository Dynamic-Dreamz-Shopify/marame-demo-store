      "default": "klaviyo_embed"
    },
    {
      "type": "text",
      "id": "klaviyo_form_id",
      "label": "Klaviyo form ID",
      "default": "ShK72R",
      "info": "6-character ID from your embed (e.g. ShK72R for klaviyo-form-ShK72R)."
    },
    {
      "type": "textarea",
      "id": "klaviyo_embed_code",
      "label": "Klaviyo embed HTML (optional)",
      "default": "<div class=\"klaviyo-form-ShK72R\"></div>",
      "info": "Paste the full embed snippet from Klaviyo. The form ID is read automatically; our custom field styling is still applied."
    },
    {
      "type": "textarea",
      "id": "signup_heading",
      "label": "Heading",
      "default": "register your interests for pre access"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "enter email"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit label",
      "default": "SUBMIT"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Message after submit",
      "default": "Thank you for registering."
    },
    {
      "type": "text",
      "id": "klaviyo_company_id",
      "label": "Klaviyo company ID (custom form)",
      "default": "RuBV9d"
    },
    {
      "type": "text",
      "id": "klaviyo_list_id",
      "label": "Klaviyo list ID (custom form)",
      "default": "Tca9mX"
    },
    {
      "type": "text",
      "id": "terms_button_label",
      "label": "Info button label",
      "default": "Terms and conditions"
    },
    {
      "type": "image_picker",
      "id": "terms_icon",
      "label": "Info icon (optional)"
    },
    {
      "type": "text",
      "id": "terms_modal_title",
      "label": "Terms popup title",
      "default": "Terms & conditions"
    },
    {
      "type": "richtext",
      "id": "terms_content",
      "label": "Terms popup content",
      "default": "<p>By submitting your email you agree to receive marketing communications from Marame. You can unsubscribe at any time.</p>"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "paragraph",

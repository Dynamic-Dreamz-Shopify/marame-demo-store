{% render 'msp-assets' %}

{%- capture klaviyo_form_id -%}{% render 'msp-klaviyo-form-id', form_id: section.settings.klaviyo_form_id, embed_code: section.settings.klaviyo_embed_code %}{%- endcapture -%}
{%- assign klaviyo_form_id = klaviyo_form_id | strip -%}
{%- liquid
  assign use_klaviyo_embed = false
  if section.settings.form_mode == 'klaviyo_embed' and klaviyo_form_id != blank
    assign use_klaviyo_embed = true
  endif
-%}

{% style %}
  #msp-form-{{ section.id }} {
    --msp-border: {{ section.settings.color_border }};
    --msp-muted: {{ section.settings.color_placeholder }};
    --msp-signup-bg: {{ section.settings.color_signup_glass }};
    --msp-input-bg: {{ section.settings.color_input_bg }};
    --msp-button-bg: {{ section.settings.color_button_bg }};
    --msp-button-color: {{ section.settings.color_button_text }};
    --msp-button-bg-inactive: {{ section.settings.color_button_bg_inactive }};
    --msp-button-color-inactive: {{ section.settings.color_button_text_inactive }};
    --msp-signup-heading-color: {{ section.settings.color_signup_heading }};
    {% render 'msp-signup-form-vars', section: section %}
    {% render 'msp-headline-weight-vars', weight: section.settings.signup_heading_font_weight %}
    --msp-signup-pad-top-mobile: {{ section.settings.signup_pad_top_mobile }}px;
    --msp-signup-pad-bottom-mobile: {{ section.settings.signup_pad_bottom_mobile }}px;
    --msp-signup-pad-top-desktop: {{ section.settings.signup_pad_top_desktop }}px;
    --msp-signup-pad-bottom-desktop: {{ section.settings.signup_pad_bottom_desktop }}px;
    --msp-gap-before-signup-mobile: {{ section.settings.gap_before_signup_mobile }}px;
    --msp-gap-before-signup-desktop: {{ section.settings.gap_before_signup_desktop }}px;
  }
  {%- capture msp_form_scope -%}#msp-form-{{ section.id }}{%- endcapture -%}
  {% render 'msp-block-height-style',
    scope_id: msp_form_scope,
    target_selector: '.msp-signup-wrap',
    height_mobile: section.settings.block_height_mobile,
    height_desktop: section.settings.block_height_desktop,
    use_min_height: true
  %}
{% endstyle %}

<section
  id="msp-form-{{ section.id }}"
  class="msp msp-section msp-section--form{% unless section.settings.show_mobile %} msp-section--hide-mobile{% endunless %}{% unless section.settings.show_desktop %} msp-section--hide-desktop{% endunless %}"
  {% render 'msp-logo-zone-marker', zone_key: 'signup_form', zone_label: 'Register form' %}
  data-marame-signup-page
  data-marame-signup-section
  data-klaviyo-company="{{ section.settings.klaviyo_company_id | escape }}"
  data-klaviyo-list="{{ section.settings.klaviyo_list_id | escape }}"
  data-success-message="{{ section.settings.success_message | escape }}"
>
  <div class="msp-signup-wrap{% if section.settings.enable_scroll_animations %} msp-reveal{% endif %}">
    {% render 'msp-signup-form', section: section, use_klaviyo_embed: use_klaviyo_embed, klaviyo_form_id: klaviyo_form_id %}
  </div>

  <div
    class="msp-modal"
    data-msp-terms-modal
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-labelledby="msp-terms-title-{{ section.id }}"
  >
    <div class="msp-modal__dialog">
      <button type="button" class="msp-modal__close" data-msp-terms-close aria-label="Close">&times;</button>
      <h2 class="msp-modal__title" id="msp-terms-title-{{ section.id }}">
        {{ section.settings.terms_modal_title }}
      </h2>
      <div class="msp-modal__content rte">
        {{ section.settings.terms_content }}
      </div>
    </div>
  </div>
</section>

{% schema %}

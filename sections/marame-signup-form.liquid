    },
    {
      "type": "color",
      "id": "color_input_bg",
      "label": "Input background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_signup_glass",
      "label": "Glass background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_signup_heading",
      "label": "Heading colour",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "color_button_bg",

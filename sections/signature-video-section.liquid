{{ 'signature-video-section.css' | asset_url | stylesheet_tag }}

<section class="signature-video-section">
  <div class="signature-wrapper">
    <div class="signature-text">
      <div class="signature-title">
        <img src="{{ section.settings.title | img_url: 'master' }}" alt="{{ section.settings.title.alt }}" width="100%" height="100%">
      </div>
      <a href="{{ section.settings.button_link }}" class="signature-button">
        {{ section.settings.button_text }}
        <span class="arrow">
          <svg xmlns="http://www.w3.org/2000/svg" width="8" height="15" viewBox="0 0 8 15" fill="none">
            <path d="M1 1L7 7.74074L1 14" stroke="#E6E0D4"/>
          </svg>
        </span>
      </a>
    </div>

    <div class="signature-video">
        {% if section.settings.video != blank %}
            {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, class: 'signature-video-element' }}
        {% endif %}
        <div class="signature-video-mute">
            <svg width="25" height="18" class="no-sound" viewBox="0 0 25 18" fill="none" xmlns="http://www.w3.org/2000/svg">
              <g clip-path="url(#clip0_625_4786)">
                <path d="M11.5 0.87V17.12L6.43 11.85C6.29 11.7 6.09 11.62 5.89 11.62H0.5V6.38H5.9C6.1 6.38 6.3 6.3 6.44 6.15L11.5 0.87ZM11.75 0C11.69 0 11.63 0.02 11.58 0.08L6.08 5.8C6.08 5.8 5.97 5.88 5.9 5.88H0.25C0.11 5.88 0 6 0 6.14V11.86C0 12 0.11 12.12 0.25 12.12H5.9C5.97 12.12 6.03 12.15 6.08 12.2L11.58 17.92C11.63 17.97 11.69 18 11.75 18C11.88 18 12 17.9 12 17.74V0.26C12 0.1 11.88 0 11.75 0Z" fill="white"/>
                <path opacity="0.75" d="M14 4L24 14" stroke="white" stroke-width="0.5" stroke-miterlimit="10" stroke-linecap="round"/>
                <path opacity="0.75" d="M14 14L24 4" stroke="white" stroke-width="0.5" stroke-miterlimit="10" stroke-linecap="round"/>
              </g>
              <defs>
                <clipPath id="clip0_625_4786">
                  <rect width="24.25" height="18" fill="white"/>
                </clipPath>
              </defs>
            </svg>
            <svg width="25" height="18" class="sound" viewBox="0 0 25 18" fill="none" xmlns="http://www.w3.org/2000/svg">
              <g clip-path="url(#clip0_625_4792)">
                <path d="M11.5 0.87V17.12L6.43 11.85C6.29 11.7 6.09 11.62 5.89 11.62H0.5V6.38H5.9C6.1 6.38 6.3 6.3 6.44 6.15L11.5 0.87ZM11.75 0C11.69 0 11.63 0.02 11.58 0.08L6.08 5.8C6.08 5.8 5.97 5.88 5.9 5.88H0.25C0.11 5.88 0 6 0 6.14V11.86C0 12 0.11 12.12 0.25 12.12H5.9C5.97 12.12 6.03 12.15 6.08 12.2L11.58 17.92C11.63 17.97 11.69 18 11.75 18C11.88 18 12 17.9 12 17.74V0.26C12 0.1 11.88 0 11.75 0Z" fill="white"/>
                <path opacity="0.75" d="M14 15C16.42 11.37 16.42 6.63 14 3" stroke="white" stroke-width="0.5" stroke-miterlimit="10" stroke-linecap="round"/>
                <path opacity="0.75" d="M18 15C20.42 11.37 20.42 6.63 18 3" stroke="white" stroke-width="0.5" stroke-miterlimit="10" stroke-linecap="round"/>
                <path opacity="0.75" d="M22 15C24.42 11.37 24.42 6.63 22 3" stroke="white" stroke-width="0.5" stroke-miterlimit="10" stroke-linecap="round"/>
              </g>
              <defs>
                <clipPath id="clip0_625_4792">
                  <rect width="24.07" height="18" fill="white"/>
                </clipPath>
              </defs>
            </svg>
        </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const video = document.querySelector('.signature-video-element');
    const button = document.querySelector('.signature-video-mute');

    if (!video || !button) return;

    // On load — add class if video is muted
    if (video.muted) {
      button.classList.add('is-muted');
    } else {
      button.classList.remove('is-muted');
    }

    // On click — toggle mute and class
    button.addEventListener('click', function () {
      video.muted = !video.muted;
      video.play();

      if (video.muted) {
        button.classList.add('is-muted');
      } else {
        button.classList.remove('is-muted');
      }
    });
  });
</script>

{% schema %}
{
  "name": "Signature Video Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "title",
      "label": "Signature Image"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "EXPERIENCE NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Upload Video"
    }
  ],
  "presets": [
    {
      "name": "Signature Video Section"
    }
  ]
}
{% endschema %}

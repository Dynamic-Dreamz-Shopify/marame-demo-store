<section class="image-slider-wrapper image-slider-wrapper--homepage{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}">
  <div class="image-slider-container{% if section.settings.full_width %} full_width{% endif %}">
    <div class="image-slider">
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
      <div class="image-slider__arrow-left">
        <svg xmlns="http://www.w3.org/2000/svg" width="6" height="11" viewBox="0 0 6 11" fill="none">
          <path opacity="0.5" d="M5.5 10.5L1 5.5L5.5 1" stroke="#2A2A2D"/>
        </svg>
      </div>
      <div class="image-slider__arrow-right">
        <svg xmlns="http://www.w3.org/2000/svg" width="6" height="11" viewBox="0 0 6 11" fill="none">
          <path opacity="0.5" d="M5.5 10.5L1 5.5L5.5 1" stroke="#2A2A2D"/>
        </svg>
      </div>
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          {% if block.type == 'left_image' %}
            {% if block.settings.image != blank %}
              <a href="{{ block.settings.link | default: 'javascript:void(0)' }}" target="_blank" class="swiper-slide">
                <img
                  loading="lazy" 
                  class="fullscreen__bg__desktop"
                  src="{{ block.settings.image | img_url: 'master' }}"
                  alt="{{ block.settings.image.alt }} {{ shop.name }}"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                >
              </a>
            {% endif %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
    <div class="image-slider">
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
      <div class="image-slider__arrow-left">
        <svg xmlns="http://www.w3.org/2000/svg" width="6" height="11" viewBox="0 0 6 11" fill="none">
          <path opacity="0.5" d="M5.5 10.5L1 5.5L5.5 1" stroke="#2A2A2D"/>
        </svg>
      </div>
      <div class="image-slider__arrow-right">
        <svg xmlns="http://www.w3.org/2000/svg" width="6" height="11" viewBox="0 0 6 11" fill="none">
          <path opacity="0.5" d="M5.5 10.5L1 5.5L5.5 1" stroke="#2A2A2D"/>
        </svg>
      </div>
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          {% if block.type == 'right_image' %}
            {% if block.settings.image != blank %}
              <a href="{{ block.settings.link | default: 'javascript:void(0)' }}" target="_blank" class="swiper-slide">
                <img loading="lazy" class="fullscreen__bg__desktop" src="{{ block.settings.image | img_url: 'original' }}" alt="{{ block.settings.image.alt }} {{ shop.name }}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}">
              </a>
            {% endif %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('shopify:block:select', function (event) {
    load_image_slider();
  });
  
  document.addEventListener('shopify:block:deselect', function (event) {
    load_image_slider();
  });
  
  document.addEventListener('shopify:section:load', () => {
    load_image_slider();
  });
  
  document.addEventListener('shopify:section:unload', (event) => {
    load_image_slider();
  });
</script>
            
{% schema %}
{
  "name": "Image grid slider",
  "class": "image_grid_slider",
  "settings": [
    {
      "type": "text",
      "label": "Custom class",
      "id": "custom_class"
    },
    {
      "type": "checkbox",
      "label": "Full Width",
      "id": "full_width",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "left_image",
      "name": "Left Image",
      "settings": [
        {
          "type": "image_picker",
          "label": "Image",
          "id": "image"
        },
        {
          "type": "url",
          "label": "Link",
          "id": "link"
        }
      ]
    },
    {
      "type": "right_image",
      "name": "Right Image",
      "settings": [
        {
          "type": "image_picker",
          "label": "Image",
          "id": "image"
        },
        {
          "type": "url",
          "label": "Link",
          "id": "link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image grid slider"
    }
  ]
}
{% endschema %}

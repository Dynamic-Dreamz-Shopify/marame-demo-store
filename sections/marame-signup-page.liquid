{{ 'marame-signup-page.css' | asset_url | stylesheet_tag }}
<script src="{{ 'marame-signup-page.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign use_klaviyo_embed = false
  if section.settings.form_mode == 'klaviyo_embed' and section.settings.klaviyo_form_id != blank
    assign use_klaviyo_embed = true
  endif
-%}

{% style %}
  #marame-signup-{{ section.id }} {
    --msp-text: {{ section.settings.color_text }};
    --msp-body-color: {{ section.settings.color_body }};
    --msp-border: {{ section.settings.color_border }};
    --msp-muted: {{ section.settings.color_placeholder }};
    --msp-signup-bg: {{ section.settings.color_signup_glass }};
    --msp-input-bg: {{ section.settings.color_input_bg }};
    --msp-button-bg: {{ section.settings.color_button_bg }};
    --msp-button-color: {{ section.settings.color_button_text }};
    --msp-signup-heading-color: {{ section.settings.color_signup_heading }};
    --msp-headline-size-mobile: {{ section.settings.headline_size_mobile }}px;
    --msp-headline-size-desktop: {{ section.settings.headline_size_desktop }}px;
    --msp-headline-tracking-mobile: {{ section.settings.headline_tracking_mobile }}px;
    --msp-headline-tracking-desktop: {{ section.settings.headline_tracking_desktop }}px;
    --msp-body-size-mobile: {{ section.settings.body_size_mobile }}px;
    --msp-body-size-desktop: {{ section.settings.body_size_desktop }}px;
    --msp-body-tracking-mobile: {{ section.settings.body_tracking_mobile }}px;
    --msp-body-tracking-desktop: {{ section.settings.body_tracking_desktop }}px;
    --msp-body-max-width: {{ section.settings.body_max_width_mobile }}px;
    --msp-body-max-width-desktop: {{ section.settings.body_max_width_desktop }}px;
    --msp-body-line-height: {{ section.settings.body_line_height }}px;
    --msp-signup-heading-tracking: {{ section.settings.signup_heading_tracking }}px;
    {% render 'msp-signup-form-vars', section: section %}
    --msp-headline-body-gap-mobile: {{ section.settings.headline_body_gap_mobile }}px;
    --msp-headline-body-gap-desktop: {{ section.settings.headline_body_gap_desktop }}px;
    --msp-intro-headline-transform: {{ section.settings.headline_text_transform }};
    --msp-intro-body-transform: {{ section.settings.body_text_transform }};
    --msp-intro-pad-top-mobile: {{ section.settings.intro_pad_top_mobile }}px;
    --msp-intro-pad-bottom-mobile: {{ section.settings.intro_pad_bottom_mobile }}px;
    --msp-intro-pad-top-desktop: {{ section.settings.intro_pad_top_desktop }}px;
    --msp-intro-pad-bottom-desktop: {{ section.settings.intro_pad_bottom_desktop }}px;
    --msp-signup-pad-top-mobile: {{ section.settings.signup_pad_top_mobile }}px;
    --msp-signup-pad-bottom-mobile: {{ section.settings.signup_pad_bottom_mobile }}px;
    --msp-signup-pad-top-desktop: {{ section.settings.signup_pad_top_desktop }}px;
    --msp-signup-pad-bottom-desktop: {{ section.settings.signup_pad_bottom_desktop }}px;
    --msp-section-gap-mobile: {{ section.settings.section_gap_mobile }}px;
    --msp-section-gap-desktop: {{ section.settings.section_gap_desktop }}px;
    --msp-hero-blend-mode: {{ section.settings.hero_overlay_blend_mode }};
    --msp-gap-after-intro-mobile: {{ section.settings.gap_after_intro_mobile }}px;
    --msp-gap-after-intro-desktop: {{ section.settings.gap_after_intro_desktop }}px;
    --msp-gap-before-signup-mobile: {{ section.settings.gap_before_signup_mobile }}px;
    --msp-gap-before-signup-desktop: {{ section.settings.gap_before_signup_desktop }}px;
  }
{% endstyle %}

<div
  class="msp"
  id="marame-signup-{{ section.id }}"
  data-marame-signup-page
  data-klaviyo-company="{{ section.settings.klaviyo_company_id | escape }}"
  data-klaviyo-list="{{ section.settings.klaviyo_list_id | escape }}"
  data-success-message="{{ section.settings.success_message | escape }}"
>
  {%- if section.settings.show_hero -%}
    <header class="msp-hero{% if section.settings.enable_scroll_animations %} msp-reveal{% endif %}">
      <div class="msp-hero__image-wrap">
        <div class="msp-hero__image msp-hero__image--mobile">
          {% render 'msp-image',
            image: section.settings.hero_image_mobile,
            fallback_asset: 'marame-signup-hero-mobile.png',
            alt: section.settings.hero_image_alt_mobile,
            class: ''
          %}
        </div>
        <div class="msp-hero__image msp-hero__image--desktop">
          {% render 'msp-image',
            image: section.settings.hero_image_desktop,
            fallback_asset: 'marame-signup-hero-desktop.png',
            alt: section.settings.hero_image_alt_desktop,
            class: ''
          %}
        </div>
        {%- liquid
          assign hero_vid_mobile = section.settings.hero_video_mobile
          if hero_vid_mobile == blank
            assign hero_vid_mobile = section.settings.hero_video_desktop
          endif
        -%}
        <div class="msp-hero__video-wrap">
          {%- if hero_vid_mobile != blank -%}
            {{
              hero_vid_mobile
              | video_tag:
                class: 'msp-hero__video msp-hero__video--mobile',
                autoplay: true,
                loop: true,
                muted: true,
                playsinline: true,
                controls: false,
                preload: 'metadata'
            }}
          {%- endif -%}
          {%- if section.settings.hero_video_desktop != blank -%}
            {{
              section.settings.hero_video_desktop
              | video_tag:
                class: 'msp-hero__video msp-hero__video--desktop',
                autoplay: true,
                loop: true,
                muted: true,
                playsinline: true,
                controls: false,
                preload: 'metadata'
            }}
          {%- endif -%}
          {%- if section.settings.hero_overlay_poster != blank -%}
            {%- if hero_vid_mobile == blank -%}
              {{
                section.settings.hero_overlay_poster
                | image_url: width: 800
                | image_tag:
                  class: 'msp-hero__overlay-poster msp-hero__overlay-poster--mobile',
                  alt: '',
                  loading: 'eager'
              }}
            {%- endif -%}
            {%- if section.settings.hero_video_desktop == blank -%}
              {{
                section.settings.hero_overlay_poster
                | image_url: width: 1200
                | image_tag:
                  class: 'msp-hero__overlay-poster msp-hero__overlay-poster--desktop',
                  alt: '',
                  loading: 'eager'
              }}
            {%- endif -%}
          {%- endif -%}
        </div>
      </div>
    </header>
  {%- endif -%}

  {%- if section.settings.show_mobile_duo -%}
    <div class="msp-media msp-media--duo msp-media--mobile-only msp-section-gap">
      <div class="msp-media__cell msp-media__cell--tall{% if section.settings.enable_scroll_animations %} msp-reveal{% endif %}">
        {% render 'msp-image',
          image: section.settings.image_fabric,
          fallback_asset: 'marame-signup-grid-fabric-white.png',
          alt: section.settings.image_fabric_alt,
          class: ''
        %}
      </div>
      <div class="msp-media__cell msp-media__cell--tall{% if section.settings.enable_scroll_animations %} msp-reveal{% endif %}">
        {% render 'msp-image',
          image: section.settings.image_portrait_brown,
          fallback_asset: 'marame-signup-grid-portrait-brown.png',
          alt: section.settings.image_portrait_brown_alt,
          class: ''
        %}
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.show_intro -%}
    <div class="msp-intro{% if section.settings.enable_scroll_animations %} msp-reveal{% endif %}">
      {%- if section.settings.headline != blank -%}
        <h1 class="msp-intro__headline">{{ section.settings.headline }}</h1>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="msp-intro__body">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.settings.show_desktop_trio -%}
    <div class="msp-media msp-media--trio msp-media--desktop-only">
      <div class="msp-media__cell msp-media__cell--tall{% if section.settings.enable_scroll_animations %} msp-reveal{% endif %}">
        {% render 'msp-image',
          image: section.settings.image_fabric,
          fallback_asset: 'marame-signup-grid-fabric-white.png',
          alt: section.settings.image_fabric_alt,
          class: ''
        %}
      </div>
      <div class="msp-media__cell msp-media__cell--portrait{% if section.settings.enable_scroll_animations %} msp-reveal{% endif %}">
        {% render 'msp-image',
          image: section.settings.image_portrait_brown,
          fallback_asset: 'marame-signup-grid-portrait-brown.png',
          alt: section.settings.image_portrait_brown_alt,
          class: ''
        %}
      </div>
      <div class="msp-media__cell msp-media__cell--sq{% if section.settings.enable_scroll_animations %} msp-reveal{% endif %}">
        {% render 'msp-image',
          image: section.settings.image_portrait_polo,
          fallback_asset: 'marame-signup-grid-portrait-polo.png',
          alt: section.settings.image_portrait_polo_alt,
          class: ''
        %}
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.show_mobile_running_video -%}
    <div class="msp-running-video-wrap msp-running-video-wrap--mobile msp-section-gap{% if section.settings.enable_scroll_animations %} msp-reveal{% endif %}">
      {% render 'msp-running-video', section: section, class: 'msp-running-video--wide' %}
    </div>
  {%- endif -%}

  {%- if section.settings.show_signup -%}
    <div class="msp-signup-wrap{% if section.settings.enable_scroll_animations %} msp-reveal{% endif %}">
      {% render 'msp-signup-form', section: section, use_klaviyo_embed: use_klaviyo_embed %}
    </div>
  {%- endif -%}

  {%- if section.settings.show_mobile_closeup -%}
    <div class="msp-media msp-media--mobile-only msp-section-gap">
      <div class="msp-media__cell msp-media__cell--wide{% if section.settings.enable_scroll_animations %} msp-reveal{% endif %}">
        {% render 'msp-image',
          image: section.settings.image_closeup,
          fallback_asset: 'marame-signup-grid-closeup.png',
          alt: section.settings.image_closeup_alt,
          class: ''
        %}
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.show_mobile_lower_grid -%}
    <div class="msp-media msp-media--duo-lower msp-media--mobile-only msp-section-gap">
      <div class="msp-media__cell msp-media__cell--sq{% if section.settings.enable_scroll_animations %} msp-reveal{% endif %}">
        {% render 'msp-image',
          image: section.settings.image_result_square,
          fallback_asset: 'marame-signup-grid-result-square.png',
          alt: section.settings.image_result_square_alt,
          class: ''
        %}
      </div>
      <div class="msp-media__cell msp-media__cell--tall{% if section.settings.enable_scroll_animations %} msp-reveal{% endif %}">
        {% render 'msp-image',
          image: section.settings.image_orange_skirt,
          fallback_asset: 'marame-signup-grid-orange-skirt.png',
          alt: section.settings.image_orange_skirt_alt,
          class: ''
        %}
      </div>
    </div>

    {%- if section.settings.show_mobile_embroidery -%}
      <div class="msp-media msp-media--mobile-only">
        <div class="msp-media__cell msp-media__cell--full{% if section.settings.enable_scroll_animations %} msp-reveal{% endif %}">
          {% render 'msp-image',
            image: section.settings.image_embroidery,
            fallback_asset: 'marame-signup-grid-embroidery.png',
            alt: section.settings.image_embroidery_alt,
            class: ''
          %}
        </div>
      </div>
    {%- endif -%}
  {%- endif -%}

  {%- comment -%} Desktop: close-up + running video after signup {%- endcomment -%}
  {%- if section.settings.show_desktop_lower_grid -%}
    <div class="msp-media msp-media--duo msp-media--desktop-only msp-section-gap">
      <div class="msp-media__cell msp-media__cell--desktop-closeup{% if section.settings.enable_scroll_animations %} msp-reveal{% endif %}">
        {% render 'msp-image',
          image: section.settings.image_closeup,
          fallback_asset: 'marame-signup-grid-closeup.png',
          alt: section.settings.image_closeup_alt,
          class: ''
        %}
      </div>
      <div class="msp-media__cell msp-media__cell--desktop-video{% if section.settings.enable_scroll_animations %} msp-reveal{% endif %}">
        {% render 'msp-running-video', section: section, class: '' %}
      </div>
    </div>
  {%- endif -%}

  <div
    class="msp-modal"
    data-msp-terms-modal
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-labelledby="msp-terms-title-{{ section.id }}"
  >
    <div class="msp-modal__dialog">
      <button type="button" class="msp-modal__close" data-msp-terms-close aria-label="Close">&times;</button>
      <h2 class="msp-modal__title" id="msp-terms-title-{{ section.id }}">
        {{ section.settings.terms_modal_title }}
      </h2>
      <div class="msp-modal__content rte">
        {{ section.settings.terms_content }}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Signup (legacy)",
  "tag": "section",
  "class": "section-marame-signup-page",
  "settings": [
    {
      "type": "paragraph",
      "content": "Edit all copy and images below. Header and footer are unchanged — this section is the page content only. Use the pre-access page template."
    },
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "checkbox",
      "id": "show_hero",
      "label": "Show hero",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "hero_image_desktop",
      "label": "Hero image — desktop"
    },
    {
      "type": "image_picker",
      "id": "hero_image_mobile",
      "label": "Hero image — mobile"
    },
    {
      "type": "text",
      "id": "hero_image_alt_desktop",
      "label": "Hero alt text — desktop",
      "default": "Marame collection campaign"
    },
    {
      "type": "text",
      "id": "hero_image_alt_mobile",
      "label": "Hero alt text — mobile",
      "default": "Marame collection campaign"
    },
    {
      "type": "video",
      "id": "hero_video_desktop",
      "label": "Hero overlay video — desktop",
      "info": "Transparent WebM/MOV (animated logo). Loops over the hero image."
    },
    {
      "type": "video",
      "id": "hero_video_mobile",
      "label": "Hero overlay video — mobile"
    },
    {
      "type": "image_picker",
      "id": "hero_overlay_poster",
      "label": "Hero logo overlay — static fallback",
      "info": "Shown when no overlay video is uploaded (PNG with transparency). Upload your handwritten logo export here until the video is ready."
    },
    {
      "type": "select",
      "id": "hero_overlay_blend_mode",
      "label": "Hero overlay blend mode",
      "info": "Use Lighten for black-background logo videos (same as Figma). Set None if your video already has transparency.",
      "options": [
        { "value": "normal", "label": "None" },
        { "value": "lighten", "label": "Lighten" },
        { "value": "screen", "label": "Screen" },
        { "value": "multiply", "label": "Multiply" },
        { "value": "overlay", "label": "Overlay" },
        { "value": "soft-light", "label": "Soft light" }
      ],
      "default": "lighten"
    },
    {
      "type": "header",
      "content": "Intro text"
    },
    {
      "type": "checkbox",
      "id": "show_intro",
      "label": "Show intro",
      "default": true
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "launching june 26"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We are delighted to announce our new Marame Collection range launching this June, co-designed with Melissa Murrell"
    },
    {
      "type": "select",
      "id": "headline_text_transform",
      "label": "Headline letter case",
      "options": [
        { "value": "uppercase", "label": "ALL CAPS" },
        { "value": "none", "label": "Normal (as typed)" },
        { "value": "capitalize", "label": "Capitalize each word" }
      ],
      "default": "uppercase"
    },
    {
      "type": "select",
      "id": "body_text_transform",
      "label": "Body letter case",
      "options": [
        { "value": "none", "label": "Normal (as typed)" },
        { "value": "uppercase", "label": "ALL CAPS" },
        { "value": "capitalize", "label": "Capitalize each word" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "headline_size_mobile",
      "label": "Headline size — mobile",
      "min": 14,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "headline_size_desktop",
      "label": "Headline size — desktop",
      "min": 20,
      "max": 56,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "headline_tracking_mobile",
      "label": "Headline letter-spacing — mobile",
      "min": 0,
      "max": 12,
      "step": 0.2,
      "unit": "px",
      "default": 4.2
    },
    {
      "type": "range",
      "id": "headline_tracking_desktop",
      "label": "Headline letter-spacing — desktop",
      "min": 0,
      "max": 16,
      "step": 0.2,
      "unit": "px",
      "default": 6.8
    },
    {
      "type": "range",
      "id": "body_size_mobile",
      "label": "Body size — mobile",
      "min": 9,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "range",
      "id": "body_size_desktop",
      "label": "Body size — desktop",
      "min": 11,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "body_tracking_mobile",
      "label": "Body letter-spacing — mobile",
      "min": 0,
      "max": 4,
      "step": 0.1,
      "unit": "px",
      "default": 1.3
    },
    {
      "type": "range",
      "id": "body_tracking_desktop",
      "label": "Body letter-spacing — desktop",
      "min": 0,
      "max": 4,
      "step": 0.1,
      "unit": "px",
      "default": 1.8
    },
    {
      "type": "range",
      "id": "body_line_height",
      "label": "Body line height",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "body_max_width_mobile",
      "label": "Body max width — mobile",
      "min": 200,
      "max": 400,
      "step": 4,
      "unit": "px",
      "default": 320
    },
    {
      "type": "range",
      "id": "body_max_width_desktop",
      "label": "Body max width — desktop",
      "min": 320,
      "max": 720,
      "step": 4,
      "unit": "px",
      "default": 544
    },
    {
      "type": "header",
      "content": "Gallery — mobile row under hero"
    },
    {
      "type": "checkbox",
      "id": "show_mobile_duo",
      "label": "Show mobile 2-image row",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image_fabric",
      "label": "Image — fabric (left)"
    },
    {
      "type": "text",
      "id": "image_fabric_alt",
      "label": "Alt text — fabric",
      "default": "White fabric detail"
    },
    {
      "type": "image_picker",
      "id": "image_portrait_brown",
      "label": "Image — portrait brown top"
    },
    {
      "type": "text",
      "id": "image_portrait_brown_alt",
      "label": "Alt text — portrait brown",
      "default": "Model in brown top"
    },
    {
      "type": "header",
      "content": "Gallery — desktop 3-image row"
    },
    {
      "type": "checkbox",
      "id": "show_desktop_trio",
      "label": "Show desktop 3-image row",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image_portrait_polo",
      "label": "Image — portrait polo (desktop only)"
    },
    {
      "type": "text",
      "id": "image_portrait_polo_alt",
      "label": "Alt text — portrait polo",
      "default": "Model in knit polo"
    },
    {
      "type": "header",
      "content": "Running video (woman on beach)"
    },
    {
      "type": "checkbox",
      "id": "show_mobile_running_video",
      "label": "Show on mobile (between intro and signup)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_desktop_lower_grid",
      "label": "Show on desktop (after signup — right column is video)",
      "default": true
    },
    {
      "type": "video",
      "id": "running_video",
      "label": "Running video file"
    },
    {
      "type": "checkbox",
      "id": "running_video_show_controls",
      "label": "Show video controls",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "running_video_poster",
      "label": "Poster image (if no video uploaded)"
    },
    {
      "type": "text",
      "id": "running_video_alt",
      "label": "Video / poster alt text",
      "default": "Campaign video"
    },
    {
      "type": "header",
      "content": "Gallery — mobile close-up (after signup)"
    },
    {
      "type": "checkbox",
      "id": "show_mobile_closeup",
      "label": "Show mobile close-up image",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image_closeup",
      "label": "Image — close-up campaign"
    },
    {
      "type": "text",
      "id": "image_closeup_alt",
      "label": "Alt text — close-up",
      "default": "Campaign close-up"
    },
    {
      "type": "header",
      "content": "Klaviyo signup"
    },
    {
      "type": "checkbox",
      "id": "show_signup",
      "label": "Show signup block",
      "default": true
    },
    {
      "type": "select",
      "id": "form_mode",
      "label": "Form type",
      "options": [
        { "value": "klaviyo_embed", "label": "Klaviyo embed (recommended)" },
        { "value": "custom", "label": "Custom API form (fallback)" }
      ],
      "default": "klaviyo_embed"
    },
    {
      "type": "text",
      "id": "klaviyo_form_id",
      "label": "Klaviyo form ID",
      "info": "6-character ID from Klaviyo → Sign-up forms → embed code (e.g. U8Y5hR). Styled to match this design.",
      "default": "U8Y5hR"
    },
    {
      "type": "checkbox",
      "id": "signup_glass",
      "label": "Frosted glass card on desktop",
      "default": true
    },
    {
      "type": "text",

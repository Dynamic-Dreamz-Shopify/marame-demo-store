<section class="fullscreen row">
  <div class="fullscreen__bg fullscreen__bg--no-mobile-img">
    {% if section.settings.image_desktop != blank %}
      <img
        class="fullscreen__bg__desktop{% if section.settings.image_mobile != blank %} small_hide{% endif %}"
        src="{{ section.settings.image_desktop | img_url: 'master' }}"
        alt=""
        data-p-speed="0.15"
      >
    {% endif %}
    {% if section.settings.image_mobile != blank %}
      <img
        class="fullscreen__bg__mobile_ large_hide"
        src="{{ section.settings.image_mobile | img_url: 'master' }}"
        alt=""
      >
    {% endif %}
  </div>
  <div class="fullscreen__content col--6 col--md--4 col--lg--4">
    <ul class="fullscreen__content__links">
      {% for block in section.blocks %}
        {% if block.settings.text != blank %}
          <li>
            <a href="{{ block.settings.link | default: 'javascript:void(0)' }}">
              <h6>{{ block.settings.text }}</h6>
            </a>
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Fullscreen banner block",
  "class": "fullscreen_banner_block",
  "settings": [
    {
      "type": "image_picker",
      "label": "Image Desktop",
      "id": "image_desktop"
    },
    {
      "type": "image_picker",
      "label": "Image Mobile",
      "id": "image_mobile"
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Link",
      "settings": [
        {
          "type": "text",
          "label": "Text",
          "id": "text"
        },
        {
          "type": "url",
          "label": "Link",
          "id": "link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fullscreen banner block"
    }
  ]
}
{% endschema %}

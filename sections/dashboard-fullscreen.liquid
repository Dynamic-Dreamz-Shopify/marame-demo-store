{% if section.settings.image != blank or section.settings.mobile_image != blank %}
  <section class="fullscreen row gradient text--white">
    <div class="fullscreen__bg fullscreen__bg--no-mobile-img">
      <img
        class="fullscreen__bg__desktop{% if section.settings.mobile_image != blank %} small_hide{% endif %}"
        src="{{ section.settings.image | img_url: 'master' }}"
        alt="{{ section.settings.image.alt }}"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        loading="eager" fetchpriority="high"
        data-p-speed="0.15"
      >
      {% if section.settings.mobile_image != blank %}
        <img
          class="fullscreen_bg__mobile large_hide"
          src="{{ section.settings.mobile_image | img_url: 'master' }}"
          alt="{{ section.settings.mobile_image.alt }}"
          width="{{ section.settings.mobile_image.width }}"
          height="{{ section.settings.mobile_image.height }}"
          loading="eager" fetchpriority="high"
          data-p-speed="0.15"
        >
      {% endif %}
    </div>
    <div class="fullscreen__content col--6 col--md--3 col--lg--3">
      {% if section.settings.heading != blank %}
        <h2>MENS SUMMER 25 LOOKBOOK</h2>
      {% endif %}
      {% if section.settings.button_lable != blank %}
        <div class="splitscreen__item__content__ctas">
          <a
            href="{{ section.settings.button_url | default: 'javascript:void(0)' }}"
            class="btn btn--underline btn--light"
          >
            <h4>{{ section.settings.button_lable }}</h4>
          </a>
        </div>
      {% endif %}
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Dashboard Fullscreen",
  "settings": [
    {
      "type": "image_picker",
      "label": "Image",
      "id": "image"
    },
    {
      "type": "image_picker",
      "label": "Mobile Image",
      "id": "mobile_image"
    },
    {
      "type": "text",
      "label": "Heading",
      "id": "heading"
    },
    {
      "type": "text",
      "label": "Button Lable",
      "id": "button_lable"
    },
    {
      "type": "url",
      "label": "Button URL",
      "id": "button_url"
    }
  ],
  "presets": [
    {
      "name": "Dashboard Fullscreen"
    }
  ]
}
{% endschema %}

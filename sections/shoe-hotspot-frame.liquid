{{ 'shoe-hotspot-frame.css' | asset_url | stylesheet_tag }}

{% if section.settings.background_color != blank %}
<style>
    .shoe-hotspot-frame {
        background-color: {{ section.settings.background_color }};
    }
    
    @media (max-width: 767px) {
        .shoe-hotspot-frame .shoe-image-wrapper {
            padding: 0 {{ section.settings.mob_padding }}px;
        }
    }
</style>
{% endif %}

<section class="shoe-hotspot-frame">
    <div class="shoe-hotspot-inner">
        {% if section.settings.link != blank %}
        <a href="{{ section.settings.link }}">
        {% endif %}
            <div class="shoe-image-wrapper">
            {% if section.settings.shoe_image != blank %}
                <img src="{{ section.settings.shoe_image | img_url: 'master' }}" alt="Shoe Image" class="shoe-image" width="100%" height="100%" loading="lazy">
            {% endif %}
            </div>

            {% if section.settings.title1 != blank %}
                <div class="hotspot hotspot-left">
                <span class="label">{{ section.settings.title1 }}</span>
                </div>
            {% endif %}
            
            {% if section.settings.title2 != blank %}
                <div class="hotspot hotspot-right">
                <span class="label">{{ section.settings.title2 }}</span>
                </div>
            {% endif %}
        {% if section.settings.link != blank %}
        </a>
        {% endif %}
    </div>
</section>

{% schema %}
{
  "name": "Shoe Hotspot Frame",
  "settings": [
    {
        "type": "image_picker",
        "id": "shoe_image",
        "label": "Shoe image"
    },
    {
        "type": "text",
        "id": "title1",
        "label": "Title 1"
    },
    {
        "type": "text",
        "id": "title2",
        "label": "Title 2"
    },
    {
        "type": "url",
        "id": "link",
        "label": "Link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "number",
      "id": "mob_padding",
      "label": "Mobile Image Set",
    }
  ],
  "presets": [
    {
      "name": "Shoe Hotspot Frame"
    }
  ]
}
{% endschema %}
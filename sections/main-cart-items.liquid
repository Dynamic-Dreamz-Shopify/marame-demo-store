  <svg xmlns="http://www.w3.org/2000/svg" width="7" height="3" viewBox="0 0 7 3" fill="none"><path d="M6.888 2.168H0.518V0.95H6.888V2.168Z" fill="#2A2A2D"/></svg>
{% endcapture %}
{% capture warning_icon %}
  <svg class="svg-warning-icon" width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M7.5 15C11.6421 15 15 11.6421 15 7.5C15 3.35786 11.6421 0 7.5 0C3.35786 0 0 3.35786 0 7.5C0 11.6421 3.35786 15 7.5 15Z" fill="#F90000"/><path d="M7.5 11.25C7.625 11.25 7.75 11.25 7.875 11.125C8 11 8 10.875 8 10.75C8 10.625 8 10.5 7.875 10.375C7.75 10.25 7.625 10.25 7.5 10.25C7.375 10.25 7.25 10.25 7.125 10.375C7 10.5 7 10.625 7 10.75C7 10.875 7 11 7.125 11.125C7.25 11.25 7.375 11.25 7.5 11.25ZM7.125 9.125H7.875V3.75H7.125V9.125Z" fill="white"/></svg>

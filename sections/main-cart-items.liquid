  <svg xmlns="http://www.w3.org/2000/svg" width="7" height="7" viewBox="0 0 7 7" fill="none"><path d="M4.368 2.9H6.888V4.132H4.368V6.638H3.038V4.132H0.518V2.9H3.038V0.379999H4.368V2.9Z" fill="#2A2A2D"/></svg>

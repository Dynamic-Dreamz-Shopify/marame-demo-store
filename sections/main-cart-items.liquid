<div class="cart-container" id="cartPage">
  {{ 'component-cart.css' | asset_url | stylesheet_tag }}
  {{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
  {{ 'component-totals.css' | asset_url | stylesheet_tag }}

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  {%- unless settings.cart_type == 'drawer' -%}
    <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
  {%- endunless -%}

  {% assign color_option = 'color' %}
  {% assign size_option = 'size' %}
  
  {%- if cart == empty -%}
    <section class="your-cart is-empty">
      <h2 class="cart-page-title">Your cart is empty</h2>
    </section>
  {%- else -%}
  <section class="your-cart">
    <h2 class="cart-page-title">{{ 'sections.cart.title' | t }}</h2>

    <div class="your-cart__wrapper">
      <div class="product-table desktop-only">
        <table>
          <thead>
            <tr>
              <th class="col image-title-col"></th>
              <th class="col remove-btn-col"></th>
              <th class="col color-col">COLOUR</th>
              <th class="col size-col">Size</th>
              <th class="col unit-price-col">Unit Price</th>
              <th class="col total-price-col">Total Price</th>
              <th class="col qty-col">Quantity</th>
            </tr>
          </thead>
          <tbody>
            {%- for item in cart.items -%}

              {% assign diffSizeFoundDesk = false %}
              {% unless item.product.type contains "Gift card" %}
              {%- for l_item in cart.items -%}                
                {% if item.id != l_item.id %}
                  {% if l_item.product.id == item.product.id %}
                    {% assign diffSizeFoundDesk = true %}
                    {% break %}
                  {% endif %}
                {% endif %}
              {% endfor %}
              {% endunless %}
              <tr class="product-row{% if diffSizeFoundDesk %} product-row_diff-size-found{% endif %}" line_key="{{ item.key }}" item_variant_id="{{ item.variant.id }}">
                <td class="col image-title-col">
                  {%- render 'loading-spinner' -%}
                  <div class="product-cell">
                    <div class="product-image" onclick="location.href='{{ item.url }}'">
                      {% if item.variant.featured_media != null %}
                        <img
                          class="product-image default_image"
                          src="{{ item.variant.featured_image | img_url: 'master' }}"
                          alt="Product Image"
                          width="{{ item.variant.featured_image.width }}"
                          height="{{ item.variant.featured_image.height }}"
                          loading="lazy"
                        >
                      {% else %}
                        <img
                          class="product-image default_image"
                          src="{{ item.product.featured_image | img_url: 'master' }}"
                          alt="Product Image"
                          width="{{ item.product.featured_image.width }}"
                          height="{{ item.product.featured_image.height }}"
                          loading="lazy"
                        >
                      {% endif %}
                      {% assign men_image = false %}
                      {% assign women_image = false %}
                      {% for media in item.product.media %}
                        {% if media.alt contains 'womens' %}
                          {% unless women_image %}
                            {% assign women_image = true %}
                            <img
                              class="product-image"
                              src="{{ media | img_url: 'master' }}"
                              alt="{{ media.alt }}"
                              width="{{ media.width }}"
                              height="{{ media.height }}"
                              loading="lazy"
                              style="display: none;"
                            >
                          {% endunless %}
                        {% elsif media.alt contains 'mens' %}
                          {% unless men_image %}
                            {% assign men_image = true %}
                            <img
                              class="product-image"
                              src="{{ media | img_url: 'master' }}"
                              alt="{{ media.alt }}"
                              width="{{ media.width }}"
                              height="{{ media.height }}"
                              loading="lazy"
                              style="display: none;"
                            >
                          {% endunless %}
                        {% endif %}
                      {% endfor %}
                    </div>
                    <div class="product-details cart-desktop-title">
                      <a href="{{ item.url }}" class="cart_pro_link">{{ item.product.title }}</a>
                    </div>
                  </div>
                </td>
                <td class="col remove-btn-col item_remove_inner">
                  <div class="product-details cart-mobile-title">
                      <a href="{{ item.url }}" class="cart_pro_link">{{ item.product.title }}</a>
                    </div>
                  <div class="remove_item cursor_pointer">
                    {{ close_icon }}
                  </div>
                </td>
                <td col-title="COLOUR" class="col color-col">
                  {%- assign colorVal = blank -%}
                  {%- if item.product.has_only_default_variant == false -%}
                      {%- for option in item.options_with_values -%}
                        {% assign option_name = option.name | downcase %}
                        {% if option_name == color_option %}
                          {% assign colorVal = option.value %}
                        {% endif %}
                      {%- endfor -%}
                    {%- endif -%}
                    {{- colorVal | default:"-" -}}
                </td>
                <td  col-title="Size" class="col size-col">
                  <span class="size-col-wrap">
                    {%- assign sizeVal = blank -%}
                    {%- if item.product.has_only_default_variant == false -%}
                    {%- for option in item.options_with_values -%}
                      {%- assign option_name = option.name | downcase -%}
                      {%- if option_name == size_option or option_name == 'shoe size' -%}
                        {%- assign sizeVal = option.value -%}
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}
                  {{- sizeVal | default:"-" -}}
                  <span class="warning-icon-wrap">{{ warning_icon }}</span>
                  </span>
                </td>
                <td col-title="Unit Price" class="unit-price-col col">{{ item.price | money }}</td>
                <td col-title="Total Price" class="total-price-col col">{{ item.price | times: item.quantity | money }}</td>
                <td class="col qty-col">
                  <div class="qty_update">
                    <span class="qty_minus qty_action">{{ minus_icon }}</span>
                    <input
                      class="quantity__input"
                      type="number"
                      value="{{ item.quantity }}"
                      min="1"
                      {% if item.variant.quantity_rule.max != null %}
                        max="{{ item.variant.quantity_rule.max }}"
                      {% endif %}
                      step="{{ item.variant.quantity_rule.increment }}"
                    >
                    <span class="qty_plus qty_action">{{ plus_icon }}</span>
                  </div>
                </td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      </div>

      <div class="product-table mobile-only product-mobile-table">
        <div class="product-row-group">
          
          {%- for item in cart.items -%}
              {% assign diffSizeFound = false %}
              {% unless item.product.type contains "Gift card" %}
              {%- for l_item in cart.items -%}
                {% if item.id != l_item.id %}
                  {% if l_item.product.id == item.product.id %}
                    {% assign diffSizeFound = true %}
                    {% break %}
                  {% endif %}
                {% endif %}
              {% endfor %}
              {% endunless %}
              <div class="product-row{% if diffSizeFound %} product-row_diff-size-found{% endif %}" line_key="{{ item.key }}" item_variant_id="{{ item.variant.id }}">
                {%- render 'loading-spinner' -%}
                <div class="col image-title-col">
                  <div class="product-cell">
                    <div class="product-image" onclick="location.href='{{ item.url }}'">
                      {% if item.variant.featured_media != null %}
                        <img
                          class="product-image default_image"
                          src="{{ item.variant.featured_image | img_url: 'master' }}"
                          alt="Product Image"
                          width="{{ item.variant.featured_image.width }}"
                          height="{{ item.variant.featured_image.height }}"
                          loading="lazy"
                        >
                      {% else %}
                        <img
                          class="product-image default_image"
                          src="{{ item.product.featured_image | img_url: 'master' }}"
                          alt="Product Image"
                          width="{{ item.product.featured_image.width }}"
                          height="{{ item.product.featured_image.height }}"
                          loading="lazy"
                        >
                      {% endif %}
                      {% assign men_image = false %}
                      {% assign women_image = false %}
                      {% for media in item.product.media %}
                        {% if media.alt contains 'womens' %}
                          {% unless women_image %}
                            {% assign women_image = true %}
                            <img
                              class="product-image"
                              src="{{ media | img_url: 'master' }}"
                              alt="{{ media.alt }}"
                              width="{{ media.width }}"
                              height="{{ media.height }}"
                              loading="lazy"
                              style="display: none;"
                            >
                          {% endunless %}
                        {% elsif media.alt contains 'mens' %}
                          {% unless men_image %}
                            {% assign men_image = true %}
                            <img
                              class="product-image"
                              src="{{ media | img_url: 'master' }}"
                              alt="{{ media.alt }}"
                              width="{{ media.width }}"
                              height="{{ media.height }}"
                              loading="lazy"
                              style="display: none;"
                            >
                          {% endunless %}
                        {% endif %}
                      {% endfor %}
                    </div>
                  </div>
                </div>
                <div class="item-info-wrap">
                  <div class="item-info-title">
                    <div class="product-details cart-mobile-title">
                        <a href="{{ item.url }}" class="cart_pro_link">{{ item.product.title }}</a>
                      </div>
                  </div>
                  <div class="item-info-col-wrap">
                    <div class="item-info-col left-col">
                      <ul>
                        {%- if item.product.has_only_default_variant == false -%}
                        {%- for option in item.options_with_values -%}
                          {% assign option_name = option.name | downcase %}
                          {% assign option_name_size = option.name | downcase %}
                          {% if option_name == color_option %}
                          <li>
                            <span class="item-infolist-title">COLOUR</span>
                            <span class="item-info-value">{{ option.value }}</span>
                          </li>
                        {% elsif option_name_size == size_option or option_name_size == 'shoe size' %}
                          <li>
                            <span class="item-infolist-title">SIZE{{ warning_icon }}</span>
                            <span class="item-info-value">{{ option.value }}</span>
                          </li>
                          {% endif %}
                        {%- endfor -%}
                        {%- endif -%}
                        <li>
                          <span class="item-infolist-title">UNIT PRICE</span>
                          <span class="item-info-value">{{ item.price | money }}</span>
                        </li>
                        <li>
                          <span class="item-infolist-title">TOTAL PRICE</span>
                          <span class="item-info-value">{{ item.price | times: item.quantity | money }}</span>
                        </li>
                      </ul>  
                    </div>
                    <div class="col qty-col">
                      <div class="remove_item cursor_pointer">{{ close_icon }}</div>
                      <div class="qty_update">
                        <span class="qty_minus qty_action">{{ minus_icon }}</span>
                        <input
                          class="quantity__input"
                          type="number"
                          value="{{ item.quantity }}"
                          min="1"
                          {% if item.variant.quantity_rule.max != null %}
                            max="{{ item.variant.quantity_rule.max }}"
                          {% endif %}
                          step="{{ item.variant.quantity_rule.increment }}"
                        >
                        <span class="qty_plus qty_action">{{ plus_icon }}</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
        </div>
      </div>

      <div class="cart-warning-info">
        <div class="cart-warning-info-wrap">
          <div class="cart-warning-icon"><svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M10 20C15.5228 20 20 15.5228 20 10C20 4.47715 15.5228 0 10 0C4.47715 0 0 4.47715 0 10C0 15.5228 4.47715 20 10 20Z" fill="#F90000"/><path d="M10.0007 15C10.1673 15 10.334 15 10.5007 14.8333C10.6673 14.6667 10.6673 14.5 10.6673 14.3333C10.6673 14.1667 10.6673 14 10.5007 13.8333C10.334 13.6667 10.1673 13.6667 10.0007 13.6667C9.83398 13.6667 9.66733 13.6667 9.50066 13.8333C9.33399 14 9.33398 14.1667 9.33398 14.3333C9.33398 14.5 9.33399 14.6667 9.50066 14.8333C9.66733 15 9.83398 15 10.0007 15ZM9.50066 12.1667H10.5007V5H9.50066V12.1667Z" fill="white"/></svg></div>
          <div class="cart-warning-text">
            <p><strong>It looks like you’ve added the same item in multiple sizes. </strong>While we understand the temptation to try more than one, we do our best to help you choose the right fit the first time through our detailed Fit & Features section and Size Guide listed on our product pages.</p>
            <p>Returns have an environmental and financial impact, so we kindly encourage you to select one size based on the guidance provided. If it doesn’t fit, exchanges are completely free, while returns carry a £3 processing fee.</p>
            <p>Thank you for shopping thoughtfully.</p>
          </div>
        </div>
      </div>

      <div class="summary-table">
        <div class="cart-checkbox">
          <input id="packing_info"{% unless cart.note contains 'Parcel to be unscented' %}checked{% endunless %} type="checkbox">
          <label for="packing_info" class="flexbox">
            <span class="custom-checkbox-svg">
              <svg width="134" height="134" viewBox="0 0 134 134" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M71.0951 81.4906L104.919 65.4689L57.7437 59.2382L57.7437 79.4945L71.0951 81.4906Z" fill="#D7D7D7"/>
                <path d="M17.5122 101.755L71.0951 109.602L71.0951 81.4906L57.7437 79.4945L17.5122 73.4798L17.5122 101.755Z" fill="white"/>
